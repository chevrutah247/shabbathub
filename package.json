{
  "name": "shabbathub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backfill:previews": "node backfill-previews.mjs",
    "backfill:previews:dry": "node backfill-previews.mjs --dry-run",
    "import:levi:scan": "node import-levi-archive.mjs scan",
    "import:levi:plan": "node import-levi-archive.mjs import",
    "import:levi:apply": "node import-levi-archive.mjs import --apply",
    "cleanup:large:plan": "node cleanup-large-files.mjs --max-mb=25",
