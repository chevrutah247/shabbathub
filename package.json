    "index:issues:plan": "node index-issues-content.mjs --limit=100",
    "index:issues:apply": "node index-issues-content.mjs --apply --limit=100",
    "summaries:plan": "node summarize-issues.mjs --limit=100",
    "summaries:apply": "node summarize-issues.mjs --apply --limit=100"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/supabase-js": "^2.78.0",
    "@upstash/redis": "^1.36.2",
    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
