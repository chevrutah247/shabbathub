\uc0\u1057 \u1074 \u1103 \u1090 \u1086 \u1089 \u1090 \u1100  \u1082 \u1088 \u1077 \u1087 \u1082 \u1086  \u1080  \u1085 \u1077 \u1078 \u1085 \u1086  \u1074 \u1079 \u1103 \u1083 \u1072  \u1077 \u1075 \u1086  \u1089 \u1077 \u1088 \u1076 \u1094 \u1077 , \u1086 \u1073 \u1085 \u1103 \u1083 \u1072  \u1076 \u1091 \u1096 \u1091 , \u1087 \u1088 \u1080 \u1082 \u1086 \u1089 \u1085 \u1091 \u1083 \u1072 \u1089 \u1100  \u1082  \u1089 \u1072 \u1084 \u1086 \u1084 \u1091  \u1089 \u1086 \u1082 \u1088 \u1086 \u1074 \u1077 \u1085 \u1085 \u1086 \u1084 \u1091 . \u1048  \u1085 \u1080 \u1095 \u1077 \u1075 \u1086  \u1073 \u1086 \u1083 \u1100 \u1096 \u1077  \u1085 \u1077  \u1093 \u1086 \u1090 \u1077 \u1083 \u1086 \u1089 \u1100  \u1074  \u1078 \u1080 \u1079 \u1085 \u1080 , \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1073 \u1099  \u1085 \u1077  \u1082 \u1086 \u1085 \u1095 \u1072 \u1083 \u1080 \u1089 \u1100  \u1101 \u1090 \u1080  \u1089 \u1083 \u1072 \u1076 \u1082 \u1080 \u1077  \u1084 \u1080 \u1085 \u1091 \u1090 \u1099 , \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1073 \u1099  \u1079 \u1074 \u1091 \u1095 \u1072 \u1083  \u1080  \u1079 \u1074 \u1091 \u1095 \u1072 \u1083  \u1093 \u1088 \u1080 \u1087 \u1083 \u1086 \u1074 \u1072 \u1090 \u1099 \u1081  \u1075 \u1086 \u1083 \u1086 \u1089  \u1052 \u1072 \u1075 \u1080 \u1076 \u1072 . \
