\'97 \uc0\u1054 \u1090 \u1082 \u1091 \u1076 \u1072  \u1077 \u1074 \u1088 \u1077 \u1081 ?\
\'97 \uc0\u1048 \u1079  \u1057 \u1090 \u1072 \u1085 \u1080 \u1089 \u1083 \u1072 \u1074 \u1080 \u1094 \u1077 .\
\'97 \uc0\u1048 \u1079  \u1057 \u1090 \u1072 \u1085 \u1080 \u1089 \u1083 \u1072 \u1074 \u1080 \u1094 \u1077 ? \'97 \u1087 \u1086 \u1074 \u1090 \u1086 \u1088 \u1080 \u1083  \u1052 \u1072 \u1075 \u1080 \u1076 . \'97 \u1058 \u1072 \u1082  \u1101 \u1090 \u1086  \u1074 \u1077 \u1076 \u1100  \u1084 \u1086 \u1081  \u1088 \u1072 \u1081 \u1086 \u1085 . \u1055 \u1086 \u1095 \u1077 \u1084 \u1091  \u1078 \u1077  \u1090 \u1099  \u1085 \u1077  \u1087 \u1088 \u1080 \u1074 \u1077 \u1079  \u1084 \u1085 \u1077  \u1096 \u1072 \u1083 \u1072 \u1093 \u1084 \u1086 \u1085 \u1077 \u1089  \u1085 \u1072  \u1055 \u1091 \u1088 \u1080 \u1084 ?\
\uc0\u1061 \u1072 \u1095 \u1077  \u1074 \u1080 \u1085 \u1086 \u1074 \u1072 \u1090 \u1086  \u1088 \u1072 \u1079 \u1074 \u1077 \u1083  \u1088 \u1091 \u1082 \u1072 \u1084 \u1080 . \u1050 \u1072 \u1082 \u1080 \u1077  \u1096 \u1072 \u1083 \u1072 \u1093 \u1084 \u1086 \u1085 \u1077 \u1089 , \u1082 \u1086 \u1075 \u1076 \u1072  \u1074  \u1076 \u1086 \u1084 \u1077  \u1096 \u1072 \u1088 \u1086 \u1084  \u1087 \u1086 \u1082 \u1072 \u1090 \u1080 , \u1076 \u1077 \u1090 \u1103 \u1084  \u1085 \u1077 \u1095 \u1077 \u1075 \u1086  \u1077 \u1089 \u1090 \u1100 ! \u1053 \u1086  \u1089  \u1076 \u1088 \u1091 \u1075 \u1086 \u1081  \u1089 \u1090 \u1086 \u1088 \u1086 \u1085 \u1099 , \u1094 \u1072 \u1076 \u1080 \u1082  \u1087 \u1088 \u1072 \u1074  \'97 \u1086 \u1073 \u1099 \u1095 \u1072 \u1081  \u1077 \u1089 \u1090 \u1100  \u1086 \u1073 \u1099 \u1095 \u1072 \u1081 . \u1057  \u1082 \u1072 \u1082 \u1086 \u1081  \u1073 \u1099  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1100 \u1102  \u1086 \u1085  \u1087 \u1088 \u1080 \u1074 \u1077 \u1079  \u1077 \u1084 \u1091  \u1073 \u1086 \u1083 \u1100 \u1096 \u1091 \u1102  \u1082 \u1086 \u1088 \u1079 \u1080 \u1085 \u1091 , \u1085 \u1072 \u1073 \u1080 \u1090 \u1091 \u1102  \u1074 \u1089 \u1103 \u1082 \u1086 \u1081  \u1074 \u1089 \u1103 \u1095 \u1080 \u1085 \u1086 \u1081 . \u1069 \u1093 ! \
\'97 \uc0\u1055 \u1091 \u1088 \u1080 \u1084  \u1089 \u1077 \u1075 \u1086 \u1076 \u1085 \u1103 ! \'97 \u1087 \u1088 \u1077 \u1088 \u1074 \u1072 \u1083  \u1052 \u1072 \u1075 \u1080 \u1076  \u1088 \u1072 \u1079 \u1084 \u1099 \u1096 \u1083 \u1077 \u1085 \u1080 \u1103  \u1061 \u1072 \u1095 \u1077 . \'97 \u1055 \u1086 \u1096 \u1083 \u1080  \u1089 \u1086  \u1084 \u1085 \u1086 \u1081 , \u1074 \u1099 \u1087 \u1100 \u1077 \u1096 \u1100  \u1085 \u1077 \u1084 \u1085 \u1086 \u1075 \u1086  \u1074 \u1086 \u1076 \u1082 \u1080  \u1074  \u1095 \u1077 \u1089 \u1090 \u1100  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1082 \u1072 .\
\uc0\u1055 \u1086 \u1074 \u1077 \u1079 \u1083 \u1086  \u1090 \u1072 \u1082  \u1087 \u1086 \u1074 \u1077 \u1079 \u1083 \u1086 ! \u1052 \u1086 \u1075  \u1083 \u1080  \u1061 \u1072 \u1095 \u1077  \u1087 \u1088 \u1077 \u1076 \u1087 \u1086 \u1083 \u1086 \u1078 \u1080 \u1090 \u1100 , \u1095 \u1090 \u1086  \u1086 \u1082 \u1072 \u1078 \u1077 \u1090 \u1089 \u1103  \u1079 \u1072  \u1089 \u1090 \u1086 \u1083 \u1086 \u1084  \u1094 \u1072 \u1076 \u1080 \u1082 \u1072 , \u1074  \u1086 \u1082 \u1088 \u1091 \u1078 \u1077 \u1085 \u1080 \u1080  \u1089 \u1072 \u1084 \u1099 \u1093  \u1073 \u1083 \u1080 \u1079 \u1082 \u1080 \u1093  \u1077 \u1075 \u1086  \u1091 \u1095 \u1077 \u1085 \u1080 \u1082 \u1086 \u1074 ? \u1050 \u1072 \u1078 \u1076 \u1099 \u1081  \u1080 \u1079  \u1085 \u1080 \u1093  \u1089 \u1074 \u1077 \u1090 \u1086 \u1095  \u1087 \u1088 \u1072 \u1074 \u1077 \u1076 \u1085 \u1086 \u1089 \u1090 \u1080 , \u1084 \u1091 \u1076 \u1088 \u1077 \u1094 , \u1079 \u1085 \u1072 \u1102 \u1097 \u1080 \u1081  \u1074 \u1089 \u1102  \u1058 \u1086 \u1088 \u1091 . \u1048  \u1088 \u1103 \u1076 \u1086 \u1084  \u1089  \u1101 \u1090 \u1080 \u1084 \u1080  \u1089 \u1074 \u1103 \u1090 \u1099 \u1084 \u1080  \u1083 \u1102 \u1076 \u1100 \u1084 \u1080  \u1089 \u1080 \u1076 \u1080 \u1090  \u1086 \u1085 , \u1087 \u1088 \u1086 \u1089 \u1090 \u1086 \u1081  \u1096 \u1086 \u1088 \u1085 \u1080 \u1082 , \u1089  \u1090 \u1088 \u1091 \u1076 \u1086 \u1084  \u1088 \u1072 \u1079 \u1073 \u1080 \u1088 \u1072 \u1102 \u1097 \u1080 \u1081  \u1082 \u1086 \u1084 \u1084 \u1077 \u1085 \u1090 \u1072 \u1088 \u1080 \u1081  \u1056 \u1072 \u1096 \u1080 !\
\uc0\u1040  \u1082 \u1086 \u1075 \u1076 \u1072  \u1052 \u1072 \u1075 \u1080 \u1076  \u1089 \u1072 \u1084 \u1086 \u1083 \u1080 \u1095 \u1085 \u1086  \u1085 \u1072 \u1083 \u1080 \u1083  \u1095 \u1072 \u1088 \u1082 \u1091  \u1074 \u1086 \u1076 \u1082 \u1080  \u1080  \u1087 \u1086 \u1076 \u1072 \u1083  \u1077 \u1077  \u1061 \u1072 \u1095 \u1077 , \u1090 \u1086 \u1090  \u1087 \u1086 \u1087 \u1083 \u1099 \u1083 , \u1088 \u1072 \u1089 \u1090 \u1077 \u1082 \u1089 \u1103  \u1086 \u1090  \u1089 \u1095 \u1072 \u1089 \u1090 \u1100 \u1103  \u1080  \u1075 \u1086 \u1088 \u1076 \u1086 \u1089 \u1090 \u1080 . \u1053 \u1077  \u1091 \u1089 \u1087 \u1077 \u1083  \u1086 \u1085  \u1086 \u1089 \u1091 \u1096 \u1080 \u1090 \u1100  \u1095 \u1072 \u1088 \u1082 \u1091 , \u1082 \u1072 \u1082  \u1089 \u1080 \u1076 \u1077 \u1074 \u1096 \u1080 \u1081  \u1089 \u1083 \u1077 \u1074 \u1072  \u1091 \u1095 \u1077 \u1085 \u1080 \u1082 , \u1089  \u1088 \u1072 \u1074 \u1074 \u1080 \u1085 \u1089 \u1082 \u1086 \u1081  \u1073 \u1086 \u1088 \u1086 \u1076 \u1086 \u1081 , \u1085 \u1086  \u1089  \u1084 \u1086 \u1083 \u1086 \u1076 \u1099 \u1084 \u1080 , \u1074 \u1077 \u1089 \u1077 \u1083 \u1099 \u1084 \u1080  \u1075 \u1083 \u1072 \u1079 \u1072 \u1084 \u1080 , \u1087 \u1088 \u1080 \u1076 \u1074 \u1080 \u1085 \u1091 \u1083  \u1087 \u1088 \u1103 \u1084 \u1086  \u1077 \u1084 \u1091  \u1087 \u1086 \u1076  \u1083 \u1086 \u1082 \u1086 \u1090 \u1100  \u1090 \u1072 \u1088 \u1077 \u1083 \u1082 \u1091  \u1089  \u1088 \u1091 \u1073 \u1083 \u1077 \u1085 \u1099 \u1084 \u1080  \u1103 \u1081 \u1094 \u1072 \u1084 \u1080 , \u1097 \u1077 \u1076 \u1088 \u1086  \u1087 \u1086 \u1083 \u1080 \u1090 \u1099 \u1084 \u1080  \u1087 \u1086 \u1076 \u1089 \u1086 \u1083 \u1085 \u1077 \u1095 \u1085 \u1099 \u1084  \u1084 \u1072 \u1089 \u1083 \u1086 \u1084 , \u1080  \u1084 \u1080 \u1089 \u1082 \u1091  \u1089  \u1073 \u1077 \u1083 \u1099 \u1084 \u1080 , \u1085 \u1086 \u1079 \u1076 \u1088 \u1077 \u1074 \u1072 \u1090 \u1099 \u1084 \u1080  \u1096 \u1072 \u1088 \u1080 \u1082 \u1072 \u1084 \u1080  \u1080 \u1079  \u1074 \u1072 \u1088 \u1077 \u1085 \u1086 \u1075 \u1086  \u1082 \u1072 \u1088 \u1087 \u1072 , \u1087 \u1083 \u1072 \u1074 \u1072 \u1102 \u1097 \u1080 \u1084 \u1080  \u1074  \u1078 \u1077 \u1083 \u1090 \u1086 \u1084  \u1083 \u1091 \u1082 \u1086 \u1074 \u1086 \u1084  \u1089 \u1086 \u1091 \u1089 \u1077 . \u1061 \u1072 \u1095 \u1077  \u1089 \u1093 \u1074 \u1072 \u1090 \u1080 \u1083  \u1076 \u1077 \u1088 \u1077 \u1074 \u1103 \u1085 \u1085 \u1091 \u1102  \u1083 \u1086 \u1078 \u1082 \u1091  \u1080  \u1082 \u1088 \u1077 \u1087 \u1082 \u1086  \u1079 \u1072 \u1082 \u1091 \u1089 \u1080 \u1083 . \u1052 \u1072 \u1075 \u1080 \u1076  \u1090 \u1091 \u1090  \u1078 \u1077  \u1085 \u1072 \u1083 \u1080 \u1083  \u1074 \u1090 \u1086 \u1088 \u1091 \u1102  \u1095 \u1072 \u1088 \u1082 \u1091  \u1080  \u1087 \u1086 \u1076 \u1072 \u1083  \u1077 \u1077  \u1075 \u1086 \u1089 \u1090 \u1102 . \u1055 \u1086 \u1082 \u1072  \u1090 \u1086 \u1090  \u1076 \u1080 \u1074 \u1080 \u1083 \u1089 \u1103  \u1085 \u1072  \u1089 \u1074 \u1072 \u1083 \u1080 \u1074 \u1096 \u1077 \u1077 \u1089 \u1103  \u1087 \u1088 \u1103 \u1084 \u1086  \u1089  \u1053 \u1077 \u1073 \u1077 \u1089 , \u1085 \u1077 \u1087 \u1086 \u1085 \u1103 \u1090 \u1085 \u1086  \u1095 \u1077 \u1084  \u1074 \u1099 \u1079 \u1074 \u1072 \u1085 \u1085 \u1086 \u1077  \u1073 \u1083 \u1072 \u1075 \u1086 \u1074 \u1086 \u1083 \u1077 \u1085 \u1080 \u1077  \u1094 \u1072 \u1076 \u1080 \u1082 \u1072 , \u1090 \u1086 \u1090  \u1089 \u1076 \u1077 \u1083 \u1072 \u1083  \u1078 \u1077 \u1089 \u1090  \'97 \u1074 \u1099 \u1087 \u1077 \u1081 .\
\
\uc0\u1061 \u1072 \u1095 \u1077  \u1074 \u1099 \u1087 \u1080 \u1083  \u1074 \u1090 \u1086 \u1088 \u1091 \u1102  \u1088 \u1102 \u1084 \u1082 \u1091  \u1096 \u1077 \u1089 \u1090 \u1080 \u1076 \u1077 \u1089 \u1103 \u1090 \u1080 \u1075 \u1088 \u1072 \u1076 \u1091 \u1089 \u1085 \u1086 \u1081  \u1074 \u1086 \u1076 \u1082 \u1080 , \u1079 \u1072 \u1077 \u1083  \u1090 \u1088 \u1077 \u1084 \u1103  \u1088 \u1099 \u1073 \u1085 \u1099 \u1084 \u1080  \u1096 \u1072 \u1088 \u1080 \u1082 \u1072 \u1084 \u1080 , \u1079 \u1072 \u1095 \u1077 \u1088 \u1087 \u1085 \u1091 \u1083  \u1087 \u1086 \u1083 \u1085 \u1091 \u1102  \u1083 \u1086 \u1078 \u1082 \u1091  \u1088 \u1091 \u1073 \u1083 \u1077 \u1085 \u1099 \u1093  \u1103 \u1080 \u1094  \u1080  \u1089 \u1083 \u1072 \u1076 \u1082 \u1086  \u1086 \u1093 \u1084 \u1077 \u1083 \u1077 \u1083 . \u1053 \u1080 \u1095 \u1077 \u1075 \u1086  \u1091 \u1076 \u1080 \u1074 \u1080 \u1090 \u1077 \u1083 \u1100 \u1085 \u1086 \u1075 \u1086  \u1074  \u1090 \u1086 \u1084  \u1085 \u1077  \u1073 \u1099 \u1083 \u1086 : \u1082 \u1086 \u1075 \u1076 \u1072  \u1087 \u1100 \u1077 \u1096 \u1100  \u1085 \u1072  \u1087 \u1091 \u1089 \u1090 \u1086 \u1081 , \u1089 \u1074 \u1077 \u1076 \u1077 \u1085 \u1085 \u1099 \u1081  \u1075 \u1086 \u1083 \u1086 \u1076 \u1086 \u1084  \u1078 \u1077 \u1083 \u1091 \u1076 \u1086 \u1082 , \u1087 \u1086 -\u1076 \u1088 \u1091 \u1075 \u1086 \u1084 \u1091  \u1080  \u1085 \u1077  \u1073 \u1099 \u1074 \u1072 \u1077 \u1090 . \
\uc0\u1042 \u1086 \u1082 \u1088 \u1091 \u1075  \u1079 \u1072 \u1096 \u1091 \u1084 \u1077 \u1083 \u1072 , \u1087 \u1086 \u1082 \u1072 \u1090 \u1080 \u1083 \u1072 \u1089 \u1100  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1095 \u1085 \u1072 \u1103  \u1090 \u1088 \u1072 \u1087 \u1077 \u1079 \u1072 , \u1072  \u1061 \u1072 \u1095 \u1077 , \u1073 \u1083 \u1072 \u1078 \u1077 \u1085 \u1085 \u1086  \u1091 \u1083 \u1099 \u1073 \u1072 \u1103 \u1089 \u1100 , \u1089 \u1080 \u1076 \u1077 \u1083 , \u1095 \u1091 \u1090 \u1100  \u1088 \u1072 \u1089 \u1082 \u1072 \u1095 \u1080 \u1074 \u1072 \u1103 \u1089 \u1100 , \u1089 \u1083 \u1086 \u1074 \u1085 \u1086  \u1085 \u1072  \u1084 \u1086 \u1083 \u1080 \u1090 \u1074 \u1077 , \u1080  \u1074 \u1086  \u1074 \u1089 \u1077  \u1075 \u1083 \u1072 \u1079 \u1072  \u1089 \u1084 \u1086 \u1090 \u1088 \u1077 \u1083  \u1085 \u1072  \u1087 \u1088 \u1072 \u1074 \u1077 \u1076 \u1085 \u1080 \u1082 \u1072 . \u1050 \u1072 \u1082  \u1086 \u1085  \u1087 \u1100 \u1077 \u1090 , \u1095 \u1090 \u1086  \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1090 , \u1095 \u1077 \u1084  \u1079 \u1072 \u1082 \u1091 \u1089 \u1099 \u1074 \u1072 \u1077 \u1090 . \u1057 \u1084 \u1086 \u1090 \u1088 \u1077 \u1083  \u1080  \u1076 \u1077 \u1083 \u1072 \u1083  \u1090 \u1086  \u1078 \u1077  \u1089 \u1072 \u1084 \u1086 \u1077 , \u1089 \u1090 \u1072 \u1088 \u1072 \u1103 \u1089 \u1100  \u1093 \u1086 \u1090 \u1100  \u1085 \u1072  \u1082 \u1088 \u1086 \u1096 \u1077 \u1095 \u1082 \u1091  \u1089 \u1090 \u1072 \u1090 \u1100  \u1087 \u1086 \u1093 \u1086 \u1078 \u1080 \u1084 .\
\uc0\u1050 \u1072 \u1082 \u1072 \u1103 -\u1090 \u1086  \u1085 \u1077 \u1091 \u1076 \u1086 \u1073 \u1085 \u1072 \u1103  \u1084 \u1099 \u1089 \u1083 \u1100  \u1084 \u1077 \u1096 \u1072 \u1083 \u1072  \u1077 \u1075 \u1086  \u1073 \u1083 \u1072 \u1078 \u1077 \u1085 \u1089 \u1090 \u1074 \u1091 . \u1061 \u1072 \u1095 \u1077  \u1087 \u1077 \u1088 \u1077 \u1074 \u1077 \u1083  \u1075 \u1083 \u1072 \u1079 \u1072  \u1085 \u1072  \u1089 \u1090 \u1086 \u1083 \u1077 \u1096 \u1085 \u1080 \u1094 \u1091  \u1087 \u1088 \u1103 \u1084 \u1086  \u1087 \u1077 \u1088 \u1077 \u1076  \u1089 \u1086 \u1073 \u1086 \u1081  \u1080  \u1079 \u1072 \u1076 \u1091 \u1084 \u1072 \u1083 \u1089 \u1103 .\
\uc0\u1042 \u1086 \u1090  \u1086 \u1085 \u1086 ! \u1052 \u1072 \u1075 \u1080 \u1076  \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1083  \u1086  \u1096 \u1072 \u1083 \u1072 \u1093 \u1084 \u1086 \u1085 \u1077 \u1089 . \u1052 \u1086 \u1078 \u1085 \u1086  \u1087 \u1086 \u1076 \u1091 \u1084 \u1072 \u1090 \u1100 , \u1094 \u1072 \u1076 \u1080 \u1082 \u1091  \u1085 \u1091 \u1078 \u1085 \u1099  \u1087 \u1086 \u1076 \u1072 \u1088 \u1082 \u1080  \u1086 \u1090  \u1061 \u1072 \u1095 \u1077 ?! \u1056 \u1086 \u1074 \u1085 \u1086  \u1085 \u1072 \u1086 \u1073 \u1086 \u1088 \u1086 \u1090 , \u1061 \u1072 \u1095 \u1077  \u1085 \u1077 \u1086 \u1073 \u1093 \u1086 \u1076 \u1080 \u1084 \u1086  \u1087 \u1088 \u1080 \u1085 \u1077 \u1089 \u1090 \u1080  \u1087 \u1086 \u1076 \u1072 \u1088 \u1086 \u1082  \u1087 \u1088 \u1072 \u1074 \u1077 \u1076 \u1085 \u1080 \u1082 \u1091 . \u1044 \u1083 \u1103  \u1095 \u1077 \u1075 \u1086 , \u1087 \u1086 \u1095 \u1077 \u1084 \u1091 , \u1082 \u1072 \u1082 \u1086 \u1081  \u1074  \u1101 \u1090 \u1086 \u1084  \u1089 \u1082 \u1088 \u1099 \u1090  \u1090 \u1080 \u1082 \u1091 \u1085 , \u1080 \u1089 \u1087 \u1088 \u1072 \u1074 \u1083 \u1077 \u1085 \u1080 \u1077 , \u1083 \u1080 \u1096 \u1100  \u1052 \u1072 \u1075 \u1080 \u1076  \u1079 \u1085 \u1072 \u1077 \u1090 . \u1048  \u1077 \u1089 \u1083 \u1080  \u1086 \u1085  \u1090 \u1072 \u1082  \u1095 \u1077 \u1090 \u1082 \u1086  \u1080  \u1085 \u1077 \u1076 \u1074 \u1091 \u1089 \u1084 \u1099 \u1089 \u1083 \u1077 \u1085 \u1085 \u1086  \u1089 \u1082 \u1072 \u1079 \u1072 \u1083  \u1086 \u1073  \u1101 \u1090 \u1086 \u1084 , \u1079 \u1085 \u1072 \u1095 \u1080 \u1090 \'85 \u1079 \u1085 \u1072 \u1095 \u1080 \u1090 , \u1085 \u1072 \u1076 \u1086  \u1095 \u1090 \u1086 -\u1090 \u1086  \u1076 \u1077 \u1083 \u1072 \u1090 \u1100 . \
\uc0\u1061 \u1072 \u1095 \u1077  \u1074 \u1099 \u1073 \u1088 \u1072 \u1083 \u1089 \u1103  \u1080 \u1079 -\u1079 \u1072  \u1089 \u1090 \u1086 \u1083 \u1072  \u1080 , \u1085 \u1077  \u1087 \u1088 \u1086 \u1097 \u1072 \u1103 \u1089 \u1100 , \u1074 \u1099 \u1096 \u1077 \u1083  \u1085 \u1072  \u1091 \u1083 \u1080 \u1094 \u1091 . \u1057 \u1085 \u1077 \u1075  \u1073 \u1077 \u1083 \u1077 \u1083  \u1085 \u1072  \u1079 \u1072 \u1073 \u1086 \u1088 \u1072 \u1093 , \u1085 \u1072 \u1083 \u1080 \u1095 \u1085 \u1080 \u1082 \u1072 \u1093 , \u1082 \u1088 \u1099 \u1096 \u1072 \u1093  \u1080  \u1076 \u1077 \u1088 \u1077 \u1074 \u1100 \u1103 \u1093 . \u1042  \u1095 \u1077 \u1088 \u1085 \u1099 \u1093  \u1074 \u1077 \u1090 \u1074 \u1103 \u1093 , \u1085 \u1072 \u1076 \u1088 \u1099 \u1074 \u1072 \u1103 \u1089 \u1100 , \u1082 \u1088 \u1080 \u1095 \u1072 \u1083 \u1080  \u1075 \u1072 \u1083 \u1082 \u1080 . \u1057 \u1082 \u1086 \u1083 \u1100 \u1079 \u1103  \u1087 \u1086  \u1083 \u1100 \u1076 \u1091 , \u1061 \u1072 \u1095 \u1077  \u1087 \u1086 \u1089 \u1087 \u1077 \u1096 \u1080 \u1083  \u1074  \u1076 \u1086 \u1084  \u1073 \u1086 \u1075 \u1072 \u1090 \u1086 \u1075 \u1086  \u1074 \u1080 \u1085 \u1086 \u1090 \u1086 \u1088 \u1075 \u1086 \u1074 \u1094 \u1072 . \u1058 \u1072 \u1084  \u1091 \u1078 \u1077  \u1074 \u1086 \u1074 \u1089 \u1102  \u1096 \u1083 \u1080  \u1087 \u1088 \u1080 \u1075 \u1086 \u1090 \u1086 \u1074 \u1083 \u1077 \u1085 \u1080 \u1103  \u1082  \u1090 \u1088 \u1072 \u1087 \u1077 \u1079 \u1077 . \
\'97 \uc0\u1057  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1082 \u1086 \u1084 ! \'97 \u1074 \u1077 \u1089 \u1077 \u1083 \u1086  \u1074 \u1086 \u1089 \u1082 \u1083 \u1080 \u1082 \u1085 \u1091 \u1083  \u1061 \u1072 \u1095 \u1077 . \'97 \u1044 \u1072 \u1081 \u1090 \u1077  \u1084 \u1085 \u1077  \u1074  \u1076 \u1086 \u1083 \u1075  \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1091  \u1093 \u1086 \u1088 \u1086 \u1096 \u1077 \u1075 \u1086  \u1074 \u1080 \u1085 \u1072 . \u1071 , \u1088 \u1072 \u1079 \u1091 \u1084 \u1077 \u1077 \u1090 \u1089 \u1103 , \u1079 \u1072 \u1087 \u1083 \u1072 \u1095 \u1091 . \u1053 \u1086  \u1077 \u1089 \u1083 \u1080  \u1074 \u1076 \u1088 \u1091 \u1075  \u1085 \u1077  \u1074 \u1077 \u1088 \u1085 \u1091  \u1076 \u1086 \u1083 \u1075 , \u1090 \u1086  \u1074 \u1077 \u1076 \u1100  \u1055 \u1091 \u1088 \u1080 \u1084  \u1089 \u1077 \u1075 \u1086 \u1076 \u1085 \u1103 ! \
\uc0\u1042 \u1080 \u1085 \u1086 \u1090 \u1086 \u1088 \u1075 \u1086 \u1074 \u1077 \u1094  \u1074 \u1085 \u1080 \u1084 \u1072 \u1090 \u1077 \u1083 \u1100 \u1085 \u1086  \u1087 \u1086 \u1089 \u1084 \u1086 \u1090 \u1088 \u1077 \u1083  \u1085 \u1072  \u1061 \u1072 \u1095 \u1077 , \u1091 \u1096 \u1077 \u1083  \u1074  \u1079 \u1072 \u1076 \u1085 \u1080 \u1077  \u1082 \u1086 \u1084 \u1085 \u1072 \u1090 \u1099  \u1080  \u1087 \u1088 \u1080 \u1085 \u1077 \u1089  \u1086 \u1090 \u1090 \u1091 \u1076 \u1072  \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1091  \u1076 \u1086 \u1088 \u1086 \u1075 \u1086 \u1075 \u1086  \u1074 \u1080 \u1085 \u1072 .\
\'97 \uc0\u1042 \u1086 \u1090  \u1074 \u1080 \u1085 \u1086 , \'97 \u1089 \u1082 \u1072 \u1079 \u1072 \u1083  \u1086 \u1085 , \u1079 \u1072 \u1074 \u1086 \u1088 \u1072 \u1095 \u1080 \u1074 \u1072 \u1103  \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1091  \u1074  \u1095 \u1080 \u1089 \u1090 \u1086 \u1077  \u1087 \u1086 \u1083 \u1086 \u1090 \u1077 \u1085 \u1094 \u1077 . \'97 \u1053 \u1077 \u1089 \u1080  \u1086 \u1089 \u1090 \u1086 \u1088 \u1086 \u1078 \u1085 \u1086 , \u1089 \u1077 \u1075 \u1086 \u1076 \u1085 \u1103  \u1089 \u1082 \u1086 \u1083 \u1100 \u1079 \u1082 \u1086 . \
\uc0\u1054 \u1082 \u1088 \u1099 \u1083 \u1077 \u1085 \u1085 \u1099 \u1081  \u1091 \u1076 \u1072 \u1095 \u1077 \u1081 , \u1061 \u1072 \u1095 \u1077  \u1087 \u1086 \u1089 \u1087 \u1077 \u1096 \u1080 \u1083  \u1082  \u1073 \u1072 \u1082 \u1072 \u1083 \u1077 \u1081 \u1097 \u1080 \u1082 \u1091 .\
\'97 \uc0\u1057  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1082 \u1086 \u1084 ! \'97 \u1074 \u1089 \u1082 \u1088 \u1080 \u1095 \u1072 \u1083  \u1086 \u1085 , \u1074 \u1088 \u1099 \u1074 \u1072 \u1103 \u1089 \u1100  \u1074  \u1083 \u1072 \u1074 \u1082 \u1091 . \'97 \u1044 \u1072 \u1081 \u1090 \u1077  \u1084 \u1085 \u1077  \u1074  \u1076 \u1086 \u1083 \u1075  \u1076 \u1074 \u1077  \u1073 \u1086 \u1083 \u1100 \u1096 \u1080 \u1077  \u1089 \u1091 \u1096 \u1077 \u1085 \u1099 \u1077  \u1075 \u1088 \u1091 \u1096 \u1080  \u1080  \u1087 \u1086 \u1083 \u1092 \u1091 \u1085 \u1090 \u1072  \u1080 \u1079 \u1102 \u1084 \u1091 . \u1071 , \u1088 \u1072 \u1079 \u1091 \u1084 \u1077 \u1077 \u1090 \u1089 \u1103 , \u1079 \u1072 \u1087 \u1083 \u1072 \u1095 \u1091 . \u1053 \u1086  \u1077 \u1089 \u1083 \u1080  \u1074 \u1076 \u1088 \u1091 \u1075  \u1085 \u1077  \u1074 \u1077 \u1088 \u1085 \u1091  \u1076 \u1086 \u1083 \u1075 , \u1090 \u1086  \u1074 \u1077 \u1076 \u1100  \u1055 \u1091 \u1088 \u1080 \u1084  \u1089 \u1077 \u1075 \u1086 \u1076 \u1085 \u1103 !\
\uc0\u1041 \u1072 \u1082 \u1072 \u1083 \u1077 \u1081 \u1097 \u1080 \u1082 , \u1085 \u1077  \u1075 \u1086 \u1074 \u1086 \u1088 \u1103  \u1085 \u1080  \u1089 \u1083 \u1086 \u1074 \u1072 , \u1086 \u1090 \u1074 \u1077 \u1089 \u1080 \u1083  \u1080 \u1079 \u1102 \u1084 , \u1076 \u1086 \u1073 \u1072 \u1074 \u1080 \u1083  \u1075 \u1088 \u1091 \u1096 \u1080  \u1080  \u1074 \u1088 \u1091 \u1095 \u1080 \u1083  \u1061 \u1072 \u1095 \u1077 . \u1053 \u1077  \u1095 \u1091 \u1103  \u1087 \u1086 \u1076  \u1089 \u1086 \u1073 \u1086 \u1081  \u1085 \u1086 \u1075 , \u1090 \u1086 \u1090  \u1087 \u1086 \u1084 \u1095 \u1072 \u1083 \u1089 \u1103  \u1082  \u1052 \u1072 \u1075 \u1080 \u1076 \u1091 . \u1042 \u1099 \u1075 \u1083 \u1103 \u1085 \u1091 \u1083 \u1086  \u1089 \u1086 \u1083 \u1085 \u1094 \u1077 , \u1079 \u1072 \u1080 \u1085 \u1076 \u1077 \u1074 \u1077 \u1083 \u1099 \u1077  \u1086 \u1082 \u1085 \u1072  \u1076 \u1086 \u1084 \u1086 \u1074  \u1089 \u1080 \u1103 \u1083 \u1080 , \u1089 \u1083 \u1086 \u1074 \u1085 \u1086  \u1080 \u1093  \u1087 \u1086 \u1082 \u1088 \u1099 \u1074 \u1072 \u1083  \u1085 \u1077  \u1083 \u1077 \u1076 , \u1072  \u1072 \u1083 \u1084 \u1072 \u1079 \u1099 . \
\'97 \uc0\u1042 \u1086 \u1090 , \u1088 \u1077 \u1073 \u1077 , \'97 \u1089 \u1082 \u1072 \u1079 \u1072 \u1083  \u1061 \u1072 \u1095 \u1077 , \u1089 \u1090 \u1072 \u1074 \u1103  \u1085 \u1072  \u1089 \u1090 \u1086 \u1083  \u1087 \u1077 \u1088 \u1077 \u1076  \u1052 \u1072 \u1075 \u1080 \u1076 \u1086 \u1084  \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1091  \u1080  \u1089 \u1091 \u1096 \u1077 \u1085 \u1099 \u1077  \u1092 \u1088 \u1091 \u1082 \u1090 \u1099 . \'97 \u1071  \u1087 \u1088 \u1080 \u1085 \u1077 \u1089  \u1074 \u1072 \u1084  \u1096 \u1072 \u1083 \u1072 \u1093 \u1084 \u1086 \u1085 \u1077 \u1089 .\
\'97 \uc0\u1052 \u1086 \u1083 \u1086 \u1076 \u1077 \u1094 , \'97 \u1087 \u1086 \u1093 \u1074 \u1072 \u1083 \u1080 \u1083  \u1077 \u1075 \u1086  \u1052 \u1072 \u1075 \u1080 \u1076 . \'97 \u1055 \u1088 \u1072 \u1074 \u1080 \u1083 \u1100 \u1085 \u1086  \u1087 \u1086 \u1089 \u1090 \u1091 \u1087 \u1080 \u1083 . \u1053 \u1077  \u1079 \u1072 \u1073 \u1091 \u1076 \u1100 , \u1090 \u1077 \u1087 \u1077 \u1088 \u1100  \u1082 \u1072 \u1078 \u1076 \u1099 \u1081  \u1075 \u1086 \u1076  \u1090 \u1099  \u1076 \u1086 \u1083 \u1078 \u1077 \u1085  \u1074  \u1055 \u1091 \u1088 \u1080 \u1084  \u1087 \u1088 \u1080 \u1093 \u1086 \u1076 \u1080 \u1090 \u1100  \u1082 \u1086  \u1084 \u1085 \u1077 . \u1057  \u1087 \u1086 \u1076 \u1072 \u1088 \u1082 \u1086 \u1084 , \u1061 \u1072 \u1095 \u1077 , \u1089  \u1087 \u1086 \u1076 \u1072 \u1088 \u1082 \u1086 \u1084 . \
\'97 \uc0\u1044 \u1072  \u1103  \u1089  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1100 \u1102 , \u1085 \u1086 \'85 \'97 \u1085 \u1072 \u1095 \u1072 \u1083  \u1073 \u1099 \u1083 \u1086  \u1061 \u1072 \u1095 \u1077  \u1080  \u1087 \u1088 \u1080 \u1082 \u1091 \u1089 \u1080 \u1083  \u1103 \u1079 \u1099 \u1082 . \u1045 \u1089 \u1083 \u1080  \u1052 \u1072 \u1075 \u1080 \u1076  \u1090 \u1072 \u1082  \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1090 , \u1079 \u1085 \u1072 \u1095 \u1080 \u1090 , \u1073 \u1091 \u1076 \u1077 \u1090  \u1085 \u1072  \u1095 \u1090 \u1086  \u1082 \u1091 \u1087 \u1080 \u1090 \u1100  \u1096 \u1072 \u1083 \u1072 \u1093 \u1084 \u1086 \u1085 \u1077 \u1089  \u1080  \u1091 \u1089 \u1090 \u1088 \u1086 \u1080 \u1090 \u1100  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1095 \u1085 \u1091 \u1102  \u1090 \u1088 \u1072 \u1087 \u1077 \u1079 \u1091 , \u1080 \'85\
