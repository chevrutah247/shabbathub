\uc0\u1047 \u1072 \u1089 \u1090 \u1086 \u1103 \u1074 \u1096 \u1072 \u1103 \u1089 \u1103  \u1083 \u1086 \u1096 \u1072 \u1076 \u1082 \u1072  \u1088 \u1077 \u1079 \u1074 \u1086  \u1074 \u1079 \u1103 \u1083 \u1072  \u1089  \u1084 \u1077 \u1089 \u1090 \u1072 , \u1080  \u1079 \u1072 \u1089 \u1082 \u1088 \u1080 \u1087 \u1077 \u1083 \u1080 , \u1079 \u1072 \u1087 \u1077 \u1083 \u1080  \u1087 \u1086 \u1083 \u1086 \u1079 \u1100 \u1103 , \u1084 \u1077 \u1076 \u1083 \u1077 \u1085 \u1085 \u1086  \u1087 \u1086 \u1090 \u1103 \u1085 \u1091 \u1083 \u1080 \u1089 \u1100  \u1084 \u1080 \u1084 \u1086  \u1073 \u1077 \u1088 \u1077 \u1075 \u1072  \u1079 \u1072 \u1089 \u1090 \u1099 \u1074 \u1096 \u1077 \u1081  \u1087 \u1086 \u1076 \u1086  \u1083 \u1100 \u1076 \u1086 \u1084  \u1088 \u1077 \u1095 \u1082 \u1080 . \u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1088 \u1072 \u1089 \u1082 \u1091 \u1088 \u1080 \u1083  \u1082 \u1086 \u1088 \u1086 \u1090 \u1082 \u1091 \u1102  \u1090 \u1088 \u1091 \u1073 \u1082 \u1091 -\u1085 \u1086 \u1089 \u1086 \u1075 \u1088 \u1077 \u1081 \u1082 \u1091  \u1080  \u1087 \u1088 \u1080 \u1085 \u1103 \u1083 \u1089 \u1103  \u1087 \u1091 \u1089 \u1082 \u1072 \u1090 \u1100  \u1082 \u1083 \u1091 \u1073 \u1099  \u1074 \u1086 \u1085 \u1102 \u1095 \u1077 \u1075 \u1086  \u1076 \u1099 \u1084 \u1072 . \
\'97 \uc0\u1044 \u1072 , \u1078 \u1080 \u1079 \u1085 \u1103 , \'97 \u1073 \u1086 \u1088 \u1084 \u1086 \u1090 \u1072 \u1083  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 , \'97 \u1090 \u1091 \u1075 \u1072 \u1103  \u1086 \u1085 \u1072  \u1096 \u1090 \u1091 \u1082 \u1072 , \u1078 \u1080 \u1079 \u1085 \u1103 . \u1058 \u1086  \u1082 \u1072 \u1082  \u1085 \u1086 \u1095 \u1100 , \u1090 \u1086  \u1082 \u1072 \u1082  \u1076 \u1077 \u1085 \u1100 . \u1058 \u1086  \u1085 \u1077 \u1089 \u1077 \u1090 \u1089 \u1103 , \u1082 \u1072 \u1082  \u1089 \u1072 \u1085 \u1080  \u1089  \u1075 \u1086 \u1088 \u1099 , \u1090 \u1086  \u1079 \u1072 \u1084 \u1080 \u1088 \u1072 \u1077 \u1090  \u1089 \u1090 \u1086 \u1083 \u1073 \u1086 \u1084 . \u1048 \u1085 \u1086 \u1075 \u1076 \u1072  \u1089 \u1083 \u1072 \u1076 \u1082 \u1072 \u1103 , \u1090 \u1086 \u1095 \u1085 \u1086  \u1074 \u1086 \u1076 \u1082 \u1072 , \u1085 \u1086  \u1095 \u1072 \u1097 \u1077  \u1075 \u1086 \u1088 \u1100 \u1082 \u1072 \u1103 , \u1095 \u1080 \u1089 \u1090 \u1086  \u1084 \u1086 \u1103  \u1088 \u1077 \u1076 \u1100 \u1082 \u1072 .\
\uc0\u1061 \u1072 \u1095 \u1077  \u1089 \u1083 \u1091 \u1096 \u1072 \u1083  \u1080  \u1085 \u1077  \u1089 \u1083 \u1091 \u1096 \u1072 \u1083 . \u1045 \u1084 \u1091  \u1090 \u1086 \u1078 \u1077  \u1073 \u1099 \u1083 \u1086  \u1095 \u1090 \u1086  \u1089 \u1082 \u1072 \u1079 \u1072 \u1090 \u1100  \u1086  \u1078 \u1080 \u1079 \u1085 \u1080 , \u1085 \u1086  \u1086 \u1085  \u1079 \u1085 \u1072 \u1083 , \u1095 \u1090 \u1086  \u1078 \u1080 \u1079 \u1085 \u1100  \u1076 \u1072 \u1077 \u1090  \u1042 \u1089 \u1077 \u1074 \u1099 \u1096 \u1085 \u1080 \u1081 , \u1072  \u1089  \u1053 \u1077 \u1073 \u1077 \u1089  \u1089 \u1087 \u1091 \u1089 \u1082 \u1072 \u1077 \u1090 \u1089 \u1103  \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1093 \u1086 \u1088 \u1086 \u1096 \u1077 \u1077 , \u1085 \u1086  \u1095 \u1077 \u1083 \u1086 \u1074 \u1077 \u1082  \u1085 \u1077  \u1089 \u1087 \u1086 \u1089 \u1086 \u1073 \u1077 \u1085  \u1101 \u1090 \u1086 \u1075 \u1086  \u1088 \u1072 \u1079 \u1086 \u1073 \u1088 \u1072 \u1090 \u1100 . \u1059 \u1078 \u1077  \u1089 \u1086 \u1074 \u1089 \u1077 \u1084  \u1073 \u1083 \u1080 \u1079 \u1082 \u1086 , \u1088 \u1091 \u1082 \u1086 \u1081  \u1087 \u1086 \u1076 \u1072 \u1090 \u1100 , \u1089 \u1074 \u1077 \u1088 \u1082 \u1072 \u1083  \u1087 \u1086 \u1082 \u1088 \u1099 \u1090 \u1099 \u1081  \u1080 \u1085 \u1077 \u1077 \u1084  \u1080  \u1089 \u1086 \u1089 \u1091 \u1083 \u1100 \u1082 \u1072 \u1084 \u1080  \u1050 \u1086 \u1078 \u1085 \u1080 \u1094 , \u1072  \u1074  \u1085 \u1077 \u1084  \u1061 \u1072 \u1095 \u1077  \u1078 \u1076 \u1072 \u1083 \u1080  \u1094 \u1072 \u1076 \u1080 \u1082 , \u1084 \u1080 \u1085 \u1100 \u1103 \u1085 , \u1077 \u1074 \u1088 \u1077 \u1080 , \u1095 \u1090 \u1077 \u1085 \u1080 \u1077  \'ab\u1057 \u1074 \u1080 \u1090 \u1082 \u1072  \u1069 \u1089 \u1090 \u1077 \u1088 \'bb, \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1095 \u1085 \u1072 \u1103  \u1095 \u1072 \u1088 \u1082 \u1072  \'97 \u1089 \u1083 \u1086 \u1074 \u1086 \u1084 , \u1074 \u1089 \u1077  \