\uc0\u1044 \u1077 \u1090 \u1080  \u1085 \u1072 \u1082 \u1080 \u1085 \u1091 \u1083 \u1080 \u1089 \u1100  \u1085 \u1072  \u1093 \u1083 \u1077 \u1073  \u1080  \u1089 \u1077 \u1083 \u1077 \u1076 \u1082 \u1091 , \u1056 \u1099 \u1089 \u1103  \u1089  \u1061 \u1072 \u1095 \u1077  \u1085 \u1077 \u1084 \u1085 \u1086 \u1075 \u1086  \u1087 \u1086 \u1084 \u1086 \u1075 \u1083 \u1080  \u1080 \u1084 , \u1080  \u1074  \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1077  \u1086 \u1089 \u1090 \u1072 \u1083 \u1072 \u1089 \u1100  \u1087 \u1086 \u1089 \u1083 \u1077 \u1076 \u1085 \u1103 \u1103  \u1090 \u1088 \u1077 \u1090 \u1100 . \u1053 \u1077 \u1091 \u1077 \u1084 \u1085 \u1086 \u1077  \u1074 \u1077 \u1089 \u1077 \u1083 \u1100 \u1077  \u1061 \u1072 \u1095 \u1077 , \u1087 \u1086 \u1083 \u1091 \u1095 \u1077 \u1085 \u1085 \u1086 \u1077  \u1080 \u1084  \u1086 \u1090  \u1052 \u1072 \u1075 \u1080 \u1076 \u1072 , \u1087 \u1077 \u1088 \u1077 \u1076 \u1072 \u1083 \u1086 \u1089 \u1100  \u1077 \u1075 \u1086  \u1089 \u1077 \u1084 \u1100 \u1077 . \u1054 \u1090 \u1086 \u1076 \u1074 \u1080 \u1085 \u1091 \u1074  \u1074  \u1089 \u1090 \u1086 \u1088 \u1086 \u1085 \u1091  \u1089 \u1090 \u1086 \u1083 , \u1076 \u1077 \u1090 \u1080  \u1079 \u1072 \u1082 \u1088 \u1091 \u1078 \u1080 \u1083 \u1080 \u1089 \u1100  \u1074  \u1093 \u1086 \u1088 \u1086 \u1074 \u1086 \u1076 \u1077 , \u1088 \u1072 \u1089 \u1087 \u1077 \u1074 \u1072 \u1103  \u1087 \u1091 \u1088 \u1080 \u1084 \u1089 \u1082 \u1080 \u1077  \u1087 \u1077 \u1089 \u1085 \u1080 . \u1056 \u1099 \u1089 \u1103  \u1080  \u1061 \u1072 \u1095 \u1077 , \u1089  \u1090 \u1088 \u1091 \u1076 \u1086 \u1084  \u1089 \u1090 \u1086 \u1103 \u1097 \u1080 \u1081  \u1085 \u1072  \u1085 \u1086 \u1075 \u1072 \u1093 , \u1087 \u1088 \u1080 \u1089 \u1086 \u1077 \u1076 \u1080 \u1085 \u1080 \u1083 \u1080 \u1089 \u1100  \u1082  \u1085 \u1080 \u1084 . \
