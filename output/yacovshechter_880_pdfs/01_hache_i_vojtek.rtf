\'97 \uc0\u1044 \u1086 \u1088 \u1086 \u1075 \u1072  \u1087 \u1077 \u1088 \u1077 \u1076  \u1085 \u1077 \u1081  \u1087 \u1086 \u1074 \u1086 \u1088 \u1086 \u1090  \u1076 \u1077 \u1083 \u1072 \u1077 \u1090 , \u1074 \u1086 \u1090  \u1080 \u1079 -\u1079 \u1072  \u1087 \u1086 \u1074 \u1086 \u1088 \u1086 \u1090 \u1072  \u1074 \u1099 \u1089 \u1090 \u1088 \u1077 \u1083 \u1099  \u1080  \u1076 \u1086 \u1085 \u1086 \u1089 \u1080 \u1083 \u1080 \u1089 \u1100 . \u1071  \u1083 \u1086 \u1096 \u1072 \u1076 \u1082 \u1091  \u1086 \u1089 \u1090 \u1072 \u1074 \u1080 \u1083  \u1080  \u1095 \u1077 \u1088 \u1077 \u1079  \u1083 \u1077 \u1089 \u1086 \u1082  \u1086 \u1089 \u1090 \u1086 \u1088 \u1086 \u1078 \u1085 \u1086  \u1087 \u1086 \u1076 \u1086 \u1073 \u1088 \u1072 \u1083 \u1089 \u1103 , \u1075 \u1083 \u1103 \u1085 \u1091 \u1090 \u1100 , \u1095 \u1090 \u1086  \u1087 \u1088 \u1086 \u1080 \u1089 \u1093 \u1086 \u1076 \u1080 \u1090 . \u1040  \u1090 \u1072 \u1084  \u1079 \u1072  \u1087 \u1086 \u1074 \u1086 \u1088 \u1086 \u1090 \u1086 \u1084  \u1085 \u1072 \u1089 \u1090 \u1086 \u1103 \u1097 \u1080 \u1081  \u1073 \u1086 \u1081 : \u1096 \u1072 \u1081 \u1082 \u1072  \u1088 \u1072 \u1079 \u1073 \u1086 \u1081 \u1085 \u1080 \u1082 \u1086 \u1074  \u1085 \u1072 \u1087 \u1072 \u1083 \u1072  \u1085 \u1072  \u1082 \u1072 \u1088 \u1077 \u1090 \u1091 . \u1047 \u1086 \u1083 \u1086 \u1095 \u1077 \u1085 \u1091 \u1102 , \u1089  \u1075 \u1077 \u1088 \u1073 \u1086 \u1084  \u1085 \u1072  \u1076 \u1074 \u1077 \u1088 \u1094 \u1077 . \u1043 \u1072 \u1081 \u1076 \u1091 \u1082 \u1080  \u1087 \u1072 \u1085 \u1089 \u1082 \u1080 \u1077  \u1088 \u1072 \u1079 \u1073 \u1086 \u1081 \u1085 \u1080 \u1082 \u1072 \u1084  \u1086 \u1090 \u1087 \u1086 \u1088  \u1076 \u1072 \u1083 \u1080 , \u1074 \u1089 \u1077 \u1093  \u1091 \u1083 \u1086 \u1078 \u1080 \u1083 \u1080 , \u1085 \u1086  \u1080  \u1089 \u1072 \u1084 \u1080  \u1087 \u1086 \u1083 \u1077 \u1075 \u1083 \u1080 . \u1071  \u1082 \u1086 \u1075 \u1076 \u1072  \u1082  \u1082 \u1072 \u1088 \u1077 \u1090 \u1077  \u1087 \u1086 \u1076 \u1086 \u1096 \u1077 \u1083 , \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1088 \u1072 \u1085 \u1077 \u1085 \u1099 \u1077  \u1093 \u1088 \u1080 \u1087 \u1077 \u1083 \u1080 , \u1082 \u1086 \u1085 \u1095 \u1072 \u1083 \u1080 \u1089 \u1100  \u1073 \u1077 \u1076 \u1086 \u1083 \u1072 \u1075 \u1080 . \
\uc0\u1042  \u1082 \u1072 \u1088 \u1077 \u1090 \u1077  \u1087 \u1072 \u1085  \u1089 \u1080 \u1076 \u1077 \u1083 , \u1089  \u1075 \u1086 \u1083 \u1086 \u1074 \u1086 \u1081  \u1087 \u1088 \u1086 \u1089 \u1090 \u1088 \u1077 \u1083 \u1077 \u1085 \u1085 \u1086 \u1081 , \u1072  \u1085 \u1072  \u1082 \u1086 \u1083 \u1077 \u1085 \u1103 \u1093  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1072 . \u1054 \u1085  \u1077 \u1077  \u1086 \u1073 \u1077 \u1080 \u1084 \u1080  \u1088 \u1091 \u1082 \u1072 \u1084 \u1080  \u1076 \u1077 \u1088 \u1078 \u1072 \u1083 , \u1082 \u1088 \u1077 \u1087 \u1082 \u1086 -\u1082 \u1088 \u1077 \u1087 \u1082 \u1086 , \u1103  \u1077 \u1083 \u1077  \u1087 \u1072 \u1083 \u1100 \u1094 \u1099  \u1088 \u1072 \u1089 \u1094 \u1077 \u1087 \u1080 \u1083 . \u1064 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1072  \u1076 \u1086 \u1088 \u1086 \u1075 \u1072 \u1103 , \u1085 \u1072  \u1082 \u1083 \u1102 \u1095  \u1079 \u1072 \u1087 \u1077 \u1088 \u1090 \u1072 \u1103 . \u1053 \u1091 , \u1103  \u1085 \u1077  \u1089 \u1090 \u1072 \u1083  \u1082 \u1083 \u1102 \u1095  \u1080 \u1089 \u1082 \u1072 \u1090 \u1100 , \u1074 \u1099 \u1090 \u1072 \u1097 \u1080 \u1083  \u1080 \u1079  \u1087 \u1072 \u1085 \u1089 \u1082 \u1080 \u1093  \u1084 \u1077 \u1088 \u1090 \u1074 \u1099 \u1093  \u1088 \u1091 \u1082  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091 , \u1083 \u1086 \u1096 \u1072 \u1076 \u1082 \u1091  \u1089 \u1074 \u1086 \u1102  \u1085 \u1072  \u1076 \u1088 \u1091 \u1075 \u1091 \u1102  \u1076 \u1086 \u1088 \u1086 \u1075 \u1091  \u1085 \u1072 \u1087 \u1088 \u1072 \u1074 \u1080 \u1083  \u1080  \u1076 \u1072 \u1083  \u1076 \u1077 \u1088 \u1091 . \u1054 \u1090 \u1098 \u1077 \u1093 \u1072 \u1083  \u1087 \u1086 \u1088 \u1103 \u1076 \u1086 \u1095 \u1085 \u1086 , \u1079 \u1072 \u1096 \u1077 \u1083  \u1074  \u1088 \u1086 \u1097 \u1091 , \u1087 \u1086 \u1076 \u1072 \u1083 \u1100 \u1096 \u1077  \u1086 \u1090  \u1095 \u1091 \u1078 \u1080 \u1093  \u1075 \u1083 \u1072 \u1079 , \u1080  \u1090 \u1086 \u1087 \u1086 \u1088 \u1086 \u1084  \u1074 \u1089 \u1082 \u1088 \u1099 \u1083  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091 . \u1042  \u1085 \u1077 \u1081  \u1076 \u1088 \u1072 \u1075 \u1086 \u1094 \u1077 \u1085 \u1085 \u1086 \u1089 \u1090 \u1080 : \u1082 \u1086 \u1083 \u1100 \u1094 \u1072  \u1073 \u1088 \u1080 \u1083 \u1083 \u1080 \u1072 \u1085 \u1090 \u1086 \u1074 \u1099 \u1077 , \u1089 \u1077 \u1088 \u1100 \u1075 \u1080 , \u1086 \u1078 \u1077 \u1088 \u1077 \u1083 \u1100 \u1103 . \u1042 \u1089 \u1077  \u1089 \u1080 \u1103 \u1077 \u1090 , \u1087 \u1077 \u1088 \u1077 \u1083 \u1080 \u1074 \u1072 \u1077 \u1090 \u1089 \u1103 , \u1073 \u1086 \u1083 \u1100 \u1096 \u1086 \u1077  \u1073 \u1086 \u1075 \u1072 \u1090 \u1089 \u1090 \u1074 \u1086 . \
\uc0\u1071  \u1089 \u1088 \u1072 \u1079 \u1091  \u1087 \u1086 \u1085 \u1103 \u1083 , \u1095 \u1090 \u1086  \u1076 \u1086 \u1073 \u1088 \u1086 \u1084  \u1101 \u1090 \u1086  \u1085 \u1077  \u1082 \u1086 \u1085 \u1095 \u1080 \u1090 \u1089 \u1103 , \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091  \u1085 \u1072 \u1089 \u1083 \u1077 \u1076 \u1085 \u1080 \u1082 \u1080  \u1080 \u1089 \u1082 \u1072 \u1090 \u1100  \u1089 \u1090 \u1072 \u1085 \u1091 \u1090 , \u1079 \u1077 \u1084 \u1083 \u1102  \u1085 \u1086 \u1089 \u1086 \u1084  \u1088 \u1099 \u1090 \u1100 . \u1050 \u1086 \u1083 \u1086 \u1076 \u1077 \u1094  \u1085 \u1072  \u1087 \u1086 \u1083 \u1076 \u1086 \u1088 \u1086 \u1075 \u1077  \u1074  \u1050 \u1086 \u1078 \u1085 \u1080 \u1094  \u1079 \u1085 \u1072 \u1077 \u1096 \u1100 ?\
\'97 \uc0\u1047 \u1085 \u1072 \u1102 .\
\'97 \uc0\u1057 \u1087 \u1088 \u1072 \u1074 \u1072  \u1086 \u1090  \u1085 \u1077 \u1075 \u1086  \u1076 \u1091 \u1073 , \u1084 \u1086 \u1083 \u1085 \u1080 \u1077 \u1081  \u1089 \u1086 \u1078 \u1078 \u1077 \u1085 \u1085 \u1099 \u1081 . \u1055 \u1086 \u1076  \u1085 \u1080 \u1084 , \u1089 \u1086  \u1089 \u1090 \u1086 \u1088 \u1086 \u1085 \u1099  \u1086 \u1090 \u1082 \u1088 \u1099 \u1090 \u1086 \u1075 \u1086  \u1076 \u1091 \u1087 \u1083 \u1072 , \u1103  \u1101 \u1090 \u1091  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091  \u1080  \u1079 \u1072 \u1082 \u1086 \u1087 \u1072 \u1083 . \u1048  \u1074 \u1072 \u1083 \u1091 \u1085  \u1085 \u1072 \u1082 \u1072 \u1090 \u1080 \u1083 , \u1095 \u1090 \u1086 \u1073 \u1099  \u1089 \u1082 \u1088 \u1099 \u1090 \u1100  \u1089 \u1074 \u1077 \u1078 \u1091 \u1102  \u1079 \u1077 \u1084 \u1083 \u1102 . \u1047 \u1072 \u1082 \u1086 \u1087 \u1072 \u1083  \u1080  \u1087 \u1086 \u1077 \u1093 \u1072 \u1083  \u1089 \u1077 \u1073 \u1077  \u1074  \u1050 \u1086 \u1078 \u1085 \u1080 \u1094 . \
\uc0\u1050  \u1074 \u1077 \u1095 \u1077 \u1088 \u1091  \u1085 \u1072 \u1083 \u1077 \u1090 \u1077 \u1083 \u1086  \u1087 \u1086 \u1083 \u1080 \u1094 \u1080 \u1080  \u1074 \u1080 \u1076 \u1080 \u1084 \u1086 -\u1085 \u1077 \u1074 \u1080 \u1076 \u1080 \u1084 \u1086 , \u1074 \u1089 \u1077 \u1093  \u1076 \u1086 \u1087 \u1088 \u1086 \u1089 \u1080 \u1083 \u1080 , \u1074 \u1089 \u1077  \u1087 \u1077 \u1088 \u1077 \u1090 \u1088 \u1103 \u1089 \u1083 \u1080 . \u1040  \u1103  \u1084 \u1086 \u1083 \u1095 \u1086 \u1082 , \u1085 \u1080 \u1095 \u1077 \u1075 \u1086  \u1085 \u1077  \u1079 \u1085 \u1072 \u1102 , \u1073 \u1099 \u1083  \u1074  \u1075 \u1086 \u1088 \u1086 \u1076 \u1077 , \u1080  \u1089 \u1074 \u1080 \u1076 \u1077 \u1090 \u1077 \u1083 \u1080  \u1090 \u1086 \u1084 \u1091  \u1077 \u1089 \u1090 \u1100 . \u1054 \u1090 \u1082 \u1091 \u1076 \u1072  \u1087 \u1086 \u1083 \u1080 \u1094 \u1080 \u1080  \u1079 \u1085 \u1072 \u1090 \u1100 , \u1082 \u1086 \u1075 \u1076 \u1072  \u1085 \u1072 \u1087 \u1072 \u1076 \u1077 \u1085 \u1080 \u1077  \u1089 \u1086 \u1074 \u1077 \u1088 \u1096 \u1080 \u1083 \u1086 \u1089 \u1100 , \u1074 \u1086 \u1090  \u1103  \u1080  \u1089 \u1090 \u1086 \u1103 \u1083  \u1085 \u1072  \u1089 \u1074 \u1086 \u1077 \u1084 . \u1058 \u1072 \u1082  \u1085 \u1080 \u1095 \u1077 \u1084  \u1076 \u1077 \u1083 \u1086  \u1080  \u1085 \u1077  \u1082 \u1086 \u1085 \u1095 \u1080 \u1083 \u1086 \u1089 \u1100 , \u1076 \u1091 \u1084 \u1072 \u1102 , \u1086 \u1085 \u1080  \u1088 \u1077 \u1096 \u1080 \u1083 \u1080 , \u1095 \u1090 \u1086  \u1082 \u1090 \u1086 -\u1090 \u1086  \u1080 \u1079  \u1088 \u1072 \u1079 \u1073 \u1086 \u1081 \u1085 \u1080 \u1082 \u1086 \u1074  \u1091 \u1094 \u1077 \u1083 \u1077 \u1083  \u1080  \u1091 \u1085 \u1077 \u1089  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091 . \
\uc0\u1047 \u1072  \u1087 \u1088 \u1086 \u1096 \u1077 \u1076 \u1096 \u1080 \u1077  \u1075 \u1086 \u1076 \u1099  \u1085 \u1077  \u1073 \u1099 \u1083 \u1086  \u1076 \u1085 \u1103 , \u1074  \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1081  \u1103  \u1087 \u1088 \u1086  \u1101 \u1090 \u1080  \u1076 \u1088 \u1072 \u1075 \u1086 \u1094 \u1077 \u1085 \u1085 \u1086 \u1089 \u1090 \u1080  \u1085 \u1077  \u1076 \u1091 \u1084 \u1072 \u1083 . \u1044 \u1091 \u1084 \u1072 \u1083  \u1080  \u1073 \u1086 \u1103 \u1083 \u1089 \u1103 . \u1050 \u1091 \u1076 \u1072  \u1103  \u1089  \u1085 \u1080 \u1084 \u1080 ? \u1057 \u1088 \u1072 \u1079 \u1091  \u1087 \u1086 \u1081 \u1084 \u1091 \u1090 : \u1080 \u1083 \u1080  \u1091 \u1082 \u1088 \u1072 \u1083 , \u1080 \u1083 \u1080  \u1086 \u1075 \u1088 \u1072 \u1073 \u1080 \u1083 . \u1042  \u1085 \u1072 \u1096 \u1080 \u1093  \u1082 \u1088 \u1072 \u1103 \u1093  \u1087 \u1088 \u1086 \u1076 \u1072 \u1090 \u1100  \u1090 \u1072 \u1082 \u1080 \u1077  \u1074 \u1077 \u1097 \u1080  \u1085 \u1077 \u1074 \u1086 \u1079 \u1084 \u1086 \u1078 \u1085 \u1086 , \u1085 \u1072 \u1076 \u1086  \u1091 \u1077 \u1079 \u1078 \u1072 \u1090 \u1100  \u1076 \u1072 \u1083 \u1077 \u1082 \u1086  \u1080  \u1087 \u1091 \u1089 \u1082 \u1072 \u1090 \u1100 \u1089 \u1103  \u1074 \u1086  \u1074 \u1089 \u1103 \u1082 \u1080 \u1077  \u1093 \u1080 \u1090 \u1088 \u1086 \u1089 \u1090 \u1080 . \u1040  \u1103  \u1087 \u1088 \u1086 \u1089 \u1090 \u1086 \u1081  \u1082 \u1088 \u1077 \u1089 \u1090 \u1100 \u1103 \u1085 \u1080 \u1085 , \u1085 \u1077  \u1091 \u1084 \u1077 \u1102 . \u1042 \u1086 \u1090 , \u1076 \u1091 \u1084 \u1072 \u1083 , \u1089 \u1099 \u1085  \u1087 \u1086 \u1076 \u1088 \u1072 \u1089 \u1090 \u1077 \u1090 , \u1089 \u1099 \u1085 \'85 \
\uc0\u1042 \u1086 \u1086 \u1073 \u1097 \u1077 , \u1087 \u1088 \u1072 \u1074 \u1080 \u1083 \u1100 \u1085 \u1086  \u1074 \u1089 \u1077  \u1087 \u1086 \u1083 \u1091 \u1095 \u1080 \u1083 \u1086 \u1089 \u1100 . \u1058 \u1099  \u1087 \u1086 \u1081 \u1076 \u1077 \u1096 \u1100  \u1082  \u1089 \u1074 \u1086 \u1080 \u1084  \u1077 \u1074 \u1088 \u1077 \u1103 \u1084 , \u1086 \u1085 \u1080  \u1085 \u1077  \u1074 \u1099 \u1076 \u1072 \u1076 \u1091 \u1090 , \u1088 \u1072 \u1079 \u1074 \u1077  \u1095 \u1090 \u1086  \u1094 \u1077 \u1085 \u1091  \u1085 \u1080 \u1078 \u1077  \u1076 \u1072 \u1076 \u1091 \u1090 . \u1058 \u1086 \u1083 \u1100 \u1082 \u1086  \u1074 \u1086 \u1090  \u1103  \u1090 \u1077 \u1073 \u1077  \u1091 \u1089 \u1083 \u1086 \u1074 \u1080 \u1077  \u1089 \u1090 \u1072 \u1074 \u1083 \u1102 . \u1061 \u1072 \u1095 \u1077 , \u1087 \u1086 \u1093 \u1086 \u1088 \u1086 \u1085 \u1080  \u1084 \u1077 \u1085 \u1103  \u1082 \u1072 \u1082  \u1087 \u1086 \u1083 \u1086 \u1078 \u1077 \u1085 \u1086 , \u1087 \u1072 \u1084 \u1103 \u1090 \u1085 \u1080 \u1082  \u1089 \u1087 \u1088 \u1072 \u1074 \u1100 , \u1083 \u1072 \u1076 \u1085 \u1099 \u1081 , \u1076 \u1086 \u1073 \u1088 \u1086 \u1090 \u1085 \u1099 \u1081 . \u1050 \u1072 \u1082  \u1103  \u1078 \u1080 \u1083 , \u1087 \u1091 \u1089 \u1090 \u1100  \u1090 \u1072 \u1082 \u1086 \u1081  \u1087 \u1072 \u1084 \u1103 \u1090 \u1085 \u1080 \u1082  \u1080  \u1073 \u1091 \u1076 \u1077 \u1090 . \u1048  \u1089  \u1082 \u1089 \u1077 \u1085 \u1076 \u1079 \u1086 \u1084  \u1085 \u1077  \u1090 \u1086 \u1088 \u1075 \u1091 \u1081 \u1089 \u1103 , \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1079 \u1072 \u1087 \u1088 \u1086 \u1089 \u1080 \u1090 , \u1089 \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1080  \u1076 \u1072 \u1081 , \u1080  \u1077 \u1097 \u1077  \u1085 \u1072 \u1076 \u1073 \u1072 \u1074 \u1100 , \u1087 \u1091 \u1089 \u1090 \u1100  \u1084 \u1077 \u1085 \u1103  \u1074 \u1089 \u1087 \u1086 \u1084 \u1080 \u1085 \u1072 \u1077 \u1090 . \u1054 \u1076 \u1086 \u1083 \u1078 \u1080 , \u1085 \u1086  \u1079 \u1072 \u1087 \u1083 \u1072 \u1090 \u1080 , \u1087 \u1086 \u1090 \u1086 \u1084  \u1089 \u1090 \u1086 \u1088 \u1080 \u1094 \u1077 \u1081  \u1090 \u1077 \u1073 \u1077  \u1074 \u1077 \u1088 \u1085 \u1077 \u1090 \u1089 \u1103  \u1080 \u1079  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1080 .\
\uc0\u1061 \u1072 \u1095 \u1077  \u1074 \u1077 \u1088 \u1080 \u1083  \u1080  \u1085 \u1077  \u1074 \u1077 \u1088 \u1080 \u1083 . \u1044 \u1072 , \u1086 \u1085  \u1087 \u1086 \u1084 \u1085 \u1080 \u1083  \u1080 \u1089 \u1090 \u1086 \u1088 \u1080 \u1102  \u1089  \u1086 \u1075 \u1088 \u1072 \u1073 \u1083 \u1077 \u1085 \u1080 \u1077 \u1084 , \u1087 \u1086 \u1084 \u1085 \u1080 \u1083 , \u1082 \u1072 \u1082  \u1087 \u1086 \u1083 \u1080 \u1094 \u1080 \u1103  \u1088 \u1099 \u1089 \u1082 \u1072 \u1083 \u1072  \u1087 \u1086  \u1076 \u1077 \u1088 \u1077 \u1074 \u1085 \u1103 \u1084  \u1080  \u1084 \u1077 \u1089 \u1090 \u1077 \u1095 \u1082 \u1072 \u1084 , \u1085 \u1086  \u1087 \u1088 \u1086  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091  \u1089 \u1083 \u1099 \u1096 \u1072 \u1083  \u1074 \u1087 \u1077 \u1088 \u1074 \u1099 \u1077 . \u1055 \u1088 \u1072 \u1074 \u1076 \u1091  \u1083 \u1080  \u1088 \u1072 \u1089 \u1089 \u1082 \u1072 \u1079 \u1099 \u1074 \u1072 \u1077 \u1090  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1080 \u1083 \u1080  \u1086 \u1090  \u1089 \u1090 \u1072 \u1088 \u1086 \u1089 \u1090 \u1080  \u1080  \u1073 \u1086 \u1083 \u1077 \u1079 \u1085 \u1080  \u1077 \u1075 \u1086  \u1089 \u1086 \u1079 \u1085 \u1072 \u1085 \u1080 \u1077  \u1087 \u1086 \u1084 \u1091 \u1090 \u1080 \u1083 \u1086 \u1089 \u1100 ? \u1040  \u1077 \u1089 \u1083 \u1080  \u1087 \u1088 \u1072 \u1074 \u1076 \u1091 , \u1084 \u1086 \u1078 \u1077 \u1090  \u1083 \u1080  \u1086 \u1085 , \u1061 \u1072 \u1095 \u1077 , \u1074 \u1079 \u1103 \u1090 \u1100  \u1089 \u1077 \u1073 \u1077  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091 , \u1085 \u1077  \u1087 \u1086 \u1083 \u1072 \u1075 \u1072 \u1077 \u1090 \u1089 \u1103  \u1083 \u1080  \u1074 \u1077 \u1088 \u1085 \u1091 \u1090 \u1100  \u1077 \u1077  \u1079 \u1072 \u1082 \u1086 \u1085 \u1085 \u1099 \u1084  \u1085 \u1072 \u1089 \u1083 \u1077 \u1076 \u1085 \u1080 \u1082 \u1072 \u1084 ? \
\uc0\u1055 \u1088 \u1086 \u1096 \u1083 \u1086  \u1085 \u1077 \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1085 \u1077 \u1076 \u1077 \u1083 \u1100 . \u1061 \u1072 \u1095 \u1077  \u1089 \u1093 \u1086 \u1076 \u1080 \u1083  \u1074  \u1050 \u1086 \u1078 \u1085 \u1080 \u1094  \u1080  \u1087 \u1086 \u1090 \u1080 \u1093 \u1086 \u1085 \u1100 \u1082 \u1091  \u1088 \u1072 \u1089 \u1089 \u1087 \u1088 \u1086 \u1089 \u1080 \u1083  \u1089 \u1090 \u1072 \u1088 \u1080 \u1082 \u1086 \u1074  \u1087 \u1088 \u1086  \u1090 \u1091  \u1076 \u1072 \u1074 \u1085 \u1102 \u1102  \u1080 \u1089 \u1090 \u1086 \u1088 \u1080 \u1102 . \u1054 \u1082 \u1072 \u1079 \u1072 \u1083 \u1086 \u1089 \u1100 , \u1095 \u1090 \u1086  \u1091  \u1087 \u1072 \u1085 \u1072  \u1085 \u1077  \u1073 \u1099 \u1083 \u1086  \u1076 \u1077 \u1090 \u1077 \u1081 , \u1077 \u1084 \u1091  \u1085 \u1072 \u1089 \u1083 \u1077 \u1076 \u1086 \u1074 \u1072 \u1083  \u1087 \u1083 \u1077 \u1084 \u1103 \u1085 \u1085 \u1080 \u1082 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1081  \u1087 \u1088 \u1086 \u1084 \u1086 \u1090 \u1072 \u1083  \u1074  \u1082 \u1072 \u1088 \u1090 \u1099  \u1087 \u1086 \u1084 \u1077 \u1089 \u1090 \u1100 \u1077  \u1080  \u1089 \u1087 \u1091 \u1089 \u1090 \u1103  \u1087 \u1103 \u1090 \u1100  \u1083 \u1077 \u1090  \u1073 \u1099 \u1083  \u1091 \u1073 \u1080 \u1090  \u1085 \u1072  \u1076 \u1091 \u1101 \u1083 \u1080 . \u1042 \u1086 \u1079 \u1074 \u1088 \u1072 \u1097 \u1072 \u1090 \u1100  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091 , \u1077 \u1089 \u1083 \u1080  \u1090 \u1072 \u1082 \u1072 \u1103  \u1086 \u1073 \u1085 \u1072 \u1088 \u1091 \u1078 \u1080 \u1090 \u1089 \u1103 , \u1073 \u1099 \u1083 \u1086  \u1085 \u1077 \u1082 \u1086 \u1084 \u1091 .\
\
\uc0\u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1091 \u1084 \u1077 \u1088  \u1074 \u1086  \u1089 \u1085 \u1077 . \u1055 \u1086 \u1082 \u1072  \u1090 \u1077 \u1083 \u1086  \u1075 \u1086 \u1090 \u1086 \u1074 \u1080 \u1083 \u1080  \u1082  \u1087 \u1086 \u1075 \u1088 \u1077 \u1073 \u1077 \u1085 \u1080 \u1102 , \u1061 \u1072 \u1095 \u1077  \u1087 \u1086 \u1089 \u1087 \u1077 \u1096 \u1080 \u1083  \u1082  \u1076 \u1091 \u1073 \u1091  \u1074 \u1086 \u1079 \u1083 \u1077  \u1082 \u1086 \u1083 \u1086 \u1076 \u1094 \u1072  \u1080 , \u1086 \u1090 \u1082 \u1072 \u1090 \u1080 \u1074  \u1074 \u1072 \u1083 \u1091 \u1085 , \u1074 \u1099 \u1082 \u1086 \u1087 \u1072 \u1083  \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1091 . \u1057 \u1090 \u1072 \u1088 \u1080 \u1082  \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1083  \u1087 \u1088 \u1072 \u1074 \u1076 \u1091 : \u1096 \u1082 \u1072 \u1090 \u1091 \u1083 \u1082 \u1072  \u1073 \u1099 \u1083 \u1072  \u1076 \u1086 \u1074 \u1077 \u1088 \u1093 \u1091  \u1085 \u1072 \u1087 \u1086 \u1083 \u1085 \u1077 \u1085 \u1072  \u1076 \u1088 \u1072 \u1075 \u1086 \u1094 \u1077 \u1085 \u1085 \u1099 \u1084 \u1080  \u1091 \u1082 \u1088 \u1072 \u1096 \u1077 \u1085 \u1080 \u1103 \u1084 \u1080 . \
\uc0\u1061 \u1072 \u1095 \u1077  \u1085 \u1077  \u1089 \u1090 \u1072 \u1083  \u1089 \u1087 \u1077 \u1096 \u1080 \u1090 \u1100 . \u1044 \u1083 \u1103  \u1085 \u1072 \u1095 \u1072 \u1083 \u1072  \u1086 \u1085  \u1074 \u1099 \u1073 \u1088 \u1072 \u1083  \u1089 \u1072 \u1084 \u1086 \u1077  \u1084 \u1072 \u1083 \u1077 \u1085 \u1100 \u1082 \u1086 \u1077  \u1082 \u1086 \u1083 \u1077 \u1095 \u1082 \u1086 . \u1042 \u1099 \u1088 \u1091 \u1095 \u1077 \u1085 \u1085 \u1099 \u1093  \u1076 \u1077 \u1085 \u1077 \u1075  \u1093 \u1074 \u1072 \u1090 \u1080 \u1083 \u1086  \u1088 \u1072 \u1089 \u1089 \u1095 \u1080 \u1090 \u1072 \u1090 \u1100 \u1089 \u1103  \u1089 \u1086  \u1074 \u1089 \u1077 \u1084 \u1080  \u1076 \u1086 \u1083 \u1075 \u1072 \u1084 \u1080 , \u1087 \u1077 \u1088 \u1077 \u1073 \u1088 \u1072 \u1090 \u1100 \u1089 \u1103  \u1074  \u1050 \u1086 \u1078 \u1085 \u1080 \u1094  \u1080  \u1086 \u1090 \u1082 \u1088 \u1099 \u1090 \u1100  \u1096 \u1086 \u1088 \u1085 \u1091 \u1102  \u1084 \u1072 \u1089 \u1090 \u1077 \u1088 \u1089 \u1082 \u1091 \u1102 . \u1042  \u1075 \u1086 \u1088 \u1086 \u1076 \u1077  \u1101 \u1082 \u1080 \u1087 \u1072 \u1078 \u1077 \u1081  \u1073 \u1099 \u1083 \u1086  \u1073 \u1086 \u1083 \u1100 \u1096 \u1077 , \u1095 \u1077 \u1084  \u1074  \u1076 \u1077 \u1088 \u1077 \u1074 \u1085 \u1077 , \u1085 \u1086  \u1089 \u1072 \u1084 \u1086 \u1077  \u1075 \u1083 \u1072 \u1074 \u1085 \u1086 \u1077  \'97 \u1075 \u1086 \u1089 \u1087 \u1086 \u1076 \u1072  \u1089 \u1090 \u1077 \u1089 \u1085 \u1103 \u1083 \u1080 \u1089 \u1100  \u1074 \u1099 \u1077 \u1079 \u1078 \u1072 \u1090 \u1100  \u1074  \u1101 \u1082 \u1080 \u1087 \u1072 \u1078 \u1072 \u1093  \u1089 \u1086  \u1089 \u1090 \u1072 \u1088 \u1086 \u1081  \u1089 \u1073 \u1088 \u1091 \u1077 \u1081 . \u1044 \u1077 \u1083 \u1086  \u1091  \u1061 \u1072 \u1095 \u1077  \u1087 \u1086 \u1096 \u1083 \u1086 , \u1074 \u1077 \u1076 \u1100  \u1082 \u1086 \u1078 \u1091  \u1086 \u1085  \u1087 \u1086 \u1082 \u1091 \u1087 \u1072 \u1083  \u1089 \u1072 \u1084 \u1091 \u1102  \u1083 \u1091 \u1095 \u1096 \u1091 \u1102 , \u1072  \u1087 \u1083 \u1072 \u1090 \u1091  \u1073 \u1088 \u1072 \u1083  \u1074 \u1077 \u1089 \u1100 \u1084 \u1072  \u1091 \u1084 \u1077 \u1088 \u1077 \u1085 \u1085 \u1091 \u1102 . \u1057 \u1087 \u1091 \u1089 \u1090 \u1103  \u1076 \u1074 \u1072  \u1075 \u1086 \u1076 \u1072  \u1086 \u1085  \u1091 \u1078 \u1077  \u1089 \u1095 \u1080 \u1090 \u1072 \u1083 \u1089 \u1103  \u1073 \u1086 \u1075 \u1072 \u1095 \u1086 \u1084  \u1080  \u1087 \u1077 \u1088 \u1077 \u1096 \u1077 \u1083  \u1086 \u1090  \u1087 \u1086 \u1096 \u1080 \u1074 \u1072  \u1080  \u1088 \u1077 \u1084 \u1086 \u1085 \u1090 \u1072  \u1089 \u1073 \u1088 \u1091 \u1080  \u1082  \u1090 \u1086 \u1088 \u1075 \u1086 \u1074 \u1083 \u1077  \u1079 \u1077 \u1088 \u1085 \u1086 \u1084 . \u1053 \u1080  \u1086 \u1076 \u1085 \u1086 \u1084 \u1091  \u1102 \u1074 \u1077 \u1083 \u1080 \u1088 \u1091  \u1090 \u1077 \u1087 \u1077 \u1088 \u1100  \u1080  \u1074  \u1075 \u1086 \u1083 \u1086 \u1074 \u1091  \u1085 \u1077  \u1084 \u1086 \u1075 \u1083 \u1086  \u1087 \u1088 \u1080 \u1081 \u1090 \u1080  \u1088 \u1072 \u1089 \u1089 \u1087 \u1088 \u1072 \u1096 \u1080 \u1074 \u1072 \u1090 \u1100  \u1077 \u1075 \u1086  \u1086  \u1087 \u1088 \u1086 \u1080 \u1089 \u1093 \u1086 \u1078 \u1076 \u1077 \u1085 \u1080 \u1080  \u1076 \u1088 \u1072 \u1075 \u1086 \u1094 \u1077 \u1085 \u1085 \u1086 \u1089 \u1090 \u1077 \u1081 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1077  \u1086 \u1085  \u1074 \u1088 \u1077 \u1084 \u1103  \u1086 \u1090  \u1074 \u1088 \u1077 \u1084 \u1077 \u1085 \u1080  \u1087 \u1088 \u1080 \u1085 \u1086 \u1089 \u1080 \u1083  \u1076 \u1083 \u1103  \u1087 \u1088 \u1086 \u1076 \u1072 \u1078 \u1080 . \
\uc0\u1048  \u1088 \u1072 \u1079 \u1073 \u1086 \u1075 \u1072 \u1090 \u1077 \u1083  \u1090 \u1086 \u1090  \u1095 \u1077 \u1083 \u1086 \u1074 \u1077 \u1082 , \u1086 \u1073 \u1079 \u1072 \u1074 \u1077 \u1083 \u1089 \u1103  \u1076 \u1086 \u1084 \u1072 \u1084 \u1080 , \u1087 \u1088 \u1080 \u1082 \u1072 \u1079 \u1095 \u1080 \u1082 \u1072 \u1084 \u1080  \u1080  \u1087 \u1088 \u1080 \u1089 \u1083 \u1091 \u1075 \u1086 \u1081 , \u1078 \u1077 \u1088 \u1090 \u1074 \u1086 \u1074 \u1072 \u1083  \u1097 \u1077 \u1076 \u1088 \u1086 \u1081  \u1088 \u1091 \u1082 \u1086 \u1081  \u1085 \u1072  \u1073 \u1077 \u1076 \u1085 \u1099 \u1093  \u1080  \u1082 \u1072 \u1078 \u1076 \u1099 \u1081  \u1075 \u1086 \u1076  \u1087 \u1088 \u1080 \u1093 \u1086 \u1076 \u1080 \u1083  \u1082  \u1052 \u1072 \u1075 \u1080 \u1076 \u1091  \u1085 \u1072  \u1087 \u1091 \u1088 \u1080 \u1084 \u1089 \u1082 \u1091 \u1102  \u1090 \u1088 \u1072 \u1087 \u1077 \u1079 \u1091 , \u1087 \u1088 \u1080 \u1085 \u1086 \u1089 \u1103  \u1074 \u1089 \u1077 \u1075 \u1076 \u1072  \u1086 \u1076 \u1085 \u1086  \u1080  \u1090 \u1086  \u1078 \u1077  \u1074  \u1082 \u1086 \u1088 \u1079 \u1080 \u1085 \u1082 \u1077  \u1076 \u1083 \u1103  \u1096 \u1072 \u1083 \u1072 \u1093 \u1084 \u1086 \u1085 \u1077 \u1089 : \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1091  \u1074 \u1080 \u1085 \u1072 , \u1076 \u1074 \u1077  \u1089 \u1091 \u1096 \u1077 \u1085 \u1099 \u1077  \u1075 \u1088 \u1091 \u1096 \u1080  \u1080  \u1087 \u1086 \u1083 \u1092 \u1091 \u1085 \u1090 \u1072  \u1080 \u1079 \u1102 \u1084 \u1072 .}