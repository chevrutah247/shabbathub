\'97 \uc0\u1050 \u1090 \u1086  \u1101 \u1090 \u1086  \u1084 \u1086 \u1078 \u1077 \u1090  \u1073 \u1099 \u1090 \u1100 ? \'97 \u1091 \u1076 \u1080 \u1074 \u1080 \u1083 \u1072 \u1089 \u1100  \u1056 \u1099 \u1089 \u1103 . \u1050  \u1085 \u1080 \u1084  \u1076 \u1072 \u1074 \u1085 \u1086  \u1091 \u1078 \u1077  \u1085 \u1080 \u1082 \u1090 \u1086  \u1085 \u1077  \u1087 \u1088 \u1080 \u1093 \u1086 \u1076 \u1080 \u1083 : \u1083 \u1102 \u1076 \u1080  \u1089 \u1090 \u1086 \u1088 \u1086 \u1085 \u1103 \u1090 \u1089 \u1103  \u1085 \u1080 \u1097 \u1077 \u1090 \u1099  \u1080  \u1073 \u1077 \u1075 \u1091 \u1090  \u1086 \u1090  \u1085 \u1077 \u1091 \u1076 \u1072 \u1095 \u1080 .\
\'97 \uc0\u1040 , \u1074 \u1089 \u1087 \u1086 \u1084 \u1085 \u1080 \u1083 ! \'97 \u1074 \u1086 \u1089 \u1082 \u1083 \u1080 \u1082 \u1085 \u1091 \u1083  \u1061 \u1072 \u1095 \u1077 . \'97 \u1069 \u1090 \u1086  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1087 \u1088 \u1080 \u1074 \u1077 \u1079  \u1088 \u1077 \u1087 \u1082 \u1080 . \u1071  \u1077 \u1084 \u1091  \u1087 \u1086  \u1076 \u1086 \u1088 \u1086 \u1075 \u1077  \u1074  \u1050 \u1086 \u1078 \u1085 \u1080 \u1094  \u1096 \u1083 \u1077 \u1102  \u1087 \u1086 \u1095 \u1080 \u1085 \u1080 \u1083 . \u1054 \u1090 \u1082 \u1088 \u1099 \u1074 \u1072 \u1081 , \u1056 \u1099 \u1089 \u1103 , \u1079 \u1072 \u1074 \u1090 \u1088 \u1072 \u1096 \u1085 \u1080 \u1081  \u1086 \u1073 \u1077 \u1076  \u1087 \u1088 \u1080 \u1096 \u1077 \u1083 !\
\uc0\u1056 \u1099 \u1089 \u1103  \u1086 \u1090 \u1074 \u1086 \u1088 \u1080 \u1083 \u1072 . \u1053 \u1072  \u1087 \u1086 \u1088 \u1086 \u1075 \u1077 , \u1087 \u1086 \u1082 \u1072 \u1095 \u1080 \u1074 \u1072 \u1103 \u1089 \u1100 , \u1089 \u1090 \u1086 \u1103 \u1083  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 . \u1054 \u1073 \u1072  \u1075 \u1083 \u1072 \u1079 \u1072  \u1073 \u1099 \u1083 \u1080  \u1087 \u1086 \u1076 \u1073 \u1080 \u1090 \u1099 , \u1089 \u1082 \u1091 \u1083 \u1099  \u1088 \u1072 \u1089 \u1087 \u1091 \u1093 \u1083 \u1080 , \u1080 \u1079 -\u1087 \u1086 \u1076  \u1096 \u1072 \u1087 \u1082 \u1080  \u1089 \u1086 \u1095 \u1080 \u1083 \u1072 \u1089 \u1100  \u1082 \u1088 \u1086 \u1074 \u1100 .\
\'97 \uc0\u1042 \u1086 \u1090 , \'97 \u1084 \u1072 \u1093 \u1085 \u1091 \u1083  \u1086 \u1085  \u1090 \u1086 \u1088 \u1073 \u1086 \u1081 , \u1079 \u1072 \u1078 \u1072 \u1090 \u1086 \u1081  \u1074  \u1088 \u1091 \u1082 \u1077 , \'97 \u1088 \u1077 \u1087 \u1091 \u1096 \u1082 \u1080  \u1086 \u1073 \u1077 \u1097 \u1072 \u1083 \'85\
\'97 \uc0\u1041 \u1086 \u1078 \u1077  \u1084 \u1080 \u1083 \u1086 \u1089 \u1090 \u1080 \u1074 \u1099 \u1081 ! \'97 \u1074 \u1089 \u1082 \u1088 \u1080 \u1095 \u1072 \u1083 \u1072  \u1056 \u1099 \u1089 \u1103 . \'97 \u1055 \u1072 \u1085  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 , \u1082 \u1090 \u1086  \u1090 \u1077 \u1073 \u1103  \u1090 \u1072 \u1082  \u1086 \u1090 \u1076 \u1077 \u1083 \u1072 \u1083 ?!\
\uc0\u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1089 \u1075 \u1083 \u1086 \u1090 \u1085 \u1091 \u1083  \u1080  \u1091 \u1093 \u1074 \u1072 \u1090 \u1080 \u1083 \u1089 \u1103  \u1079 \u1072  \u1082 \u1086 \u1089 \u1103 \u1082  \u1076 \u1074 \u1077 \u1088 \u1080 , \u1095 \u1090 \u1086 \u1073 \u1099  \u1085 \u1077  \u1091 \u1087 \u1072 \u1089 \u1090 \u1100 .\
\'97 \uc0\u1056 \u1086 \u1076 \u1085 \u1086 \u1081  \u1089 \u1099 \u1085 , \'97 \u1087 \u1088 \u1086 \u1093 \u1088 \u1080 \u1087 \u1077 \u1083  \u1086 \u1085 . \'97 \u1042 \u1086 \u1076 \u1082 \u1080  \u1077 \u1084 \u1091  \u1085 \u1077  \u1093 \u1074 \u1072 \u1090 \u1080 \u1083 \u1086 , \u1072  \u1103  \u1080 \u1079  \u1075 \u1086 \u1088 \u1086 \u1076 \u1072  \u1074 \u1077 \u1088 \u1085 \u1091 \u1083 \u1089 \u1103  \u1089  \u1076 \u1077 \u1085 \u1100 \u1075 \u1072 \u1084 \u1080 . \
\'97 \uc0\u1044 \u1072  \u1074 \u1086 \u1081 \u1076 \u1080  \u1078 \u1077  \u1074  \u1076 \u1086 \u1084 . \'97 \u1061 \u1072 \u1095 \u1077  \u1087 \u1086 \u1076 \u1093 \u1074 \u1072 \u1090 \u1080 \u1083  \u1082 \u1088 \u1077 \u1089 \u1090 \u1100 \u1103 \u1085 \u1080 \u1085 \u1072 , \u1087 \u1086 \u1084 \u1086 \u1075  \u1077 \u1084 \u1091  \u1076 \u1086 \u1073 \u1088 \u1072 \u1090 \u1100 \u1089 \u1103  \u1076 \u1086  \u1083 \u1072 \u1074 \u1082 \u1080 . \u1058 \u1086 \u1090  \u1089 \u1077 \u1083 , \u1087 \u1088 \u1080 \u1089 \u1083 \u1086 \u1085 \u1080 \u1083 \u1089 \u1103  \u1089 \u1087 \u1080 \u1085 \u1086 \u1081  \u1082  \u1089 \u1090 \u1077 \u1085 \u1077 , \u1074 \u1099 \u1090 \u1103 \u1085 \u1091 \u1083  \u1085 \u1086 \u1075 \u1080  \u1080  \u1089 \u1085 \u1103 \u1083  \u1096 \u1072 \u1087 \u1082 \u1091 . \u1053 \u1072  \u1075 \u1086 \u1083 \u1086 \u1074 \u1077  \u1086 \u1073 \u1085 \u1072 \u1088 \u1091 \u1078 \u1080 \u1083 \u1072 \u1089 \u1100  \u1082 \u1086 \u1083 \u1086 \u1090 \u1072 \u1103  \u1088 \u1072 \u1085 \u1072 , \u1080 \u1079  \u1082 \u1086 \u1090 \u1086 \u1088 \u1086 \u1081  \u1089 \u1086 \u1095 \u1080 \u1083 \u1072 \u1089 \u1100  \u1082 \u1088 \u1086 \u1074 \u1100 . \
\'97 \uc0\u1054  \u1042 \u1083 \u1072 \u1076 \u1099 \u1082 \u1072  \u1084 \u1080 \u1088 \u1072 , \'97 \u1079 \u1072 \u1087 \u1088 \u1080 \u1095 \u1080 \u1090 \u1072 \u1083 \u1072  \u1056 \u1099 \u1089 \u1103 , \u1076 \u1086 \u1089 \u1090 \u1072 \u1074 \u1072 \u1103  \u1095 \u1080 \u1089 \u1090 \u1086 \u1077  \u1087 \u1086 \u1083 \u1086 \u1090 \u1077 \u1085 \u1094 \u1077 . \'97 \u1063 \u1090 \u1086  \u1078 \u1077  \u1101 \u1090 \u1086  \u1076 \u1077 \u1083 \u1072 \u1077 \u1090 \u1089 \u1103  \u1085 \u1072  \u1089 \u1074 \u1077 \u1090 \u1077 ? \u1044 \u1077 \u1090 \u1080  \u1091 \u1073 \u1080 \u1074 \u1072 \u1102 \u1090  \u1088 \u1086 \u1076 \u1080 \u1090 \u1077 \u1083 \u1077 \u1081 , \u1082 \u1072 \u1082  \u1090 \u1072 \u1082 \u1086 \u1077  \u1084 \u1086 \u1078 \u1077 \u1090  \u1073 \u1099 \u1090 \u1100 , \u1082 \u1072 \u1082  \u1058 \u1099  \u1090 \u1072 \u1082 \u1086 \u1077  \u1090 \u1077 \u1088 \u1087 \u1080 \u1096 \u1100 , \u1082 \u1072 \u1082  \u1087 \u1086 \u1079 \u1074 \u1086 \u1083 \u1103 \u1077 \u1096 \u1100 ? \
\uc0\u1054 \u1085 \u1072  \u1085 \u1072 \u1084 \u1086 \u1095 \u1080 \u1083 \u1072  \u1087 \u1086 \u1083 \u1086 \u1090 \u1077 \u1085 \u1094 \u1077 , \u1086 \u1084 \u1099 \u1083 \u1072  \u1080  \u1087 \u1077 \u1088 \u1077 \u1074 \u1103 \u1079 \u1072 \u1083 \u1072  \u1088 \u1072 \u1085 \u1091  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 \u1072 , \u1079 \u1072 \u1090 \u1077 \u1084  \u1085 \u1072 \u1083 \u1080 \u1083 \u1072  \u1074  \u1089 \u1090 \u1072 \u1082 \u1072 \u1085  \u1086 \u1089 \u1090 \u1072 \u1090 \u1082 \u1080  \u1074 \u1086 \u1076 \u1082 \u1080  \u1080  \u1087 \u1086 \u1076 \u1072 \u1083 \u1072  \u1088 \u1072 \u1085 \u1077 \u1085 \u1086 \u1084 \u1091 . \u1058 \u1086 \u1090  \u1074 \u1099 \u1087 \u1080 \u1083  \u1079 \u1072 \u1083 \u1087 \u1086 \u1084 , \u1079 \u1072 \u1082 \u1091 \u1089 \u1080 \u1083  \u1089 \u1077 \u1083 \u1077 \u1076 \u1082 \u1086 \u1081  \u1089  \u1093 \u1083 \u1077 \u1073 \u1086 \u1084 , \u1087 \u1088 \u1080 \u1082 \u1088 \u1099 \u1083  \u1075 \u1083 \u1072 \u1079 \u1072  \u1080  \u1073 \u1083 \u1072 \u1078 \u1077 \u1085 \u1085 \u1086  \u1091 \u1083 \u1099 \u1073 \u1085 \u1091 \u1083 \u1089 \u1103 .\
\'97 \uc0\u1053 \u1091  \u1080  \u1074 \u1086 \u1076 \u1082 \u1072  \u1091  \u1074 \u1072 \u1089 , \u1093 \u1086 \u1079 \u1103 \u1077 \u1074 \u1072 , \'97 \u1089 \u1082 \u1072 \u1079 \u1072 \u1083  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1089 \u1087 \u1091 \u1089 \u1090 \u1103  \u1085 \u1077 \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1084 \u1080 \u1085 \u1091 \u1090 . \'97 \u1042 \u1099 \u1087 \u1080 \u1083  \u1074 \u1089 \u1077 \u1075 \u1086  \u1085 \u1080 \u1095 \u1077 \u1075 \u1086 , \u1072  \u1073 \u1091 \u1076 \u1090 \u1086  \u1094 \u1077 \u1083 \u1091 \u1102  \u1073 \u1091 \u1090 \u1099 \u1083 \u1082 \u1091  \u1087 \u1088 \u1080 \u1085 \u1103 \u1083 . \u1048  \u1073 \u1086 \u1083 \u1100  \u1082 \u1072 \u1082  \u1088 \u1091 \u1082 \u1086 \u1081  \u1089 \u1085 \u1103 \u1083 \u1086 . \u1042 \u1099  \u1095 \u1090 \u1086 , \u1089 \u1083 \u1086 \u1074 \u1086  \u1082 \u1072 \u1082 \u1086 \u1077  \u1079 \u1085 \u1072 \u1077 \u1090 \u1077 ?\
\'97 \uc0\u1055 \u1088 \u1086 \u1089 \u1090 \u1086  \u1086 \u1090  \u1095 \u1080 \u1089 \u1090 \u1086 \u1075 \u1086  \u1089 \u1077 \u1088 \u1076 \u1094 \u1072  \u1085 \u1072 \u1083 \u1080 \u1074 \u1072 \u1083 \u1072 , \'97 \u1086 \u1090 \u1074 \u1077 \u1090 \u1080 \u1083 \u1072  \u1056 \u1099 \u1089 \u1103 .\
\'97 \uc0\u1053 \u1086  \u1082 \u1072 \u1082 \u1086 \u1081  \u1078 \u1077  \u1086 \u1085  \u1085 \u1077 \u1075 \u1086 \u1076 \u1103 \u1081 ! \'97 \u1074 \u1089 \u1082 \u1080 \u1085 \u1091 \u1083 \u1089 \u1103  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 . \'97 \u1055 \u1086 \u1076 \u1083 \u1077 \u1094 ! \u1048  \u1090 \u1072 \u1082  \u1073 \u1099 \u1083  \u1091 \u1078 \u1077  \u1087 \u1100 \u1103 \u1085 \u1099 \u1081 , \u1080  \u1090 \u1072 \u1082  \u1085 \u1080 \u1095 \u1077 \u1075 \u1086  \u1085 \u1077  \u1089 \u1086 \u1086 \u1073 \u1088 \u1072 \u1078 \u1072 \u1083 , \u1082 \u1091 \u1076 \u1072  \u1077 \u1097 \u1077 ? \u1057 \u1090 \u1072 \u1083  \u1076 \u1077 \u1085 \u1100 \u1075 \u1080  \u1090 \u1088 \u1077 \u1073 \u1086 \u1074 \u1072 \u1090 \u1100 . \u1043 \u1083 \u1072 \u1079 \u1072  \u1084 \u1091 \u1090 \u1085 \u1099 \u1077 , \u1095 \u1077 \u1083 \u1082 \u1072  \u1084 \u1086 \u1082 \u1088 \u1072 \u1103 , \u1085 \u1072  \u1085 \u1086 \u1075 \u1072 \u1093  \u1085 \u1077  \u1089 \u1090 \u1086 \u1080 \u1090 . \u1071  \u1086 \u1090 \u1082 \u1072 \u1079 \u1072 \u1083 , \u1082 \u1086 \u1085 \u1077 \u1095 \u1085 \u1086 , \u1087 \u1088 \u1086 \u1089 \u1087 \u1080 \u1089 \u1100 , \u1075 \u1086 \u1074 \u1086 \u1088 \u1102 , \u1090 \u1086 \u1075 \u1076 \u1072  \u1076 \u1072 \u1084 . \u1040  \u1086 \u1085  \u1079 \u1072 \u1084 \u1099 \u1095 \u1072 \u1083  \u1080  \u1076 \u1072 \u1074 \u1072 \u1081  \u1073 \u1080 \u1090 \u1100  \u1085 \u1072 \u1086 \u1090 \u1084 \u1072 \u1096 \u1100  \u1085 \u1072 \u1083 \u1077 \u1074 \u1086  \u1080  \u1085 \u1072 \u1087 \u1088 \u1072 \u1074 \u1086 . \u1057 \u1093 \u1074 \u1072 \u1090 \u1080 \u1083  \u1089 \u1086  \u1089 \u1090 \u1086 \u1083 \u1072  \u1085 \u1086 \u1078  \u1080  \u1087 \u1088 \u1103 \u1084 \u1086  \u1074  \u1075 \u1086 \u1083 \u1086 \u1074 \u1091  \u1091 \u1076 \u1072 \u1088 \u1080 \u1083 , \u1085 \u1072 \u1089 \u1080 \u1083 \u1091  \u1091 \u1074 \u1077 \u1088 \u1085 \u1091 \u1083 \u1089 \u1103 , \u1096 \u1072 \u1087 \u1082 \u1072  \u1089 \u1087 \u1072 \u1089 \u1083 \u1072 . \u1043 \u1076 \u1077  \u1084 \u1085 \u1077  \u1089  \u1085 \u1080 \u1084  \u1089 \u1086 \u1074 \u1083 \u1072 \u1076 \u1072 \u1090 \u1100 , \u1089 \u1080 \u1083 \u1099  \u1091 \u1078 \u1077  \u1085 \u1077  \u1090 \u1077 . \u1055 \u1086 \u1074 \u1072 \u1083 \u1080 \u1083  \u1086 \u1085  \u1084 \u1077 \u1085 \u1103  \u1085 \u1072  \u1087 \u1086 \u1083 , \u1076 \u1072 \u1074 \u1072 \u1081  \u1085 \u1086 \u1075 \u1072 \u1084 \u1080  \u1087 \u1080 \u1085 \u1072 \u1090 \u1100 . \u1055 \u1086 \u1085 \u1103 \u1083  \u1103 , \u1095 \u1090 \u1086  \u1079 \u1072 \u1073 \u1100 \u1077 \u1090  \u1076 \u1086  \u1089 \u1084 \u1077 \u1088 \u1090 \u1080 , \u1080  \u1086 \u1090 \u1076 \u1072 \u1083  \u1077 \u1084 \u1091  \u1076 \u1077 \u1085 \u1100 \u1075 \u1080 . \u1050 \u1072 \u1082  \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1086 \u1085  \u1080 \u1093  \u1087 \u1086 \u1083 \u1091 \u1095 \u1080 \u1083 , \u1089 \u1075 \u1088 \u1077 \u1073  \u1084 \u1077 \u1085 \u1103  \u1074  \u1086 \u1093 \u1072 \u1087 \u1082 \u1091  \u1080 , \u1090 \u1086 \u1095 \u1085 \u1086  \u1085 \u1077 \u1085 \u1091 \u1078 \u1085 \u1099 \u1081  \u1084 \u1091 \u1089 \u1086 \u1088 , \u1074 \u1099 \u1082 \u1080 \u1085 \u1091 \u1083  \u1080 \u1079  \u1076 \u1086 \u1084 \u1091 . \u1044 \u1072 -\u1076 \u1072 , \u1086 \u1090 \u1082 \u1088 \u1099 \u1083  \u1076 \u1074 \u1077 \u1088 \u1100  \u1080  \u1074 \u1099 \u1073 \u1088 \u1086 \u1089 \u1080 \u1083  \u1085 \u1072  \u1089 \u1085 \u1077 \u1075 . \u1048 \u1079  \u1084 \u1086 \u1077 \u1075 \u1086  \u1089 \u1086 \u1073 \u1089 \u1090 \u1074 \u1077 \u1085 \u1085 \u1086 \u1075 \u1086  \u1076 \u1086 \u1084 \u1072 , \u1084 \u1086 \u1081  \u1078 \u1077  \u1089 \u1099 \u1085  \u1084 \u1077 \u1085 \u1103  \u1080  \u1074 \u1099 \u1082 \u1080 \u1085 \u1091 \u1083 . \u1048 \u1076 \u1090 \u1080  \u1084 \u1085 \u1077  \u1085 \u1077 \u1082 \u1091 \u1076 \u1072 , \u1074 \u1086 \u1090 , \u1087 \u1088 \u1080 \u1096 \u1077 \u1083  \u1082  \u1074 \u1072 \u1084 \'85 \'97 \u1042 \u1086 \u1081 \u1090 \u1077 \u1082  \u1079 \u1072 \u1087 \u1083 \u1072 \u1082 \u1072 \u1083 . \u1057 \u1083 \u1077 \u1079 \u1099  \u1082 \u1072 \u1090 \u1080 \u1083 \u1080 \u1089 \u1100  \u1087 \u1086  \u1084 \u1086 \u1088 \u1097 \u1080 \u1085 \u1080 \u1089 \u1090 \u1099 \u1084  \u1097 \u1077 \u1082 \u1072 \u1084  \u1080  \u1079 \u1072 \u1089 \u1090 \u1088 \u1077 \u1074 \u1072 \u1083 \u1080  \u1074  \u1089 \u1077 \u1076 \u1086 \u1081  \u1097 \u1077 \u1090 \u1080 \u1085 \u1077 . \
\'97 \uc0\u1053 \u1080 \u1095 \u1077 \u1075 \u1086 , \u1085 \u1080 \u1095 \u1077 \u1075 \u1086 , \'97 \u1087 \u1099 \u1090 \u1072 \u1083 \u1072 \u1089 \u1100  \u1091 \u1090 \u1077 \u1096 \u1080 \u1090 \u1100  \u1077 \u1075 \u1086  \u1056 \u1099 \u1089 \u1103 . \'97 \u1058 \u1074 \u1086 \u1081  \u1089 \u1099 \u1085  \u1087 \u1088 \u1086 \u1089 \u1087 \u1080 \u1090 \u1089 \u1103 , \u1086 \u1090 \u1086 \u1081 \u1076 \u1077 \u1090  \u1080  \u1087 \u1086 \u1078 \u1072 \u1083 \u1077 \u1077 \u1090  \u1086  \u1089 \u1083 \u1091 \u1095 \u1080 \u1074 \u1096 \u1077 \u1084 \u1089 \u1103 .\
\uc0\u1053 \u1086  \u1089 \u1099 \u1085  \u1085 \u1077  \u1087 \u1086 \u1078 \u1072 \u1083 \u1077 \u1083 . \u1053 \u1072  \u1089 \u1083 \u1077 \u1076 \u1091 \u1102 \u1097 \u1080 \u1081  \u1076 \u1077 \u1085 \u1100  \u1061 \u1072 \u1095 \u1077  \u1086 \u1090 \u1087 \u1088 \u1072 \u1074 \u1080 \u1083 \u1089 \u1103  \u1074  \u1076 \u1077 \u1088 \u1077 \u1074 \u1077 \u1085 \u1100 \u1082 \u1091  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 \u1072  \u1091 \u1079 \u1085 \u1072 \u1090 \u1100 , \u1095 \u1090 \u1086  \u1080  \u1082 \u1072 \u1082 . \u1045 \u1075 \u1086  \u1089 \u1099 \u1085 \u1072  \u1086 \u1085  \u1086 \u1090 \u1099 \u1089 \u1082 \u1072 \u1083  \u1074  \u1082 \u1086 \u1088 \u1095 \u1084 \u1077 . \u1058 \u1086 \u1090  \u1087 \u1080 \u1083  \u1080  \u1093 \u1074 \u1072 \u1083 \u1080 \u1083 \u1089 \u1103  \u1074 \u1095 \u1077 \u1088 \u1072 \u1096 \u1085 \u1080 \u1084 .\
\'97 \uc0\u1044 \u1072 \u1074 \u1085 \u1086  \u1087 \u1086 \u1088 \u1072  \u1073 \u1099 \u1083 \u1086  \u1080 \u1079 \u1073 \u1072 \u1074 \u1080 \u1090 \u1100 \u1089 \u1103  \u1086 \u1090  \u1089 \u1090 \u1072 \u1088 \u1086 \u1081  \u1088 \u1091 \u1093 \u1083 \u1103 \u1076 \u1080 , \'97 \u1089  \u1082 \u1088 \u1080 \u1074 \u1086 \u1081  \u1091 \u1089 \u1084 \u1077 \u1096 \u1082 \u1086 \u1081  \u1087 \u1086 \u1074 \u1090 \u1086 \u1088 \u1103 \u1083  \u1086 \u1085 . \'97 \u1058 \u1077 \u1087 \u1077 \u1088 \u1100  \u1103  \u1074  \u1076 \u1086 \u1084 \u1077  \u1093 \u1086 \u1079 \u1103 \u1080 \u1085 .\
