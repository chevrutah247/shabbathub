\uc0\u1042  \u1090 \u1086  \u1091 \u1090 \u1088 \u1086  \u1052 \u1072 \u1075 \u1080 \u1076  \u1089 \u1072 \u1084  \u1095 \u1080 \u1090 \u1072 \u1083  \'ab\u1057 \u1074 \u1080 \u1090 \u1086 \u1082  \u1069 \u1089 \u1090 \u1077 \u1088 \'bb. \u1063 \u1080 \u1090 \u1072 \u1083  \u1085 \u1077  \u1075 \u1088 \u1086 \u1084 \u1095 \u1077  \u1080  \u1085 \u1077  \u1090 \u1080 \u1096 \u1077 , \u1085 \u1077  \u1083 \u1091 \u1095 \u1096 \u1077  \u1080  \u1085 \u1077  \u1093 \u1091 \u1078 \u1077  \u1076 \u1088 \u1091 \u1075 \u1080 \u1093  \u1095 \u1090 \u1077 \u1094 \u1086 \u1074 , \u1085 \u1086  \u1084 \u1080 \u1085 \u1091 \u1090  \u1095 \u1077 \u1088 \u1077 \u1079  \u1076 \u1077 \u1089 \u1103 \u1090 \u1100  \u1087 \u1086 \u1089 \u1083 \u1077  \u1085 \u1072 \u1095 \u1072 \u1083 \u1072  \u1061 \u1072 \u1095 \u1077  \u1087 \u1086 \u1087 \u1083 \u1099 \u1083  \u1087 \u1086  \u1074 \u1086 \u1083 \u1085 \u1077  \u1085 \u1077 \u1086 \u1087 \u1080 \u1089 \u1091 \u1077 \u1084 \u1086 \u1075 \u1086  \u1073 \u1083 \u1072 \u1078 \u1077 \u1085 \u1089 \u1090 \u1074 \u1072 . \u1054 \u1085  \u1089  \u1086 \u1089 \u1086 \u1073 \u1086 \u1081  \u1103 \u1089 \u1085 \u1086 \u1089 \u1090 \u1100 \u1102  \u1086 \u1089 \u1086 \u1079 \u1085 \u1072 \u1074 \u1072 \u1083 , \u1095 \u1090 \u1086  \u1085 \u1072 \u1093 \u1086 \u1076 \u1080 \u1090 \u1089 \u1103  \u1090 \u1072 \u1084 , \u1075 \u1076 \u1077  \u1076 \u1086 \u1083 \u1078 \u1077 \u1085  \u1085 \u1072 \u1093 \u1086 \u1076 \u1080 \u1090 \u1100 \u1089 \u1103 , \u1080  \u1076 \u1077 \u1083 \u1072 \u1077 \u1090  \u1089 \u1077 \u1081 \u1095 \u1072 \u1089  \u1090 \u1086 , \u1095 \u1090 \u1086  \u1076 \u1086 \u1083 \u1078 \u1077 \u1085  \u1076 \u1077 \u1083 \u1072 \u1090 \u1100 , \u1080  \u1095 \u1090 \u1086  \u1076 \u1083 \u1103  \u1077 \u1075 \u1086  \u1076 \u1091 \u1096 \u1080  \u1085 \u1077 \u1090  \u1073 \u1086 \u1083 \u1100 \u1096 \u1077 \u1081  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1080  \u1080  \u1091 \u1076 \u1086 \u1074 \u1086 \u1083 \u1100 \