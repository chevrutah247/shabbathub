\'97 \uc0\u1044 \u1079 \u1077 \u1085 \u1082 \u1091 \u1102  \u1073 \u1072 \u1088 \u1076 \u1079 \u1086 , \'97 \u1088 \u1072 \u1089 \u1089 \u1099 \u1087 \u1072 \u1083 \u1089 \u1103  \u1074  \u1073 \u1083 \u1072 \u1075 \u1086 \u1076 \u1072 \u1088 \u1085 \u1086 \u1089 \u1090 \u1103 \u1093  \u1042 \u1086 \u1081 \u1090 \u1077 \u1082 . \'97 \u1071  \u1074  \u1050 \u1086 \u1079 \u1077 \u1085 \u1080 \u1094 \u1077  \u1077 \u1076 \u1091  \u1089  \u1090 \u1086 \u1074 \u1072 \u1088 \u1086 \u1084 , \u1085 \u1072  \u1086 \u1073 \u1088 \u1072 \u1090 \u1085 \u1086 \u1084  \u1087 \u1091 \u1090 \u1080  \u1079 \u1072 \u1074 \u1077 \u1079 \u1091  \u1090 \u1077 \u1073 \u1077  \u1087 \u1072 \u1088 \u1091  \u1076 \u1077 \u1089 \u1103 \u1090 \u1082 \u1086 \u1074  \u1088 \u1077 \u1087 \u1091 \u1096 \u1077 \u1082 . \u1061 \u1074 \u1072 \u1090 \u1080 \u1090 ? \
\'97 \uc0\u1061 \u1074 \u1072 \u1090 \u1080 \u1090 , \u1093 \u1074 \u1072 \u1090 \u1080 \u1090 ! \u1040  \u1076 \u1086  \u1075 \u1086 \u1088 \u1086 \u1076 \u1072  \u1085 \u1077  \u1087 \u1086 \u1076 \u1074 \u1077 \u1079 \u1077 \u1096 \u1100 ?\
