\uc0\u1045 \u1083 \u1072  \u1086 \u1085 \u1072  \u1089 \u1086 \u1074 \u1089 \u1077 \u1084  \u1085 \u1077 \u1084 \u1085 \u1086 \u1075 \u1086 , \u1082 \u1072 \u1082  \u1087 \u1090 \u1080 \u1095 \u1082 \u1072 , \u1080  \u1089 \u1072 \u1084 \u1091 \u1102  \u1087 \u1088 \u1086 \u1089 \u1090 \u1091 \u1102  \u1077 \u1076 \u1091 . \u1053 \u1086 \u1089 \u1080 \u1083 \u1072  \u1086 \u1076 \u1085 \u1091  \u1080  \u1090 \u1091  \u1078 \u1077  \u1086 \u1076 \u1077 \u1078 \u1076 \u1091 , \u1074 \u1089 \u1077 \u1075 \u1076 \u1072  \u1095 \u1080 \u1089 \u1090 \u1091 \u1102 , \u1085 \u1072 \u1082 \u1088 \u1072 \u1093 \u1084 \u1072 \u1083 \u1077 \u1085 \u1085 \u1091 \u1102  \u1076 \u1086  \u1093 \u1088 \u1091 \u1089 \u1090 \u1082 \u1086 \u1081  \u1089 \u1080 \u1085 \u1077 \u1074 \u1099  \u1080  \u1072 \u1082 \u1082 \u1091 \u1088 \u1072 \u1090 \u1085 \u1086  \u1074 \u1099 \u1075 \u1083 \u1072 \u1078 \u1077 \u1085 \u1085 \u1091 \u1102 . \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1089 \u1090 \u1086  \u1088 \u1072 \u1079  \u1087 \u1088 \u1077 \u1076 \u1083 \u1072 \u1075 \u1072 \u1083  \u1077 \u1081  \u1087 \u1086 \u1096 \u1080 \u1090 \u1100  \u1085 \u1086 \u1074 \u1099 \u1077  \u1087 \u1083 \u1072 \u1090 \u1100 \u1103 , \u1085 \u1086  \u1041 \u1077 \u1081 \u1083 \u1077  \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1086 \u1090 \u1084 \u1072 \u1093 \u1080 \u1074 \u1072 \u1083 \u1072 \u1089 \u1100 .\
\'96\uc0\u1047 \u1072 \u1095 \u1077 \u1084 ? \u1045 \u1089 \u1083 \u1080  \u1091  \u1090 \u1077 \u1073 \u1103  \u1079 \u1072 \u1074 \u1077 \u1083 \u1080 \u1089 \u1100  \u1083 \u1080 \u1096 \u1085 \u1080 \u1077  \u1076 \u1077 \u1085 \u1100 \u1075 \u1080 , \u1076 \u1072 \u1074 \u1072 \u1081  \u1087 \u1086 \u1084 \u1086 \u1078 \u1077 \u1084  \u1073 \u1077 \u1076 \u1085 \u1099 \u1084 . \u1042 \u1086 \u1082 \u1088 \u1091 \u1075  \u1085 \u1072 \u1089  \u1089 \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1075 \u1086 \u1088 \u1103  \u1086 \u1090  \u1085 \u1080 \u1097 \u1077 \u1090 \u1099 , \u1072  \u1090 \u1099  \u1087 \u1088 \u1077 \u1076 \u1083 \u1072 \u1075 \u1072 \u1077 \u1096 \u1100  \u1084 \u1085 \u1077  \u1086 \u1073 \u1085 \u1086 \u1074 \u1082 \u1080 ! \u1048 \u1083 \u1080  \u1103  \u1085 \u1077  \u1083 \u1102 \u1073 \u1072  \u1090 \u1077 \u1073 \u1077  \u1074  \u1089 \u1090 \u1072 \u1088 \u1099 \u1093  \u1087 \u1083 \u1072 \u1090 \u1100 \u1103 \u1093 ?\
\'96\uc0\u1051 \u1102 \u1073 \u1072 , \u1083 \u1102 \u1073 \u1072 , \'96 \u1086 \u1090 \u1074 \u1077 \u1095 \u1072 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 , \u1082 \u1088 \u1077 \u1087 \u1082 \u1086  \u1086 \u1073 \u1085 \u1080 \u1084 \u1072 \u1103  \u1078 \u1077 \u1085 \u1091 .\
 \uc0\u1054 \u1085  \u1073 \u1099  \u1089  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1100 \u1102  \u1087 \u1086 \u1076 \u1072 \u1088 \u1080 \u1083  \u1041 \u1077 \u1081 \u1083 \u1077  \u1079 \u1086 \u1083 \u1086 \u1090 \u1099 \u1077  \u1089 \u1077 \u1088 \u1077 \u1078 \u1082 \u1080  \u1089  \u1078 \u1077 \u1084 \u1095 \u1091 \u1075 \u1086 \u1084 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1077  \u1073 \u1099  \u1090 \u1072 \u1082  \u1082 \u1088 \u1072 \u1089 \u1080 \u1074 \u1086  \u1089 \u1084 \u1086 \u1090 \u1088 \u1077 \u1083 \u1080 \u1089 \u1100  \u1074  \u1077 \u1077  \u1084 \u1072 \u1083 \u1077 \u1085 \u1100 \u1082 \u1080 \u1093  \u1091 \u1096 \u1082 \u1072 \u1093 , \u1080 \u1083 \u1080  \u1089 \u1077 \u1088 \u1077 \u1073 \u1088 \u1103 \u1085 \u1099 \u1077  \u1082 \u1086 \u1083 \u1077 \u1095 \u1082 \u1080  \u1089  \u1079 \u1077 \u1083 \u1077 \u1085 \u1099 \u1084  \u1084 \u1072 \u1083 \u1072 \u1093 \u1080 \u1090 \u1086 \u1084  \u1076 \u1083 \u1103  \u1077 \u1077  \u1090 \u1086 \u1085 \u1077 \u1085 \u1100 \u1082 \u1080 \u1093  \u1087 \u1072 \u1083 \u1100 \u1095 \u1080 \u1082 \u1086 \u1074 , \u1085 \u1086  \u1090 \u1072  \u1076 \u1072 \u1078 \u1077  \u1089 \u1083 \u1099 \u1096 \u1072 \u1090 \u1100  \u1086 \u1073  \u1101 \u1090 \u1086 \u1084  \u1085 \u1077  \u1093 \u1086 \u1090 \u1077 \u1083 \u1072 . \
\'96 \uc0\u1071  \u1085 \u1077  \u1074 \u1086 \u1088 \u1086 \u1085 \u1072 , \u1095 \u1090 \u1086 \u1073 \u1099  \u1090 \u1072 \u1097 \u1080 \u1090 \u1100  \u1074  \u1076 \u1086 \u1084  \u1073 \u1083 \u1077 \u1089 \u1090 \u1103 \u1097 \u1080 \u1077  \u1094 \u1072 \u1094 \u1082 \u1080 , \'96 \u1086 \u1090 \u1074 \u1077 \u1095 \u1072 \u1083 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077  \u1085 \u1072  \u1074 \u1089 \u1077  \u1077 \u1075 \u1086  \u1087 \u1088 \u1077 \u1076 \u1083 \u1086 \u1078 \u1077 \u1085 \u1080 \u1103 . \'96 \u1061 \u1086 \u1095 \u1077 \u1096 \u1100  \u1089 \u1076 \u1077 \u1083 \u1072 \u1090 \u1100  \u1084 \u1085 \u1077  \u1087 \u1088 \u1080 \u1103 \u1090 \u1085 \u1086 \u1077 , \u1082 \u1091 \u1087 \u1080  \u1085 \u1072  \u1101 \u1090 \u1080  \u1076 \u1077 \u1085 \u1100 \u1075 \u1080  \u1085 \u1086 \u1074 \u1099 \u1077  \u1089 \u1072 \u1087 \u1086 \u1078 \u1082 \u1080  \u1076 \u1083 \u1103  \u1076 \u1077 \u1090 \u1077 \u1081  \u1073 \u1077 \u1076 \u1085 \u1103 \u1082 \u1086 \u1074 .\
\uc0\u1040 \u1085 \u1075 \u1077 \u1083 , \u1087 \u1088 \u1086 \u1089 \u1090 \u1086  \u1072 \u1085 \u1075 \u1077 \u1083 , \u1087 \u1086 -\u1076 \u1088 \u1091 \u1075 \u1086 \u1084 \u1091  \u1085 \u1077  \u1089 \u1082 \u1072 \u1078 \u1077 \u1096 \u1100 !\
\uc0\u1053 \u1086  \u1074 \u1089 \u1077 -\u1090 \u1072 \u1082 \u1080  \u1073 \u1099 \u1083 \u1072  \u1086 \u1076 \u1085 \u1072  \u1074 \u1077 \u1097 \u1100  \u1074  \u1089 \u1082 \u1088 \u1086 \u1084 \u1085 \u1086 \u1084  \u1075 \u1072 \u1088 \u1076 \u1077 \u1088 \u1086 \u1073 \u1077  \u1041 \u1077 \u1081 \u1083 \u1077 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1091 \u1102  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1073 \u1086 \u1083 \u1100 \u1096 \u1077  \u1085 \u1077  \u1084 \u1086 \u1075  \u1087 \u1077 \u1088 \u1077 \u1085 \u1086 \u1089 \u1080 \u1090 \u1100 . \u1047 \u1080 \u1084 \u1099  \u1074  \u1050 \u1088 \u1072 \u1089 \u1085 \u1099 \u1093  \u1054 \u1082 \u1085 \u1072 \u1093  \u1086 \u1073 \u1099 \u1095 \u1085 \u1086  \u1084 \u1103 \u1075 \u1082 \u1080 \u1077 , \u1089 \u1085 \u1077 \u1075  \u1083 \u1077 \u1078 \u1080 \u1090  \u1085 \u1077 \u1076 \u1086 \u1083 \u1075 \u1086 , \u1084 \u1077 \u1089 \u1103 \u1094 \u1072  \u1087 \u1086 \u1083 \u1090 \u1086 \u1088 \u1072  \u1086 \u1090  \u1089 \u1080 \u1083 \u1099  \u1076 \u1074 \u1072 . \u1053 \u1086  \u1089 \u1083 \u1091 \u1095 \u1072 \u1102 \u1090 \u1089 \u1103  \u1080  \u1089 \u1080 \u1083 \u1100 \u1085 \u1099 \u1077  \u1084 \u1086 \u1088 \u1086 \u1079 \u1099 . \u1057 \u1088 \u1072 \u1079 \u1091  \u1087 \u1086 \u1089 \u1083 \u1077  \u1089 \u1074 \u1072 \u1076 \u1100 \u1073 \u1099  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1087 \u1086 \u1076 \u1072 \u1088 \u1080 \u1083  \u1078 \u1077 \u1085 \u1077  \u1096 \u1091 \u1073 \u1082 \u1091  \u1080 \u1079  \u1096 \u1082 \u1091 \u1088  \u1089 \u1091 \u1089 \u1083 \u1080 \u1082 \u1086 \u1074 . \u1043 \u1083 \u1072 \u1076 \u1082 \u1080 \u1081  \u1089 \u1074 \u1077 \u1090 \u1083 \u1086 -\u1082 \u1086 \u1088 \u1080 \u1095 \u1085 \u1077 \u1074 \u1099 \u1081  \u1084 \u1077 \u1093  \u1073 \u1083 \u1077 \u1089 \u1090 \u1077 \u1083  \u1080  \u1087 \u1077 \u1088 \u1077 \u1083 \u1080 \u1074 \u1072 \u1083 \u1089 \u1103 , \u1074 \u1099 \u1079 \u1099 \u1074 \u1072 \u1103  \u1078 \u1077 \u1083 \u1072 \u1085 \u1080 \u1077  \u1087 \u1088 \u1086 \u1074 \u1077 \u1089 \u1090 \u1080  \u1087 \u1086  \u1085 \u1077 \u1084 \u1091  \u1088 \u1091 \u1082 \u1086 \u1081 . \u1041 \u1077 \u1081 \u1083 \u1077  \u1087 \u1088 \u1080 \u1096 \u1083 \u1072  \u1074  \u1074 \u1086 \u1089 \u1090 \u1086 \u1088 \u1075 , \u1074  \u1077 \u1077  \u1078 \u1080 \u1079 \u1085 \u1080  \u1101 \u1090 \u1086  \u1073 \u1099 \u1083 \u1072  \u1087 \u1077 \u1088 \u1074 \u1072 \u1103  \u1082 \u1088 \u1072 \u1089 \u1080 \u1074 \u1072 \u1103  \u1080  \u1085 \u1077 \u1076 \u1077 \u1096 \u1077 \u1074 \u1072 \u1103  \u1074 \u1077 \u1097 \u1100 .\
\uc0\u1055 \u1088 \u1086 \u1096 \u1083 \u1080  \u1075 \u1086 \u1076 \u1099 , \u1088 \u1086 \u1076 \u1080 \u1083 \u1080 \u1089 \u1100  \u1084 \u1085 \u1086 \u1075 \u1080 \u1077  \u1076 \u1077 \u1090 \u1080 , \u1041 \u1077 \u1081 \u1083 \u1077  \u1087 \u1086 \u1075 \u1088 \u1091 \u1079 \u1085 \u1077 \u1083 \u1072  \u1080  \u1091 \u1078 \u1077  \u1089  \u1090 \u1088 \u1091 \u1076 \u1086 \u1084  \u1087 \u1086 \u1084 \u1077 \u1097 \u1072 \u1083 \u1072 \u1089 \u1100  \u1074  \u1089 \u1090 \u1072 \u1088 \u1086 \u1081  \u1096 \u1091 \u1073 \u1082 \u1077 . \u1044 \u1072  \u1080  \u1084 \u1077 \u1093  \u1079 \u1072  \u1101 \u1090 \u1080  \u1075 \u1086 \u1076 \u1099  \u1087 \u1086 \u1090 \u1091 \u1089 \u1082 \u1085 \u1077 \u1083 , \u1089 \u1074 \u1072 \u1083 \u1103 \u1083 \u1089 \u1103  \u1080  \u1075 \u1083 \u1072 \u1076 \u1080 \u1090 \u1100  \u1077 \u1075 \u1086  \u1089 \u1086 \u1074 \u1089 \u1077 \u1084  \u1085 \u1077  \u1093 \u1086 \u1090 \u1077 \u1083 \u1086 \u1089 \u1100 . \u1048 , \u1090 \u1077 \u1084  \u1085 \u1077  \u1084 \u1077 \u1085 \u1077 \u1077 , \u1041 \u1077 \u1081 \u1083 \u1077  \u1085 \u1080  \u1079 \u1072  \u1095 \u1090 \u1086  \u1085 \u1077  \u1089 \u1086 \u1075 \u1083 \u1072 \u1096 \u1072 \u1083 \u1072 \u1089 \u1100  \u1085 \u1072  \u1087 \u1086 \u1082 \u1091 \u1087 \u1082 \u1091  \u1085 \u1086 \u1074 \u1086 \u1081  \u1096 \u1091 \u1073 \u1099 .\
\
\'96 \uc0\u1059  \u1085 \u1072 \u1089  \u1085 \u1077 \u1090  \u1090 \u1072 \u1082 \u1080 \u1093  \u1076 \u1077 \u1085 \u1077 \u1075 , \'96 \u1087 \u1086 \u1074 \u1090 \u1086 \u1088 \u1103 \u1083 \u1072  \u1086 \u1085 \u1072 . \'96 \u1040  \u1084 \u1085 \u1077  \u1080  \u1074  \u1089 \u1090 \u1072 \u1088 \u1086 \u1081  \u1093 \u1086 \u1088 \u1086 \u1096 \u1086 . \u1071  \u1090 \u1072 \u1082  \u1082  \u1085 \u1077 \u1081  \u1087 \u1088 \u1080 \u1074 \u1099 \u1082 \u1083 \u1072 , \u1095 \u1090 \u1086  \u1080  \u1087 \u1088 \u1077 \u1076 \u1089 \u1090 \u1072 \u1074 \u1080 \u1090 \u1100  \u1089 \u1077 \u1073 \u1103  \u1085 \u1077  \u1084 \u1086 \u1075 \u1091  \u1074  \u1095 \u1077 \u1084 -\u1085 \u1080 \u1073 \u1091 \u1076 \u1100  \u1076 \u1088 \u1091 \u1075 \u1086 \u1084 . \u1044 \u1072 \u1074 \u1072 \u1081  \u1083 \u1091 \u1095 \u1096 \u1077  \u1082 \u1091 \u1087 \u1080 \u1084  \u1090 \u1077 \u1073 \u1077  \u1079 \u1086 \u1083 \u1086 \u1090 \u1099 \u1077  \u1095 \u1072 \u1089 \u1099  \u1085 \u1072  \u1094 \u1077 \u1087 \u1086 \u1095 \u1082 \u1077 . \u1058 \u1099  \u1082 \u1091 \u1087 \u1077 \u1094 , \u1091  \u1090 \u1077 \u1073 \u1103  \u1087 \u1086 \u1089 \u1090 \u1086 \u1103 \u1085 \u1085 \u1099 \u1077  \u1074 \u1089 \u1090 \u1088 \u1077 \u1095 \u1080  \u1089  \u1087 \u1086 \u1082 \u1091 \u1087 \u1072 \u1090 \u1077 \u1083 \u1103 \u1084 \u1080  \u1080  \u1087 \u1088 \u1086 \u1076 \u1072 \u1074 \u1094 \u1072 \u1084 \u1080 , \u1090 \u1077 \u1073 \u1077  \u1085 \u1077 \u1086 \u1073 \u1093 \u1086 \u1076 \u1080 \u1084 \u1086  \u1079 \u1085 \u1072 \u1090 \u1100  \u1090 \u1086 \u1095 \u1085 \u1086 \u1077  \u1074 \u1088 \u1077 \u1084 \u1103 . \u1053 \u1091 , \u1080  \u1089 \u1086 \u1083 \u1080 \u1076 \u1085 \u1086 \u1089 \u1090 \u1080  \u1101 \u1090 \u1080  \u1095 \u1072 \u1089 \u1099  \u1080 \u1079 \u1088 \u1103 \u1076 \u1085 \u1086  \u1087 \u1088 \u1080 \u1073 \u1072 \u1074 \u1083 \u1103 \u1102 \u1090 , \u1072  \u1089 \u1086 \u1083 \u1080 \u1076 \u1085 \u1086 \u1089 \u1090 \u1100  \u1074  \u1082 \u1091 \u1087 \u1077 \u1095 \u1077 \u1089 \u1082 \u1086 \u1084  \u1079 \u1072 \u1085 \u1103 \u1090 \u1080 \u1080  \u1076 \u1077 \u1083 \u1086  \u1087 \u1077 \u1088 \u1074 \u1086 \u1089 \u1090 \u1077 \u1087 \u1077 \u1085 \u1085 \u1086 \u1077 . \
 \uc0\u1053 \u1086  \u1090 \u1091 \u1090  \u1091 \u1078 \u1077  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1084 \u1072 \u1093 \u1072 \u1083  \u1088 \u1091 \u1082 \u1072 \u1084 \u1080 .\
\'96 \uc0\u1057 \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1083 \u1077 \u1090  \u1087 \u1088 \u1086 \u1078 \u1080 \u1083  \u1073 \u1077 \u1079  \u1095 \u1072 \u1089 \u1086 \u1074 , \u1080  \u1076 \u1072 \u1083 \u1100 \u1096 \u1077  \u1074 \u1087 \u1086 \u1083 \u1085 \u1077  \u1091 \u1087 \u1088 \u1072 \u1074 \u1083 \u1102 \u1089 \u1100 .\
 \uc0\u1050 \u1072 \u1082 -\u1090 \u1086  \u1088 \u1072 \u1079  \u1084 \u1077 \u1089 \u1103 \u1094  \u1090 \u1077 \u1074 \u1077 \u1090  ( \u1103 \u1085 \u1074 \u1072 \u1088 \u1100 -\u1092 \u1077 \u1074 \u1088 \u1072 \u1083 \u1100 ) \u1074 \u1099 \u1076 \u1072 \u1083 \u1089 \u1103  \u1084 \u1086 \u1088 \u1086 \u1079 \u1085 \u1099 \u1084  \u1080  \u1074 \u1100 \u1102 \u1078 \u1085 \u1099 \u1084 . \u1042 \u1077 \u1088 \u1085 \u1091 \u1074 \u1096 \u1080 \u1089 \u1100  \u1074 \u1077 \u1095 \u1077 \u1088 \u1086 \u1084  \u1076 \u1086 \u1084 \u1086 \u1081  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1086 \u1090 \u1086 \u1075 \u1088 \u1077 \u1074 \u1072 \u1083 \u1089 \u1103  \u1089 \u1090 \u1072 \u1082 \u1072 \u1085 \u1086 \u1084  \u1075 \u1086 \u1088 \u1103 \u1095 \u1077 \u1075 \u1086  \u1095 \u1072 \u1103  \u1089  \u1082 \u1091 \u1089 \u1086 \u1095 \u1082 \u1086 \u1084  \u1084 \u1077 \u1076 \u1086 \u1074 \u1086 \u1075 \u1086  \u1087 \u1088 \u1103 \u1085 \u1080 \u1082 \u1072 . \u1041 \u1077 \u1081 \u1083 \u1077  \u1089 \u1086 \u1073 \u1080 \u1088 \u1072 \u1083 \u1072  \u1091 \u1078 \u1080 \u1085 , \u1085 \u1072 \u1087 \u1086 \u1083 \u1085 \u1103 \u1103  \u1076 \u1086 \u1084  \u1074 \u1086 \u1089 \u1093 \u1080 \u1090 \u1080 \u1090 \u1077 \u1083 \u1100 \u1085 \u1099 \u1084 \u1080  \u1072 \u1088 \u1086 \u1084 \u1072 \u1090 \u1072 \u1084 \u1080 . \u1043 \u1083 \u1103 \u1076 \u1103  \u1085 \u1072  \u1078 \u1077 \u1085 \u1091 , \u1083 \u1086 \u1074 \u1082 \u1086  \u1089 \u1085 \u1091 \u1102 \u1097 \u1091 \u1102  \u1091  \u1087 \u1083 \u1080 \u1090 \u1099 , \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1074 \u1076 \u1088 \u1091 \u1075  \u1089 \u1086 \u1086 \u1073 \u1088 \u1072 \u1079 \u1080 \u1083 , \u1082 \u1072 \u1082  \u1085 \u1091 \u1078 \u1085 \u1086  \u1087 \u1086 \u1089 \u1090 \u1091 \u1087 \u1080 \u1090 \u1100 . \
\uc0\u1050 \u1072 \u1078 \u1076 \u1099 \u1081  \u1075 \u1086 \u1076  \u1074  \u1076 \u1077 \u1085 \u1100  \u1087 \u1077 \u1088 \u1077 \u1076  \u1055 \u1091 \u1088 \u1080 \u1084 \u1086 \u1084  \u1086 \u1073 \u1097 \u1080 \u1085 \u1072  \u1091 \u1089 \u1090 \u1088 \u1072 \u1080 \u1074 \u1072 \u1083 \u1072  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1095 \u1085 \u1091 \u1102  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1102 . \u1042 \u1089 \u1077  \u1078 \u1077 \u1083 \u1072 \u1102 \u1097 \u1080 \u1077  \u1087 \u1088 \u1080 \u1086 \u1073 \u1088 \u1077 \u1090 \u1072 \u1083 \u1080  \u1073 \u1080 \u1083 \u1077 \u1090 \u1099 , \u1072  \u1085 \u1072  \u1074 \u1099 \u1088 \u1091 \u1095 \u1077 \u1085 \u1085 \u1099 \u1077  \u1089 \u1088 \u1077 \u1076 \u1089 \u1090 \u1074 \u1072  \u1087 \u1086 \u1082 \u1091 \u1087 \u1072 \u1083 \u1080  \u1087 \u1086 \u1076 \u1072 \u1088 \u1082 \u1080 , \u1074  \u1086 \u1089 \u1085 \u1086 \u1074 \u1085 \u1086 \u1084  \u1089 \u1098 \u1077 \u1089 \u1090 \u1085 \u1086 \u1077 . \u1041 \u1077 \u1076 \u1085 \u1103 \u1082 \u1080  \u1087 \u1086 \u1083 \u1091 \u1095 \u1072 \u1083 \u1080  \u1073 \u1080 \u1083 \u1077 \u1090 \u1099  \u1073 \u1077 \u1089 \u1087 \u1083 \u1072 \u1090 \u1085 \u1086 , \u1080  \u1082 \u1072 \u1082 -\u1090 \u1086  \u1090 \u1072 \u1082  \u1074 \u1099 \u1093 \u1086 \u1076 \u1080 \u1083 \u1086 , \u1095 \u1090 \u1086  \u1086 \u1085 \u1080  \u1074 \u1089 \u1077 \u1075 \u1076 \u1072  \u1074 \u1099 \u1080 \u1075 \u1088 \u1099 \u1074 \u1072 \u1083 \u1080  \u1080  \u1086 \u1082 \u1072 \u1079 \u1099 \u1074 \u1072 \u1083 \u1080 \u1089 \u1100  \u1085 \u1072  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1082  \u1089  \u1087 \u1086 \u1083 \u1085 \u1099 \u1084 \u1080  \u1082 \u1086 \u1088 \u1079 \u1080 \u1085 \u1082 \u1072 \u1084 \u1080  \u1077 \u1076 \u1099 . \u1042 \u1077 \u1076 \u1072 \u1083 \u1080  \u1101 \u1090 \u1080 \u1084  \u1088 \u1072 \u1074 \u1074 \u1080 \u1085  \u1080  \u1075 \u1083 \u1072 \u1074 \u1072  \u1089 \u1086 \u1074 \u1077 \u1090 \u1072  \u1086 \u1073 \u1097 \u1080 \u1085 \u1099 , \u1080  \u1074 \u1089 \u1077 \u1084  \u1073 \u1099 \u1083 \u1086  \u1087 \u1086 \u1085 \u1103 \u1090 \u1085 \u1086 , \u1095 \u1090 \u1086  \u1088 \u1077 \u1095 \u1100  \u1080 \u1076 \u1077 \u1090  \u1079 \u1072 \u1084 \u1072 \u1089 \u1082 \u1080 \u1088 \u1086 \u1074 \u1072 \u1085 \u1085 \u1086 \u1081  \u1073 \u1083 \u1072 \u1075 \u1086 \u1090 \u1074 \u1086 \u1088 \u1080 \u1090 \u1077 \u1083 \u1100 \u1085 \u1086 \u1089 \u1090 \u1080 . \
\uc0\u1053 \u1072  \u1089 \u1083 \u1077 \u1076 \u1091 \u1102 \u1097 \u1080 \u1081  \u1076 \u1077 \u1085 \u1100  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1086 \u1090 \u1087 \u1088 \u1072 \u1074 \u1080 \u1083 \u1089 \u1103  \u1082  \u1088 \u1072 \u1074 \u1074 \u1080 \u1085 \u1091 .\
\'96 \uc0\u1071  \u1075 \u1086 \u1090 \u1086 \u1074  \u1089 \u1076 \u1077 \u1083 \u1072 \u1090 \u1100  \u1089 \u1086 \u1083 \u1080 \u1076 \u1085 \u1099 \u1081 , \u1085 \u1077 \u1090 , \u1086 \u1095 \u1077 \u1085 \u1100  \u1089 \u1086 \u1083 \u1080 \u1076 \u1085 \u1099 \u1081  \u1074 \u1079 \u1085 \u1086 \u1089  \u1074  \u1082 \u1072 \u1089 \u1089 \u1091  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1080 , \u1077 \u1089 \u1083 \u1080  \u1086 \u1076 \u1085 \u1080 \u1084  \u1080 \u1079  \u1087 \u1088 \u1080 \u1079 \u1086 \u1074  \u1073 \u1091 \u1076 \u1077 \u1090  \u1073 \u1077 \u1083 \u1080 \u1095 \u1100 \u1103  \u1096 \u1091 \u1073 \u1082 \u1072 . \u1071  \u1082 \u1091 \u1087 \u1083 \u1102  \u1101 \u1090 \u1091  \u1096 \u1091 \u1073 \u1082 \u1091  \u1080  \u1077 \u1077  \u1076 \u1086 \u1083 \u1078 \u1077 \u1085  \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1090 \u1100  \u1073 \u1080 \u1083 \u1077 \u1090 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1081  \u1086 \u1082 \u1072 \u1078 \u1077 \u1090 \u1089 \u1103  \u1091  \u1084 \u1086 \u1077 \u1081  \u1078 \u1077 \u1085 \u1099 . \
\uc0\u1056 \u1072 \u1074 \u1074 \u1080 \u1085  \u1089 \u1076 \u1074 \u1080 \u1085 \u1091 \u1083  \u1086 \u1095 \u1082 \u1080  \u1085 \u1072  \u1085 \u1086 \u1089  \u1080  \u1091 \u1076 \u1080 \u1074 \u1083 \u1077 \u1085 \u1085 \u1086  \u1087 \u1086 \u1089 \u1084 \u1086 \u1090 \u1088 \u1077 \u1083  \u1085 \u1072  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1103 .\
\'96\uc0\u1071  \u1087 \u1086 \u1085 \u1080 \u1084 \u1072 \u1102 , \'96 \u1087 \u1088 \u1086 \u1076 \u1086 \u1083 \u1078 \u1080 \u1083  \u1090 \u1086 \u1090 , \'96 \u1095 \u1090 \u1086  \u1101 \u1090 \u1086  \u1085 \u1077  \u1089 \u1086 \u1074 \u1089 \u1077 \u1084  \u1095 \u1077 \u1089 \u1090 \u1085 \u1086 . \u1053 \u1086 , \u1074  \u1082 \u1086 \u1085 \u1094 \u1077  \u1082 \u1086 \u1085 \u1094 \u1086 \u1074 , \u1084 \u1099  \u1074 \u1077 \u1076 \u1100  \u1085 \u1080 \u1082 \u1086 \u1075 \u1086  \u1085 \u1077  \u1086 \u1073 \u1084 \u1072 \u1085 \u1099 \u1074 \u1072 \u1077 \u1084 ! \u1040  \u1091  \u1084 \u1077 \u1085 \u1103  \u1085 \u1077 \u1090  \u1076 \u1088 \u1091 \u1075 \u1086 \u1081  \u1074 \u1086 \u1079 \u1084 \u1086 \u1078 \u1085 \u1086 \u1089 \u1090 \u1080  \u1091 \u1073 \u1077 \u1076 \u1080 \u1090 \u1100  \u1078 \u1077 \u1085 \u1091  \u1087 \u1088 \u1080 \u1085 \u1103 \u1090 \u1100  \u1086 \u1073 \u1085 \u1086 \u1074 \u1082 \u1091 . \
\uc0\u1056 \u1072 \u1074 \u1074 \u1080 \u1085  \u1087 \u1086 \u1076 \u1091 \u1084 \u1072 \u1083  \u1080  \u1089 \u1086 \u1075 \u1083 \u1072 \u1089 \u1080 \u1083 \u1089 \u1103 . \u1053 \u1086  \u1089  \u1091 \u1089 \u1083 \u1086 \u1074 \u1080 \u1077 \u1084 , \u1096 \u1091 \u1073 \u1082 \u1072  \u1085 \u1077  \u1073 \u1091 \u1076 \u1077 \u1090  \u1079 \u1072 \u1103 \u1074 \u1083 \u1077 \u1085 \u1072  \u1074  \u1082 \u1072 \u1095 \u1077 \u1089 \u1090 \u1074 \u1077  \u1086 \u1076 \u1085 \u1086 \u1075 \u1086  \u1080 \u1079  \u1087 \u1088 \u1080 \u1079 \u1086 \u1074  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1080 . \u1041 \u1077 \u1081 \u1083 \u1077  \u1087 \u1088 \u1086 \u1089 \u1090 \u1086  \u1087 \u1086 \u1083 \u1091 \u1095 \u1080 \u1090  \u1090 \u1097 \u1072 \u1090 \u1077 \u1083 \u1100 \u1085 \u1086  \u1091 \u1087 \u1072 \u1082 \u1086 \u1074 \u1072 \u1085 \u1085 \u1099 \u1081  \u1089 \u1074 \u1077 \u1088 \u1090 \u1086 \u1082  \u1080  \u1083 \u1080 \u1096 \u1100  \u1076 \u1086 \u1084 \u1072  \u1087 \u1086 \u1081 \u1084 \u1077 \u1090 , \u1086  \u1095 \u1077 \u1084  \u1080 \u1076 \u1077 \u1090  \u1088 \u1077 \u1095 \u1100 . \u1058 \u1072 \u1082  \u1080  \u1076 \u1086 \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1083 \u1080 \u1089 \u1100 . \
\uc0\u1053 \u1077 \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1085 \u1077 \u1076 \u1077 \u1083 \u1100  \u1089 \u1087 \u1091 \u1089 \u1090 \u1103 , \u1091 \u1087 \u1083 \u1072 \u1090 \u1080 \u1074  \u1086 \u1073 \u1077 \u1097 \u1072 \u1085 \u1085 \u1091 \u1102  \u1089 \u1091 \u1084 \u1084 \u1091  \u1080  \u1087 \u1086 \u1083 \u1091 \u1095 \u1080 \u1074  \u1073 \u1080 \u1083 \u1077 \u1090  \u1074  \u1086 \u1073 \u1084 \u1077 \u1085  \u1085 \u1072  \u1088 \u1086 \u1089 \u1082 \u1086 \u1096 \u1085 \u1091 \u1102  \u1073 \u1077 \u1083 \u1080 \u1095 \u1100 \u1102  \u1096 \u1091 \u1073 \u1082 \u1091 , \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1074 \u1077 \u1088 \u1085 \u1091 \u1083 \u1089 \u1103  \u1076 \u1086 \u1084 \u1086 \u1081  \u1074  \u1087 \u1088 \u1080 \u1087 \u1086 \u1076 \u1085 \u1103 \u1090 \u1086 \u1084  \u1085 \u1072 \u1089 \u1090 \u1088 \u1086 \u1077 \u1085 \u1080 \u1080 . \
\'96 \uc0\u1041 \u1077 \u1081 \u1083 \u1077 , \'96 \u1089 \u1082 \u1072 \u1079 \u1072 \u1083  \u1086 \u1085 , \'96 \u1103  \u1090 \u1091 \u1090  \u1082 \u1091 \u1087 \u1080 \u1083  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082  \u1087 \u1091 \u1088 \u1080 \u1084 \u1089 \u1082 \u1086 \u1081  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1080 . \u1042 \u1086 \u1079 \u1100 \u1084 \u1080 , \u1072  \u1074 \u1076 \u1088 \u1091 \u1075  \u1095 \u1090 \u1086  \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1077 \u1096 \u1100 .\
\'96 \uc0\u1053 \u1091  \u1095 \u1090 \u1086  \u1084 \u1086 \u1078 \u1085 \u1086  \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1090 \u1100  \u1074  \u1087 \u1091 \u1088 \u1080 \u1084 \u1089 \u1082 \u1091 \u1102  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1102 , \u1082 \u1088 \u1086 \u1084 \u1077  \u1082 \u1086 \u1088 \u1078 \u1080 \u1082 \u1086 \u1074  \u1080  \u1082 \u1086 \u1085 \u1092 \u1077 \u1090 ? \'96 \u1091 \u1083 \u1099 \u1073 \u1085 \u1091 \u1083 \u1072 \u1089 \u1100  \u1041 \u1077 \u1081 \u1083 \u1077 , \u1087 \u1086 \u1089 \u1087 \u1077 \u1096 \u1072 \u1103  \u1087 \u1086  \u1082 \u1072 \u1082 \u1086 \u1084 \u1091 -\u1090 \u1086  \u1085 \u1077 \u1086 \u1090 \u1083 \u1086 \u1078 \u1085 \u1086 \u1084 \u1091  \u1076 \u1086 \u1084 \u1072 \u1096 \u1085 \u1077 \u1084 \u1091  \u1076 \u1077 \u1083 \u1091 . \u1054 \u1085 \u1072  \u1087 \u1088 \u1086 \u1096 \u1083 \u1072  \u1077 \u1097 \u1077  \u1085 \u1077 \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1096 \u1072 \u1075 \u1086 \u1074  \u1080  \u1074 \u1076 \u1088 \u1091 \u1075  \u1086 \u1089 \u1090 \u1072 \u1085 \u1086 \u1074 \u1080 \u1083 \u1072 \u1089 \u1100 , \u1089 \u1083 \u1086 \u1074 \u1085 \u1086  \u1087 \u1086 \u1088 \u1072 \u1078 \u1077 \u1085 \u1085 \u1072 \u1103  \u1087 \u1088 \u1080 \u1096 \u1077 \u1076 \u1096 \u1077 \u1081  \u1074  \u1075 \u1086 \u1083 \u1086 \u1074 \u1091  \u1084 \u1099 \u1089 \u1083 \u1100 \u1102 .\
\'96 \uc0\u1040  \u1079 \u1085 \u1072 \u1077 \u1096 \u1100 , \u1090 \u1099  \u1087 \u1088 \u1072 \u1074 , \'96 \u1089 \u1082 \u1072 \u1079 \u1072 \u1083 \u1072  \u1086 \u1085 \u1072 , \u1074 \u1086 \u1079 \u1074 \u1088 \u1072 \u1097 \u1072 \u1103 \u1089 \u1100  \u1082  \u1084 \u1091 \u1078 \u1091 . \'96 \u1044 \u1072 \u1074 \u1072 \u1081  \u1077 \u1075 \u1086  \u1089 \u1102 \u1076 \u1072 . \
\uc0\u1055 \u1088 \u1086 \u1096 \u1083 \u1086  \u1085 \u1077 \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1076 \u1085 \u1077 \u1081 , \u1080  \u1074 \u1077 \u1095 \u1077 \u1088 \u1086 \u1084  \u1087 \u1086 \u1089 \u1083 \u1077  \u1091 \u1078 \u1080 \u1085 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077  \u1074 \u1077 \u1088 \u1085 \u1091 \u1083 \u1072  \u1084 \u1091 \u1078 \u1091  \u1073 \u1080 \u1083 \u1077 \u1090  \u1087 \u1091 \u1088 \u1080 \u1084 \u1089 \u1082 \u1086 \u1081  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1080 .\
\'96\uc0\u1063 \u1090 \u1086  \u1089 \u1083 \u1091 \u1095 \u1080 \u1083 \u1086 \u1089 \u1100 ? \'96 \u1074 \u1089 \u1082 \u1088 \u1080 \u1095 \u1072 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 . \'96 \u1055 \u1086 \u1095 \u1077 \u1084 \u1091  \u1090 \u1099  \u1077 \u1075 \u1086  \u1074 \u1086 \u1079 \u1074 \u1088 \u1072 \u1097 \u1072 \u1077 \u1096 \u1100 ?\
\'96 \uc0\u1053 \u1080 \u1095 \u1077 \u1075 \u1086  \u1085 \u1077  \u1089 \u1083 \u1091 \u1095 \u1080 \u1083 \u1086 \u1089 \u1100 , \'96 \u1091 \u1089 \u1087 \u1086 \u1082 \u1086 \u1080 \u1083 \u1072  \u1077 \u1075 \u1086  \u1041 \u1077 \u1081 \u1083 \u1077 . \'96 \u1069 \u1090 \u1086  \u1089 \u1086 \u1074 \u1089 \u1077 \u1084  \u1076 \u1088 \u1091 \u1075 \u1086 \u1081  \u1073 \u1080 \u1083 \u1077 \u1090 , \u1103  \u1089 \u1072 \u1084 \u1072  \u1077 \u1075 \u1086  \u1082 \u1091 \u1087 \u1080 \u1083 \u1072 . \u1042 \u1077 \u1076 \u1100  \u1086 \u1085  \u1087 \u1088 \u1086 \u1089 \u1090 \u1086  \u1087 \u1086 \u1084 \u1086 \u1097 \u1100  \u1073 \u1077 \u1076 \u1085 \u1103 \u1082 \u1072 \u1084 , \u1085 \u1077  \u1090 \u1072 \u1082  \u1083 \u1080 ?\
\'96\uc0\u1058 \u1072 \u1082 , \u1082 \u1086 \u1085 \u1077 \u1095 \u1085 \u1086  \u1090 \u1072 \u1082 , \'96 \u1087 \u1086 \u1076 \u1090 \u1074 \u1077 \u1088 \u1076 \u1080 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 .\
\'96 \uc0\u1041 \u1077 \u1088 \u1080 , \'96 \u1041 \u1077 \u1081 \u1083 \u1077  \u1087 \u1086 \u1083 \u1086 \u1078 \u1080 \u1083 \u1072  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082  \u1087 \u1077 \u1088 \u1077 \u1076  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1077 \u1084 . \'96 \u1055 \u1091 \u1089 \u1090 \u1100  \u1086 \u1085  \u1073 \u1091 \u1076 \u1077 \u1090  \u1090 \u1074 \u1086 \u1080 \u1084  \u1080  \u1087 \u1088 \u1080 \u1085 \u1077 \u1089 \u1077 \u1090  \u1090 \u1077 \u1073 \u1077  \u1091 \u1076 \u1072 \u1095 \u1091 .\
\'96 \uc0\u1053 \u1091  \u1095 \u1090 \u1086  \u1079 \u1072  \u1091 \u1076 \u1072 \u1095 \u1091  \u1084 \u1086 \u1078 \u1077 \u1090  \u1087 \u1088 \u1080 \u1085 \u1077 \u1089 \u1090 \u1080  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082  \u1087 \u1091 \u1088 \u1080 \u1084 \u1089 \u1082 \u1086 \u1081  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1080 ?\'96 \u1091 \u1083 \u1099 \u1073 \u1085 \u1091 \u1083 \u1089 \u1103  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 . \'96 \u1058 \u1072 \u1088 \u1077 \u1083 \u1082 \u1091  \u1082 \u1086 \u1088 \u1078 \u1080 \u1082 \u1086 \u1074  \u1080  \u1084 \u1080 \u1089 \u1086 \u1095 \u1082 \u1091  \u1082 \u1086 \u1085 \u1092 \u1077 \u1090 ? \
 \'96 \uc0\u1040  \u1076 \u1072 \u1074 \u1072 \u1081  \u1087 \u1086 \u1087 \u1088 \u1086 \u1073 \u1091 \u1077 \u1084 , \'96 \u1089 \u1082 \u1072 \u1079 \u1072 \u1083 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077 . \
\'96 \uc0\u1044 \u1072 \u1074 \u1072 \u1081 , \'96 \u1089 \u1086 \u1075 \u1083 \u1072 \u1089 \u1080 \u1083 \u1089 \u1103  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 , \u1079 \u1072 \u1082 \u1072 \u1085 \u1095 \u1080 \u1074 \u1072 \u1103  \u1088 \u1072 \u1079 \u1075 \u1086 \u1074 \u1086 \u1088 .\
\uc0\u1042 \u1088 \u1077 \u1084 \u1103  \u1076 \u1086  \u1055 \u1091 \u1088 \u1080 \u1084 \u1072  \u1087 \u1088 \u1086 \u1083 \u1077 \u1090 \u1077 \u1083 \u1086  \u1085 \u1077 \u1079 \u1072 \u1084 \u1077 \u1090 \u1085 \u1086 . \u1061 \u1086 \u1088 \u1086 \u1096 \u1086  \u1089 \u1082 \u1072 \u1079 \u1072 \u1083 \u1080  \u1084 \u1091 \u1076 \u1088 \u1077 \u1094 \u1099 , \u1095 \u1090 \u1086  \u1074 \u1088 \u1077 \u1084 \u1103  \'96 \u1076 \u1088 \u1091 \u1075  \u1080  \u1083 \u1102 \u1073 \u1080 \u1084 \u1072 \u1103  \u1095 \u1077 \u1083 \u1086 \u1074 \u1077 \u1082 \u1072 . \u1044 \u1088 \u1091 \u1075 , \u1087 \u1086 \u1090 \u1086 \u1084 \u1091  \u1095 \u1090 \u1086  \u1091 \u1090 \u1077 \u1096 \u1072 \u1077 \u1090  \u1082 \u1072 \u1082  \u1073 \u1083 \u1080 \u1079 \u1082 \u1080 \u1081  \u1090 \u1086 \u1074 \u1072 \u1088 \u1080 \u1097 , \u1072  \u1083 \u1102 \u1073 \u1080 \u1084 \u1072 \u1103 , \u1087 \u1086 \u1090 \u1086 \u1084 \u1091 , \u1095 \u1090 \u1086  \u1083 \u1077 \u1095 \u1080 \u1090  \u1090 \u1072 \u1082 , \u1082 \u1072 \u1082  \u1084 \u1086 \u1078 \u1077 \u1090  \u1083 \u1077 \u1095 \u1080 \u1090 \u1100  \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1083 \u1102 \u1073 \u1086 \u1074 \u1100 . \
\uc0\u1055 \u1086 \u1084 \u1080 \u1084 \u1086  \u1076 \u1086 \u1084 \u1072 \u1096 \u1085 \u1080 \u1093  \u1093 \u1083 \u1086 \u1087 \u1086 \u1090  \u1041 \u1077 \u1081 \u1083 \u1077  \u1074 \u1089 \u1077  \u1101 \u1090 \u1080  \u1076 \u1085 \u1080  \u1073 \u1099 \u1083 \u1072  \u1089  \u1075 \u1086 \u1083 \u1086 \u1074 \u1086 \u1081  \u1079 \u1072 \u1085 \u1103 \u1090 \u1072  \u1087 \u1086 \u1076 \u1075 \u1086 \u1090 \u1086 \u1074 \u1082 \u1086 \u1081  \u1089 \u1074 \u1072 \u1076 \u1100 \u1073 \u1099  \u1043 \u1080 \u1090 \u1083 , \u1077 \u1077  \u1102 \u1085 \u1086 \u1081  \u1087 \u1086 \u1084 \u1086 \u1097 \u1085 \u1080 \u1094 \u1099  \u1087 \u1086  \u1093 \u1086 \u1079 \u1103 \u1081 \u1089 \u1090 \u1074 \u1091 . \u1052 \u1072 \u1090 \u1100  \u1043 \u1080 \u1090 \u1083  \u1088 \u1072 \u1085 \u1086  \u1091 \u1084 \u1077 \u1088 \u1083 \u1072 , \u1086 \u1090 \u1077 \u1094  \u1078 \u1077 \u1085 \u1080 \u1083 \u1089 \u1103 , \u1080  \u1085 \u1086 \u1074 \u1072 \u1103  \u1078 \u1077 \u1085 \u1072  \u1085 \u1077 \u1074 \u1079 \u1083 \u1102 \u1073 \u1080 \u1083 \u1072  \u1087 \u1072 \u1076 \u1095 \u1077 \u1088 \u1080 \u1094 \u1091 . \u1043 \u1080 \u1090 \u1083  \u1074  \u1090 \u1088 \u1080 \u1085 \u1072 \u1076 \u1094 \u1072 \u1090 \u1100  \u1083 \u1077 \u1090  \u1087 \u1086 \u1096 \u1083 \u1072  \u1074  \u1089 \u1083 \u1091 \u1078 \u1072 \u1085 \u1082 \u1080 , \u1083 \u1080 \u1096 \u1100  \u1073 \u1099  \u1085 \u1077  \u1085 \u1072 \u1093 \u1086 \u1076 \u1080 \u1090 \u1100 \u1089 \u1103  \u1087 \u1086 \u1076  \u1086 \u1076 \u1085 \u1086 \u1081  \u1082 \u1088 \u1099 \u1096 \u1077 \u1081  \u1089  \u1085 \u1077 \u1076 \u1086 \u1073 \u1088 \u1086 \u1081  \u1084 \u1072 \u1095 \u1077 \u1093 \u1086 \u1081 . \u1059 \u1078 \u1077  \u1087 \u1103 \u1090 \u1100  \u1083 \u1077 \u1090  \u1086 \u1085 \u1072  \u1083 \u1077 \u1090  \u1078 \u1080 \u1083 \u1072  \u1074  \u1076 \u1086 \u1084 \u1077  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1103  \u1080  \u1041 \u1077 \u1081 \u1083 \u1077  \u1080  \u1086 \u1085 \u1080  \u1086 \u1090 \u1085 \u1086 \u1089 \u1080 \u1083 \u1080 \u1089 \u1100  \u1082  \u1085 \u1077 \u1081  \u1089 \u1083 \u1086 \u1074 \u1085 \u1086  \u1082  \u1088 \u1086 \u1076 \u1085 \u1086 \u1081  \u1076 \u1086 \u1095 \u1077 \u1088 \u1080 .\
\
\uc0\u1040  \u1091  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1103  \u1085 \u1072 \u1074 \u1072 \u1083 \u1080 \u1083 \u1086 \u1089 \u1100  \u1089 \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1076 \u1077 \u1083 , \u1087 \u1088 \u1080 \u1103 \u1090 \u1085 \u1099 \u1093  \u1080  \u1085 \u1077 \u1087 \u1088 \u1080 \u1103 \u1090 \u1085 \u1099 \u1093 , \u1095 \u1090 \u1086  \u1086 \u1085  \u1080  \u1076 \u1091 \u1084 \u1072 \u1090 \u1100  \u1079 \u1072 \u1073 \u1099 \u1083  \u1086 \u1073 \u1086  \u1074 \u1089 \u1077 \u1084 , \u1090 \u1077 \u1084  \u1073 \u1086 \u1083 \u1077 \u1077  \u1086  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1081 \u1085 \u1086 \u1084  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082 \u1077 . \u1054  \u1087 \u1086 \u1076 \u1072 \u1088 \u1082 \u1077  \u1078 \u1077 \u1085 \u1099   \u1086 \u1085  \u1074 \u1089 \u1087 \u1086 \u1084 \u1085 \u1080 \u1083  \u1083 \u1080 \u1096 \u1100  \u1085 \u1072 \u1082 \u1072 \u1085 \u1091 \u1085 \u1077  \u1055 \u1091 \u1088 \u1080 \u1084 \u1072 , \u1074 \u1086  \u1074 \u1088 \u1077 \u1084 \u1103  \u1091 \u1090 \u1088 \u1077 \u1085 \u1085 \u1077 \u1081  \u1084 \u1086 \u1083 \u1080 \u1090 \u1074 \u1099 , \u1079 \u1072  \u1076 \u1074 \u1072  \u1095 \u1072 \u1089 \u1072  \u1076 \u1086  \u1085 \u1072 \u1095 \u1072 \u1083 \u1072  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1080 . \u1048 \u1076 \u1090 \u1080  \u1085 \u1072  \u1085 \u1077 \u1077  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1085 \u1077  \u1089 \u1086 \u1073 \u1080 \u1088 \u1072 \u1083 \u1089 \u1103 , \u1087 \u1088 \u1077 \u1076 \u1089 \u1090 \u1086 \u1103 \u1083 \u1072  \u1074 \u1072 \u1078 \u1085 \u1072 \u1103  \u1074 \u1089 \u1090 \u1088 \u1077 \u1095 \u1072  \u1089  \u1087 \u1088 \u1086 \u1077 \u1079 \u1078 \u1080 \u1084  \u1086 \u1087 \u1090 \u1086 \u1074 \u1080 \u1082 \u1086 \u1084  \u1080 \u1079  \u1054 \u1076 \u1077 \u1089 \u1089 \u1099 , \u1079 \u1072 \u1082 \u1091 \u1087 \u1072 \u1102 \u1097 \u1080 \u1084  \u1082 \u1086 \u1078 \u1080 . \u1054 \u1090 \u1099 \u1089 \u1082 \u1072 \u1074  \u1074  \u1082 \u1086 \u1096 \u1077 \u1083 \u1100 \u1082 \u1077  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082 , \u1086 \u1085  \u1086 \u1090 \u1076 \u1072 \u1083  \u1077 \u1075 \u1086  \u1074 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 \u1091 , \u1084 \u1086 \u1083 \u1080 \u1074 \u1096 \u1077 \u1084 \u1091 \u1089 \u1103  \u1089  \u1085 \u1080 \u1084  \u1074  \u1086 \u1076 \u1085 \u1086 \u1081  \u1089 \u1080 \u1085 \u1072 \u1075 \u1086 \u1075 \u1077 . \
\uc0\u1041 \u1077 \u1076 \u1085 \u1103 \u1075 \u1072  \u1077 \u1076 \u1074 \u1072  \u1089 \u1074 \u1086 \u1076 \u1080 \u1083  \u1082 \u1086 \u1085 \u1094 \u1099  \u1089  \u1082 \u1086 \u1085 \u1094 \u1072 \u1084 \u1080 , \u1077 \u1075 \u1086  \u1089 \u1077 \u1084 \u1100 \u1103  \u1087 \u1077 \u1088 \u1077 \u1073 \u1080 \u1074 \u1072 \u1083 \u1072 \u1089 \u1100  \u1089  \u1093 \u1083 \u1077 \u1073 \u1072  \u1085 \u1072  \u1074 \u1086 \u1076 \u1091 , \u1072  \u1089 \u1072 \u1084  \u1086 \u1085  \u1093 \u1086 \u1076 \u1080 \u1083  \u1074  \u1090 \u1072 \u1082 \u1080 \u1093  \u1086 \u1073 \u1085 \u1086 \u1089 \u1082 \u1072 \u1093 , \u1095 \u1090 \u1086  \u1089 \u1090 \u1099 \u1076 \u1085 \u1086  \u1073 \u1099 \u1083 \u1086  \u1089 \u1084 \u1086 \u1090 \u1088 \u1077 \u1090 \u1100 . \
\'ab\uc0\u1045 \u1097 \u1077  \u1086 \u1076 \u1085 \u1072  \u1082 \u1086 \u1088 \u1079 \u1080 \u1085 \u1082 \u1072  \u1089  \u1082 \u1086 \u1088 \u1078 \u1080 \u1082 \u1072 \u1084 \u1080  \u1077 \u1084 \u1091  \u1103 \u1074 \u1085 \u1086  \u1085 \u1077  \u1087 \u1086 \u1084 \u1077 \u1096 \u1072 \u1077 \u1090 \'bb, \'96 \u1087 \u1086 \u1076 \u1091 \u1084 \u1072 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 , \u1074 \u1088 \u1091 \u1095 \u1072 \u1103  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082 .  \u1042 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079   \u1088 \u1072 \u1089 \u1089 \u1099 \u1087 \u1072 \u1083 \u1089 \u1103  \u1074  \u1073 \u1083 \u1072 \u1075 \u1086 \u1076 \u1072 \u1088 \u1085 \u1086 \u1089 \u1090 \u1103 \u1093 , \u1085 \u1086  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1091 \u1078 \u1077  \u1096 \u1077 \u1083  \u1087 \u1086  \u1087 \u1088 \u1086 \u1093 \u1086 \u1076 \u1091  \u1089 \u1080 \u1085 \u1072 \u1075 \u1086 \u1075 \u1080 , \u1077 \u1075 \u1086  \u1078 \u1076 \u1072 \u1083 \u1072  \u1085 \u1077 \u1088 \u1074 \u1085 \u1072 \u1103  \u1080  \u1086 \u1090 \u1074 \u1077 \u1090 \u1089 \u1090 \u1074 \u1077 \u1085 \u1085 \u1072 \u1103  \u1074 \u1089 \u1090 \u1088 \u1077 \u1095 \u1072 . \
\uc0\u1053 \u1077 \u1088 \u1074 \u1085 \u1080 \u1095 \u1072 \u1083  \u1086 \u1085 , \u1082 \u1072 \u1082  \u1086 \u1082 \u1072 \u1079 \u1072 \u1083 \u1086 \u1089 \u1100 , \u1085 \u1072 \u1087 \u1088 \u1072 \u1089 \u1085 \u1086 . \u1054 \u1087 \u1090 \u1086 \u1074 \u1080 \u1082  \u1087 \u1088 \u1077 \u1073 \u1099 \u1074 \u1072 \u1083  \u1074  \u1087 \u1088 \u1077 \u1082 \u1088 \u1072 \u1089 \u1085 \u1086 \u1084  \u1088 \u1072 \u1089 \u1087 \u1086 \u1083 \u1086 \u1078 \u1077 \u1085 \u1080 \u1080  \u1076 \u1091 \u1093 \u1072 , \u1074 \u1089 \u1077  \u1087 \u1088 \u1086 \u1096 \u1083 \u1086  \u1075 \u1083 \u1072 \u1076 \u1082 \u1086 , \u1093 \u1086 \u1090 \u1100  \u1080  \u1079 \u1072 \u1085 \u1103 \u1083 \u1086  \u1073 \u1086 \u1083 \u1100 \u1096 \u1077  \u1074 \u1088 \u1077 \u1084 \u1077 \u1085 \u1080 , \u1095 \u1077 \u1084  \u1087 \u1088 \u1077 \u1076 \u1087 \u1086 \u1083 \u1072 \u1075 \u1072 \u1083 \u1086 \u1089 \u1100 . \u1044 \u1086 \u1084 \u1086 \u1081  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1074 \u1086 \u1079 \u1074 \u1088 \u1072 \u1097 \u1072 \u1083 \u1089 \u1103 , \u1087 \u1088 \u1077 \u1076 \u1074 \u1082 \u1091 \u1096 \u1072 \u1103  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1085 \u1086 \u1077  \u1091 \u1076 \u1080 \u1074 \u1083 \u1077 \u1085 \u1080 \u1077 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1084  \u1089  \u1085 \u1080 \u1084  \u1087 \u1086 \u1076 \u1077 \u1083 \u1080 \u1090 \u1089 \u1103  \u1041 \u1077 \u1081 \u1083 \u1077 , \u1088 \u1072 \u1089 \u1089 \u1082 \u1072 \u1079 \u1099 \u1074 \u1072 \u1103  \u1086  \u1074 \u1099 \u1080 \u1075 \u1088 \u1099 \u1096 \u1077 . \
\uc0\u1054 \u1085 \u1072  \u1086 \u1090 \u1082 \u1088 \u1099 \u1083 \u1072  \u1077 \u1084 \u1091  \u1076 \u1074 \u1077 \u1088 \u1100 , \u1089 \u1080 \u1103 \u1103  \u1091 \u1083 \u1099 \u1073 \u1082 \u1086 \u1081 . \u1054 \u1085  \u1091 \u1083 \u1099 \u1073 \u1085 \u1091 \u1083 \u1089 \u1103  \u1074  \u1086 \u1090 \u1074 \u1077 \u1090 , \u1085 \u1086  \u1085 \u1077  \u1089 \u1090 \u1072 \u1083  \u1088 \u1072 \u1089 \u1089 \u1087 \u1088 \u1072 \u1096 \u1080 \u1074 \u1072 \u1090 \u1100 , \u1072  \u1087 \u1088 \u1086 \u1096 \u1077 \u1083  \u1074  \u1075 \u1086 \u1088 \u1085 \u1080 \u1094 \u1091 . \
\'96 \uc0\u1063 \u1090 \u1086 -\u1090 \u1086  \u1090 \u1099  \u1087 \u1088 \u1080 \u1087 \u1086 \u1079 \u1076 \u1085 \u1080 \u1083 \u1089 \u1103 , \'96 \u1074 \u1086 \u1089 \u1082 \u1083 \u1080 \u1082 \u1085 \u1091 \u1083 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077 . \'96 \u1050 \u1086 \u1090 \u1086 \u1088 \u1099 \u1081  \u1095 \u1072 \u1089 ?\
\uc0\u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1087 \u1086 \u1074 \u1077 \u1088 \u1085 \u1091 \u1083 \u1089 \u1103  \u1080  \u1087 \u1086 \u1075 \u1083 \u1103 \u1076 \u1077 \u1083  \u1085 \u1072  \u1095 \u1072 \u1089 \u1099  \u1074  \u1087 \u1088 \u1086 \u1089 \u1090 \u1077 \u1085 \u1082 \u1077 .\
\'96 \uc0\u1055 \u1086 \u1095 \u1090 \u1080  \u1076 \u1074 \u1072  \u1095 \u1072 \u1089 \u1072 . \u1071  \u1076 \u1091 \u1084 \u1072 \u1083 , \u1095 \u1090 \u1086  \u1091 \u1087 \u1088 \u1072 \u1074 \u1083 \u1102 \u1089 \u1100  \u1073 \u1099 \u1089 \u1090 \u1088 \u1077 \u1077 , \u1085 \u1086  \u1088 \u1072 \u1079 \u1075 \u1086 \u1074 \u1086 \u1088  \u1074 \u1099 \u1096 \u1077 \u1083  \u1090 \u1088 \u1091 \u1076 \u1085 \u1099 \u1084 .\
\'96 \uc0\u1056 \u1072 \u1079 \u1074 \u1077  \u1090 \u1099  \u1085 \u1077  \u1093 \u1086 \u1076 \u1080 \u1083  \u1085 \u1072  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1102 ? \'96 \u1089 \u1087 \u1088 \u1086 \u1089 \u1080 \u1083 \u1072  \u1074 \u1085 \u1077 \u1079 \u1072 \u1087 \u1085 \u1086  \u1087 \u1086 \u1075 \u1088 \u1091 \u1089 \u1090 \u1085 \u1077 \u1074 \u1096 \u1072 \u1103  \u1041 \u1077 \u1081 \u1083 \u1077 .\
\'96 \uc0\u1053 \u1077 \u1090 , \u1085 \u1080 \u1082 \u1072 \u1082  \u1085 \u1077  \u1084 \u1086 \u1075 . \u1048 \u1079 \u1074 \u1080 \u1085 \u1080 , \u1103  \u1086 \u1090 \u1076 \u1072 \u1083  \u1090 \u1074 \u1086 \u1081  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082  \u1074 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 \u1091 , \u1087 \u1091 \u1089 \u1090 \u1100  \u1077 \u1075 \u1086  \u1076 \u1077 \u1090 \u1082 \u1080  \u1074 \u1076 \u1086 \u1074 \u1086 \u1083 \u1100  \u1085 \u1072 \u1077 \u1076 \u1103 \u1090 \u1089 \u1103  \u1089 \u1083 \u1072 \u1076 \u1082 \u1080 \u1084 .\
\'96 \uc0\u1042 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 \u1091 , \'96 \u1087 \u1086 \u1074 \u1090 \u1086 \u1088 \u1080 \u1083 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077 . \'96 \u1044 \u1072 -\u1076 \u1072 , \u1087 \u1091 \u1089 \u1090 \u1100  \u1085 \u1072 \u1077 \u1076 \u1103 \u1090 \u1089 \u1103 .\
\'96 \uc0\u1040  \u1090 \u1099 ? \'96 \u1074  \u1089 \u1074 \u1086 \u1102  \u1086 \u1095 \u1077 \u1088 \u1077 \u1076 \u1100  \u1089 \u1087 \u1088 \u1086 \u1089 \u1080 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 . \'96 \u1058 \u1099 -\u1090 \u1086  \u1074 \u1077 \u1076 \u1100  \u1093 \u1086 \u1076 \u1080 \u1083 \u1072 .\
\'96 \uc0\u1053 \u1077 \u1090 , \u1103  \u1090 \u1086 \u1078 \u1077  \u1085 \u1077  \u1089 \u1084 \u1086 \u1075 \u1083 \u1072 , \'96 \u1086 \u1085 \u1072  \u1089 \u1086 \u1082 \u1088 \u1091 \u1096 \u1077 \u1085 \u1085 \u1086  \u1088 \u1072 \u1079 \u1074 \u1077 \u1083 \u1072  \u1088 \u1091 \u1082 \u1072 \u1084 \u1080 .\'96 \u1059 \u1074 \u1099 , \u1085 \u1077  \u1087 \u1086 \u1083 \u1091 \u1095 \u1080 \u1083 \u1086 \u1089 \u1100 . \
\'96 \uc0\u1040  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082 ?\
\'96 \uc0\u1048 \u1079 \u1074 \u1080 \u1085 \u1080 , \u1085 \u1077  \u1093 \u1086 \u1090 \u1077 \u1083 \u1072  \u1090 \u1077 \u1073 \u1103  \u1086 \u1075 \u1086 \u1088 \u1095 \u1072 \u1090 \u1100 . \u1071  \u1077 \u1075 \u1086  \u1087 \u1086 \u1090 \u1077 \u1088 \u1103 \u1083 \u1072 . \
\'96 \uc0\u1050 \u1072 \u1082  \u1087 \u1086 \u1090 \u1077 \u1088 \u1103 \u1083 \u1072 ?\
\'96 \uc0\u1053 \u1077  \u1079 \u1085 \u1072 \u1102 .\
\'ab\uc0\u1051 \u1072 \u1076 \u1085 \u1086 , \'96 \u1087 \u1086 \u1076 \u1091 \u1084 \u1072 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 , \'96 \u1096 \u1091 \u1073 \u1082 \u1072  \u1085 \u1077  \u1079 \u1072 \u1103 \u1074 \u1083 \u1077 \u1085 \u1072  \u1074  \u1089 \u1087 \u1080 \u1089 \u1082 \u1077  \u1087 \u1088 \u1080 \u1079 \u1086 \u1074 , \u1079 \u1085 \u1072 \u1095 \u1080 \u1090 , \u1086 \u1085 \u1072  \u1087 \u1088 \u1086 \u1089 \u1090 \u1086  \u1086 \u1089 \u1090 \u1072 \u1083 \u1072 \u1089 \u1100  \u1091  \u1088 \u1072 \u1074 \u1074 \u1080 \u1085 \u1072 . \u1053 \u1072 \u1076 \u1086  \u1073 \u1091 \u1076 \u1077 \u1090  \u1087 \u1086 \u1089 \u1083 \u1077  \u1055 \u1091 \u1088 \u1080 \u1084 \u1072  \u1077 \u1077  \u1079 \u1072 \u1073 \u1088 \u1072 \u1090 \u1100  \u1080  \u1087 \u1088 \u1080 \u1076 \u1091 \u1084 \u1072 \u1090 \u1100 , \u1082 \u1072 \u1082  \u1073 \u1099 \u1090 \u1100  \u1076 \u1072 \u1083 \u1100 \u1096 \u1077 . \u1040 \u1093 , \u1082 \u1072 \u1082 \u1086 \u1081  \u1093 \u1086 \u1088 \u1086 \u1096 \u1080 \u1081  \u1073 \u1099 \u1083  \u1087 \u1083 \u1072 \u1085 , \u1078 \u1072 \u1083 \u1100 , \u1095 \u1090 \u1086  \u1089 \u1086 \u1088 \u1074 \u1072 \u1083 \u1089 \u1103 \'bb.\
\uc0\u1053 \u1072  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1095 \u1085 \u1091 \u1102  \u1084 \u1086 \u1083 \u1080 \u1090 \u1074 \u1091  \u1086 \u1085  \u1087 \u1088 \u1080 \u1096 \u1077 \u1083  \u1095 \u1091 \u1090 \u1100  \u1088 \u1072 \u1085 \u1100 \u1096 \u1077 , \u1095 \u1077 \u1084  \u1090 \u1088 \u1077 \u1073 \u1086 \u1074 \u1072 \u1083 \u1086 \u1089 \u1100 . \u1044 \u1077 \u1090 \u1080   \u1087 \u1086 \u1073 \u1077 \u1078 \u1072 \u1083 \u1080  \u1074  \u1094 \u1077 \u1085 \u1090 \u1088 \u1072 \u1083 \u1100 \u1085 \u1091 \u1102  \u1089 \u1080 \u1085 \u1072 \u1075 \u1086 \u1075 \u1091  \u1084 \u1077 \u1089 \u1090 \u1077 \u1095 \u1082 \u1072 , \u1072  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1086 \u1090 \u1087 \u1088 \u1072 \u1074 \u1080 \u1083 \u1089 \u1103  \u1074  \u1089 \u1080 \u1085 \u1072 \u1075 \u1086 \u1075 \u1091  \u1087 \u1086  \u1089 \u1086 \u1089 \u1077 \u1076 \u1089 \u1090 \u1074 \u1091 , \u1085 \u1077  \u1090 \u1072 \u1082 \u1091 \u1102  \u1082 \u1088 \u1072 \u1089 \u1080 \u1074 \u1091 \u1102 , \u1085 \u1086  \u1090 \u1077 \u1087 \u1083 \u1091 \u1102  \u1080  \u1087 \u1088 \u1080 \u1074 \u1099 \u1095 \u1085 \u1091 \u1102 , \u1082 \u1072 \u1082  \u1073 \u1099 \u1074 \u1072 \u1077 \u1090  \u1087 \u1088 \u1080 \u1074 \u1099 \u1095 \u1085 \u1099 \u1084  \u1089 \u1090 \u1072 \u1088 \u1099 \u1081  \u1085 \u1077 \u1082 \u1072 \u1079 \u1080 \u1089 \u1090 \u1099 \u1081  \u1076 \u1086 \u1084 . \u1054 \u1085  \u1083 \u1102 \u1073 \u1080 \u1083  \u1101 \u1090 \u1080  \u1082 \u1086 \u1088 \u1086 \u1090 \u1082 \u1080 \u1077  \u1084 \u1080 \u1085 \u1091 \u1090 \u1099  \u1087 \u1077 \u1088 \u1077 \u1076  \u1085 \u1072 \u1095 \u1072 \u1083 \u1086 \u1084  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1082 \u1072 , \u1082 \u1086 \u1075 \u1076 \u1072  \u1089 \u1091 \u1077 \u1090 \u1072  \u1073 \u1091 \u1076 \u1085 \u1077 \u1081  \u1091 \u1078 \u1077  \u1086 \u1090 \u1089 \u1090 \u1091 \u1087 \u1080 \u1083 \u1072 , \u1072  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1100  \u1090 \u1086 \u1088 \u1078 \u1077 \u1089 \u1090 \u1074 \u1072  \u1077 \u1097 \u1077  \u1085 \u1077  \u1091 \u1089 \u1087 \u1077 \u1083 \u1072  \u1085 \u1072 \u1082 \u1072 \u1090 \u1080 \u1090 \u1100 . \
\uc0\u1053 \u1072  \u1087 \u1086 \u1088 \u1086 \u1075 \u1077  \u1086 \u1085  \u1089 \u1090 \u1086 \u1083 \u1082 \u1085 \u1091 \u1083 \u1089 \u1103  \u1089 \u1086  \u1089 \u1083 \u1091 \u1078 \u1082 \u1086 \u1081  \u1075 \u1083 \u1072 \u1074 \u1099  \u1089 \u1086 \u1074 \u1077 \u1090 \u1072  \u1086 \u1073 \u1097 \u1080 \u1085 \u1099 .\
\'96 \uc0\u1050 \u1086 \u1090 \u1086 \u1088 \u1099 \u1081  \u1095 \u1072 \u1089 , \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 ? \'96 \u1089 \u1087 \u1088 \u1086 \u1089 \u1080 \u1083  \u1089 \u1083 \u1091 \u1078 \u1082 \u1072 .\
\'96 \uc0\u1053 \u1077  \u1079 \u1085 \u1072 \u1102 , \'96 \u1086 \u1090 \u1074 \u1077 \u1090 \u1080 \u1083  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 .\
\'96 \uc0\u1053 \u1091 , \u1090 \u1072 \u1082  \u1074 \u1079 \u1075 \u1083 \u1103 \u1085 \u1080  \u1085 \u1072  \u1089 \u1074 \u1086 \u1080  \u1085 \u1086 \u1074 \u1099 \u1077  \u1095 \u1072 \u1089 \u1099 , \'96 \u1087 \u1088 \u1077 \u1076 \u1083 \u1086 \u1078 \u1080 \u1083  \u1089 \u1083 \u1091 \u1078 \u1082 \u1072 . \'96 \u1055 \u1086 \u1089 \u1084 \u1086 \u1090 \u1088 \u1077 \u1090 \u1100  \u1076 \u1077 \u1085 \u1077 \u1075  \u1085 \u1077  \u1089 \u1090 \u1086 \u1080 \u1090 .\
\'96 \uc0\u1050 \u1072 \u1082 \u1080 \u1077  \u1077 \u1097 \u1077  \u1095 \u1072 \u1089 \u1099 ? \'96 \u1091 \u1076 \u1080 \u1074 \u1080 \u1083 \u1089 \u1103  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 . \'96 \u1063 \u1090 \u1086  \u1090 \u1099  \u1085 \u1077 \u1089 \u1077 \u1096 \u1100 ?!\
\'96 \uc0\u1053 \u1091 , \u1090 \u1099  \u1078 \u1077  \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1083  \u1089 \u1077 \u1075 \u1086 \u1076 \u1085 \u1103  \u1074  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1102  \u1079 \u1086 \u1083 \u1086 \u1090 \u1099 \u1077  \u1095 \u1072 \u1089 \u1099 ?\
\'96\uc0\u1071  \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1083 ? \u1044 \u1072  \u1089  \u1095 \u1077 \u1075 \u1086  \u1090 \u1099  \u1074 \u1079 \u1103 \u1083 ?\
\'96 \uc0\u1057  \u1095 \u1077 \u1075 \u1086  \u1103  \u1074 \u1079 \u1103 \u1083 , \'96 \u1091 \u1089 \u1084 \u1077 \u1093 \u1085 \u1091 \u1083 \u1089 \u1103  \u1089 \u1083 \u1091 \u1078 \u1082 \u1072 . \'96 \u1053 \u1077  \u1087 \u1088 \u1080 \u1082 \u1080 \u1076 \u1099 \u1074 \u1072 \u1081 \u1089 \u1103 , \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 , \u1084 \u1085 \u1077  \u1074 \u1089 \u1077  \u1080 \u1079 \u1074 \u1077 \u1089 \u1090 \u1085 \u1086 .\
\'96 \uc0\u1044 \u1072  \u1095 \u1090 \u1086  \u1090 \u1077 \u1073 \u1077  \u1080 \u1079 \u1074 \u1077 \u1089 \u1090 \u1085 \u1086 ?\'96 \u1074 \u1086 \u1079 \u1084 \u1091 \u1090 \u1080 \u1083 \u1089 \u1103  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 . \'96 \u1071  \u1085 \u1072  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1077  \u1074 \u1086 \u1086 \u1073 \u1097 \u1077  \u1085 \u1077  \u1073 \u1099 \u1083 , \u1072  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082  \u1087 \u1086 \u1076 \u1072 \u1088 \u1080 \u1083  \u1074 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 \u1091 .\
\'96 \uc0\u1050 \u1086 \u1084 \u1091 ? \'96 \u1080 \u1079 \u1091 \u1084 \u1080 \u1083 \u1089 \u1103  \u1089 \u1083 \u1091 \u1078 \u1082 \u1072 . \'96 \u1058 \u1099  \u1087 \u1086 \u1076 \u1072 \u1088 \u1080 \u1083  \u1089 \u1074 \u1086 \u1081  \u1073 \u1080 \u1083 \u1077 \u1090  \u1074 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 \u1091 ?\
\'96 \uc0\u1044 \u1072 , \u1072  \u1095 \u1090 \u1086 ? \'96 \u1074  \u1089 \u1074 \u1086 \u1102  \u1086 \u1095 \u1077 \u1088 \u1077 \u1076 \u1100  \u1091 \u1076 \u1080 \u1074 \u1080 \u1083 \u1089 \u1103  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 .\
\'96\uc0\u1058 \u1072 \u1082  \u1090 \u1099  \u1087 \u1088 \u1086 \u1089 \u1090 \u1086  \u1076 \u1091 \u1088 \u1077 \u1085 \u1100 ! \'96 \u1074 \u1089 \u1082 \u1088 \u1080 \u1095 \u1072 \u1083  \u1089 \u1083 \u1091 \u1078 \u1082 \u1072 . \'96 \u1058 \u1074 \u1086 \u1103  \u1078 \u1077 \u1085 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077  \u1082 \u1091 \u1087 \u1080 \u1083 \u1072  \u1079 \u1086 \u1083 \u1086 \u1090 \u1099 \u1077  \u1095 \u1072 \u1089 \u1099  \u1080  \u1076 \u1086 \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1083 \u1072 \u1089 \u1100  \u1089  \u1075 \u1083 \u1072 \u1074 \u1086 \u1081  \u1089 \u1086 \u1074 \u1077 \u1090 \u1072 , \u1095 \u1090 \u1086  \u1080 \u1093  \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1077 \u1090  \u1090 \u1074 \u1086 \u1081  \u1073 \u1080 \u1083 \u1077 \u1090 \u1080 \u1082 . \u1047 \u1085 \u1072 \u1077 \u1096 \u1100 , \u1089 \u1082 \u1086 \u1083 \u1100 \u1082 \u1086  \u1086 \u1085 \u1072  \u1079 \u1072  \u1101 \u1090 \u1086  \u1087 \u1086 \u1078 \u1077 \u1088 \u1090 \u1074 \u1086 \u1074 \u1072 \u1083 \u1072  \u1085 \u1072  \u1083 \u1086 \u1090 \u1077 \u1088 \u1077 \u1102 ? \u1043 \u1086 \u1074 \u1086 \u1088 \u1080 \u1090 \u1100  \u1089 \u1090 \u1088 \u1072 \u1096 \u1085 \u1086 !\
\'96 \uc0\u1042 \u1086 \u1090  \u1080  \u1085 \u1077  \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 , \'96 \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1086 \u1087 \u1091 \u1089 \u1090 \u1080 \u1083  \u1089 \u1074 \u1086 \u1102  \u1090 \u1103 \u1078 \u1077 \u1083 \u1091 \u1102  \u1088 \u1091 \u1082 \u1091  \u1085 \u1072  \u1087 \u1083 \u1077 \u1095 \u1086  \u1089 \u1083 \u1091 \u1078 \u1082 \u1080  \u1080  \u1082 \u1088 \u1077 \u1087 \u1082 \u1086  \u1089 \u1078 \u1072 \u1083 . \'96 \u1047 \u1072 \u1073 \u1091 \u1076 \u1100  \u1087 \u1088 \u1086  \u1101 \u1090 \u1086 , \u1087 \u1086 \u1085 \u1103 \u1083 ? \u1053 \u1072 \u1074 \u1089 \u1077 \u1075 \u1076 \u1072  \u1079 \u1072 \u1073 \u1091 \u1076 \u1100 .\
\'96 \uc0\u1059 \u1078 \u1077  \u1079 \u1072 \u1073 \u1099 \u1083 , \'96 \u1089 \u1082 \u1086 \u1088 \u1095 \u1080 \u1083 \u1089 \u1103  \u1086 \u1090  \u1073 \u1086 \u1083 \u1080  \u1089 \u1083 \u1091 \u1078 \u1082 \u1072 .\
 \uc0\u1042 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079  \u1087 \u1088 \u1080 \u1096 \u1077 \u1083  \u1074  \u1089 \u1080 \u1085 \u1072 \u1075 \u1086 \u1075 \u1091  \u1074 \u1072 \u1078 \u1085 \u1099 \u1081 , \u1089 \u1083 \u1086 \u1074 \u1085 \u1086  \u1084 \u1086 \u1101 \u1083 \u1100  \u1074 \u1086  \u1074 \u1088 \u1077 \u1084 \u1103  \u1086 \u1073 \u1088 \u1077 \u1079 \u1072 \u1085 \u1080 \u1103 . \u1042 \u1089 \u1077  \u1085 \u1072  \u1085 \u1077 \u1084  \u1073 \u1099 \u1083 \u1086  \u1085 \u1086 \u1074 \u1086 \u1077  \u1080  \u1076 \u1086 \u1088 \u1086 \u1075 \u1086 \u1077 , \u1080  \u1096 \u1072 \u1087 \u1082 \u1072 , \u1080  \u1089 \u1102 \u1088 \u1090 \u1091 \u1082 , \u1080  \u1073 \u1088 \u1102 \u1082 \u1080  \u1080  \u1089 \u1072 \u1087 \u1086 \u1075 \u1080 . \u1045 \u1075 \u1086  \u1090 \u1088 \u1080  \u1089 \u1099 \u1085 \u1072  \u1090 \u1086 \u1078 \u1077  \u1073 \u1099 \u1083 \u1080  \u1086 \u1076 \u1077 \u1090 \u1099  \u1074 \u1086  \u1074 \u1089 \u1077  \u1085 \u1086 \u1074 \u1086 \u1077 . \u1042 \u1086 \u1081 \u1076 \u1103 , \u1086 \u1085  \u1089 \u1088 \u1072 \u1079 \u1091  \u1085 \u1072 \u1087 \u1088 \u1072 \u1074 \u1080 \u1083 \u1089 \u1103  \u1082  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1102 .\
\'96 \uc0\u1053 \u1077 \u1090  \u1089 \u1083 \u1086 \u1074 , \u1082 \u1072 \u1082  \u1084 \u1099  \u1090 \u1077 \u1073 \u1077  \u1073 \u1083 \u1072 \u1075 \u1086 \u1076 \u1072 \u1088 \u1085 \u1099 , \'96 \u1074 \u1089 \u1082 \u1088 \u1080 \u1095 \u1072 \u1083  \u1074 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 , \u1082 \u1088 \u1077 \u1087 \u1082 \u1086  \u1087 \u1086 \u1078 \u1080 \u1084 \u1072 \u1103  \u1077 \u1084 \u1091  \u1088 \u1091 \u1082 \u1091 . \'96 \u1041 \u1080 \u1083 \u1077 \u1090 , \u1082 \u1086 \u1090 \u1086 \u1088 \u1099 \u1081  \u1090 \u1099  \u1084 \u1085 \u1077  \u1087 \u1086 \u1076 \u1072 \u1088 \u1080 \u1083 , \u1074 \u1099 \u1080 \u1075 \u1088 \u1072 \u1083  \u1079 \u1086 \u1083 \u1086 \u1090 \u1099 \u1077  \u1095 \u1072 \u1089 \u1099 . \u1071  \u1090 \u1091 \u1090  \u1078 \u1077  \u1080 \u1093  \u1087 \u1088 \u1086 \u1076 \u1072 \u1083  \u1080  \u1079 \u1072  \u1101 \u1090 \u1080  \u1076 \u1077 \u1085 \u1100 \u1075 \u1080  \u1086 \u1076 \u1077 \u1083  \u1089 \u1077 \u1084 \u1100 \u1102  \u1074 \u1086  \u1074 \u1089 \u1077  \u1085 \u1086 \u1074 \u1086 \u1077 ! \u1048  \u1089 \u1077 \u1073 \u1103 , \u1080  \u1078 \u1077 \u1085 \u1091 , \u1080  \u1089 \u1099 \u1085 \u1086 \u1074 \u1077 \u1081 , \u1080  \u1076 \u1086 \u1095 \u1077 \u1088 \u1077 \u1081 ! \u1057 \u1087 \u1072 \u1089 \u1080 \u1073 \u1086  \u1090 \u1077 \u1073 \u1077 , \u1076 \u1086 \u1088 \u1086 \u1075 \u1086 \u1081  \u1085 \u1072 \u1096  \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081 , \u1086 \u1075 \u1088 \u1086 \u1084 \u1085 \u1086 \u1077  \u1089 \u1087 \u1072 \u1089 \u1080 \u1073 \u1086 !\
\
\uc0\u1055 \u1086 \u1089 \u1083 \u1077  \u1079 \u1072 \u1074 \u1077 \u1088 \u1096 \u1077 \u1085 \u1080 \u1103  \u1087 \u1088 \u1072 \u1079 \u1076 \u1085 \u1080 \u1095 \u1085 \u1086 \u1081  \u1084 \u1086 \u1083 \u1080 \u1090 \u1074 \u1099  \u1080  \u1095 \u1090 \u1077 \u1085 \u1080 \u1103  \'ab\u1057 \u1074 \u1080 \u1090 \u1082 \u1072  \u1069 \u1089 \u1090 \u1077 \u1088 \'bb \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1074 \u1099 \u1096 \u1077 \u1083  \u1085 \u1072  \u1091 \u1083 \u1080 \u1094 \u1091 . \u1057 \u1074 \u1077 \u1090 \u1080 \u1083 \u1072  \u1083 \u1091 \u1085 \u1072 , \u1074 \u1099 \u1089 \u1086 \u1082 \u1086 \u1077  \u1090 \u1077 \u1084 \u1085 \u1086 \u1077  \u1085 \u1077 \u1073 \u1086  \u1075 \u1091 \u1089 \u1090 \u1086  \u1087 \u1086 \u1082 \u1088 \u1099 \u1074 \u1072 \u1083 \u1080  \u1089 \u1077 \u1088 \u1077 \u1073 \u1088 \u1103 \u1085 \u1099 \u1077  \u1090 \u1086 \u1095 \u1077 \u1095 \u1082 \u1080  \u1079 \u1074 \u1077 \u1079 \u1076 . \u1044 \u1086 \u1078 \u1080 \u1076 \u1072 \u1103 \u1089 \u1100  \u1078 \u1077 \u1085 \u1091  \u1087 \u1077 \u1088 \u1077 \u1076  \u1074 \u1086 \u1088 \u1086 \u1090 \u1072 \u1084 \u1080  \u1074 \u1086  \u1076 \u1074 \u1086 \u1088  \u1089 \u1080 \u1085 \u1072 \u1075 \u1086 \u1075 \u1080 , \u1086 \u1085  \u1074 \u1089 \u1077  \u1077 \u1097 \u1077  \u1085 \u1077  \u1079 \u1085 \u1072 \u1083 , \u1089 \u1087 \u1088 \u1072 \u1096 \u1080 \u1074 \u1072 \u1090 \u1100  \u1083 \u1080  \u1077 \u1077  \u1087 \u1088 \u1086  \u1095 \u1072 \u1089 \u1099  \u1080 \u1083 \u1080  \u1076 \u1086 \u1078 \u1076 \u1072 \u1090 \u1100 \u1089 \u1103 , \u1087 \u1086 \u1082 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077  \u1089 \u1072 \u1084 \u1072  \u1079 \u1072 \u1075 \u1086 \u1074 \u1086 \u1088 \u1080 \u1090  \u1085 \u1072  \u1101 \u1090 \u1091  \u1090 \u1077 \u1084 \u1091 . \
\'ab\uc0\u1044 \u1072  \u1082 \u1072 \u1082 \u1072 \u1103  \u1088 \u1072 \u1079 \u1085 \u1080 \u1094 \u1072 , \'96 \u1074 \u1076 \u1088 \u1091 \u1075  \u1087 \u1086 \u1076 \u1091 \u1084 \u1072 \u1083  \u1086 \u1085 .\'96 \u1056 \u1072 \u1079 \u1074 \u1077  \u1077 \u1089 \u1090 \u1100  \u1073 \u1086 \u1083 \u1077 \u1077  \u1089 \u1080 \u1083 \u1100 \u1085 \u1086 \u1077  \u1076 \u1086 \u1082 \u1072 \u1079 \u1072 \u1090 \u1077 \u1083 \u1100 \u1089 \u1090 \u1074 \u1086  \u1077 \u1077  \u1083 \u1102 \u1073 \u1074 \u1080 , \u1095 \u1077 \u1084  \u1101 \u1090 \u1086 \u1090  \u1085 \u1077 \u1089 \u1086 \u1089 \u1090 \u1086 \u1103 \u1074 \u1096 \u1080 \u1081 \u1089 \u1103  \u1087 \u1086 \u1076 \u1072 \u1088 \u1086 \u1082 ? \u1048  \u1093 \u1086 \u1088 \u1086 \u1096 \u1086 , \u1095 \u1090 \u1086  \u1086 \u1085  \u1076 \u1086 \u1089 \u1090 \u1072 \u1083 \u1089 \u1103  \u1074 \u1086 \u1076 \u1086 \u1074 \u1086 \u1079 \u1091  \u1080  \u1077 \u1075 \u1086  \u1089 \u1077 \u1084 \u1100 \u1077 , \u1089 \u1090 \u1086 \u1083 \u1100 \u1082 \u1086  \u1088 \u1072 \u1076 \u1086 \u1089 \u1090 \u1080  \u1080  \u1090 \u1072 \u1082 \u1080 \u1093  \u1089 \u1074 \u1077 \u1090 \u1103 \u1097 \u1080 \u1093 \u1089 \u1103  \u1083 \u1080 \u1094  \u1103  \u1076 \u1072 \u1074 \u1085 \u1086  \u1085 \u1077  \u1074 \u1080 \u1076 \u1077 \u1083 \'bb. \
 \uc0\u1053 \u1072 \u1082 \u1086 \u1085 \u1077 \u1094  \u1080 \u1079  \u1074 \u1086 \u1088 \u1086 \u1090  \u1074 \u1099 \u1096 \u1083 \u1072  \u1041 \u1077 \u1081 \u1083 \u1077  \u1080  \u1043 \u1080 \u1090 \u1083 . \u1052 \u1086 \u1088 \u1076 \u1077 \u1093 \u1072 \u1081  \u1096 \u1072 \u1075 \u1085 \u1091 \u1083  \u1085 \u1072 \u1074 \u1089 \u1090 \u1088 \u1077 \u1095 \u1091  \u1080  \u1089 \u1088 \u1072 \u1079 \u1091  \u1091 \u1074 \u1080 \u1076 \u1077 \u1083 , \u1095 \u1090 \u1086  \u1083 \u1080 \u1094 \u1086  \u1078 \u1077 \u1085 \u1099  \u1090 \u1086 \u1078 \u1077  \u1089 \u1074 \u1077 \u1090 \u1080 \u1090 \u1089 \u1103 . \
\'ab\uc0\u1050 \u1072 \u1082 \u1072 \u1103  \u1103 \u1088 \u1082 \u1072 \u1103  \u1089 \u1077 \u1075 \u1086 \u1076 \u1085 \u1103  \u1083 \u1091 \u1085 \u1072 \'bb, \'96 \u1087 \u1086 \u1076 \u1091 \u1084 \u1072 \u1083  \u1086 \u1085 , \u1080  \u1090 \u1091 \u1090  \u1078 \u1077  \u1086 \u1089 \u1077 \u1082 \u1089 \u1103 ,  \u1089 \u1086 \u1086 \u1073 \u1088 \u1072 \u1079 \u1080 \u1074 , \u1095 \u1090 \u1086  \u1085 \u1072   \u1041 \u1077 \u1081 \u1083 \u1077  \u1087 \u1088 \u1086 \u1089 \u1090 \u1086  \u1087 \u1072 \u1076 \u1072 \u1102 \u1090   \u1086 \u1090 \u1089 \u1074 \u1077 \u1090 \u1099   \u1089 \u1080 \u1103 \u1085 \u1080 \u1103  \u1043 \u1080 \u1090 \u1083 , \u1086 \u1076 \u1077 \u1090 \u1086 \u1081  \u1074  \u1085 \u1086 \u1074 \u1091 \u1102  \u1073 \u1077 \u1083 \u1080 \u1095 \u1100 \u1102  \u1096 \u1091 \u1073 \u1082 \u1091 .\
\
